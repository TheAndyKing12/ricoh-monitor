{
	_listall_recvEntryListGroup(recvEntryList);
	AddGroup();
}


/* --------------------------------------------------------------- *
 * Edit ShowModalDialog
 * --------------------------------------------------------------- */
function Edit()
{
	var isQuick = g_objAdrsEditMode.isQuick();
	var sendAddr;
	var recvFunc = g_objModalDialog.updateBodyOnly;
	var userMode = MODE_MODUSER;
	
	/* 茫聝聴茫聝颅茫聜掳茫聝卢茫聜鹿茫聝聬茫聝录茫聜聮忙露聢茫聛聶 */
	g_objAdrsListLoad.loadCompDisp();
	
	/* 忙聹陋茅聛赂忙聤聻 */
	if( g_objAdrsSelectEntry.selectIdList.length == 0 )
	{
		alert( g_textRes_guidance_noEntry );
		return;
	}
	/* 猫陇聡忙聲掳茅聛赂忙聤聻 */
	if( g_objAdrsSelectEntry.selectIdList.length > 1 )
	{
		alert( g_textRes_guidance_multiEdit );
		return;
	}
	
	/* 氓聫聳氓戮聴茫聜聮盲赂颅忙聳颅茫聛聶茫聜聥 */
	g_objAdrsListLoad.loadPause();
	
	gl_curEntryType = g_objListEntry.entryHash[g_objAdrsSelectEntry.selectIdList[0]][dataidx_entry_type];
	var entryIdx = g_objListEntry.entryHash[g_objAdrsSelectEntry.selectIdList[0]][dataidx_entry_index];
	
	g_wizardMode = MODE_MODUSER;
	if( gl_curEntryType == ENTRYTYPE_USER )
	{
		if( isQuick != true )
		{
			sendAddr = ADRS_GET_USER;
		}
		else
		{
			sendAddr = ADRS_GET_USER_WIZARD;
			recvFunc = g_objModalDialog.updateWizard;
		}
	}
	else
	{
		sendAddr = ADRS_GET_GROUP;
		userMode = "MODGROUP";
	}
	
	g_objConnectMachine.get(
		sendAddr, 
		"mode="+userMode+"&outputSpecifyModeIn=PROGRAMMED&entryIndexIn="+entryIdx,
		recvFunc
	);
	
	/* 茅聛赂忙聤聻茫聜聮氓陇聳茫聛聶 */
	adrsListSelectClear();
	
}


/* --------------------------------------------------------------- *
 * Edit,Add Group OK
 * --------------------------------------------------------------- */
function Apply()
{
	var skip = new skip_info();
	if (BaseForm) {
		if (buttonCheckFlag) { return; }
		buttonCheckFlag = true;
		MainForm.mode.value = BaseForm.mode.value;

		aplAvailSet();

		if (CurrentMethod == ADRS_GET_USER) {
			getSkipInfo(SKIP_USER_SET,EMPTY,skip);
		}
		else if (CurrentMethod == ADRS_GET_GROUP) {
			getSkipInfo(SKIP_GROUP_SET,EMPTY,skip);
		}
 		else if (CurrentMethod == ADRS_GET_USER_TEMPLATE) {
			getSkipInfo(SKIP_USERTEMPLATE_SET,EMPTY,skip);
		}

		MainForm.wayFrom.value = skip.from;
		MainForm.wayTo.value = skip.to;
	}
	else {
		return;
	}
	
	var postData = "inputSpecifyModeIn=WRITE&listUpdateIn=UPDATE&"+$(MainForm).serialize();
	
	if( gl_curEntryType == ENTRYTYPE_USER )
	{
		g_objConnectMachine.set(
			ADRS_SET_USER,
			postData,
			_listall_recvEntryListUser
			);
	}
	else
	{
		g_objConnectMachine.set( 
			ADRS_SET_GROUP,
			postData,
			_listall_recvEntryListGroup
			);
	}

}

/* --------------------------------------------------------------- *
 * recv entry list(user)
 * --------------------------------------------------------------- */
function _listall_recvEntryListUser(recvEntryList)
{
	/* 茫聝娄茫聝录茫聜露茫聝录忙聝聟氓聽卤茫聛篓茫聝娄茫聝录茫聜露茫聝录茫聜鲁茫聝录茫聝聣忙聝聟氓聽卤茫聜聮茫聙聛氓聢楼茫聙聟茫聛芦氓聡娄莽聬聠茫聛聶茫聜聥 */

	/* 茫聝娄茫聝录茫聜露茫聝录茫聜鲁茫聝录茫聝聣忙聝聟氓聽卤莽聰篓氓聡娄莽聬聠 */
	$("#span_numOfUserCode").html(recvEntryList[1][0]);
	recvEntryList.splice(1,1);

	/* 茫聝娄茫聝录茫聜露茫聝录忙聝聟氓聽卤莽聰篓氓聡娄莽聬聠 */
	var addNum = g_objListEntry.edit(recvEntryList);
	
	g_objAdrsCount.updateEntryCnt( addNum, 0 );

	g_objModalDialog.hide();
}

/* --------------------------------------------------------------- *
 * Edit,Add User Continue
 * --------------------------------------------------------------- */
function Continue()
{
	var skip = new skip_info();
	if (BaseForm) {
		if (buttonCheckFlag) {return; }
		buttonCheckFlag = true;
		MainForm.mode.value = BaseForm.mode.value;

		aplAvailSet();

		if (CurrentMethod == ADRS_GET_USER) {
			getSkipInfo(SKIP_USER_CONTINUE,EMPTY,skip);
		}
		else if (CurrentMethod == ADRS_GET_GROUP) {
			getSkipInfo(SKIP_GROUP_CONTINUE,EMPTY,skip);
		}
		MainForm.wayFrom.value = skip.from;
		MainForm.wayTo.value = skip.to;
	}
	else {
		return;
	}

	var postData = "inputSpecifyModeIn=WRITE&listUpdateIn=UPDATE&"+$(MainForm).serialize();
	
	if( gl_curEntryType == ENTRYTYPE_USER )
	{
		g_objConnectMachine.set( 
			ADRS_SET_USER,
			postData,
			_listall_recvEntryListUserContinue
			);
	}
	else
	{
		g_objConnectMachine.set( 
			ADRS_SET_GROUP,
			postData,
			_listall_recvEntryListGroupContinue
			);
	}
}

/* --------------------------------------------------------------- *
 * recv entry list(user)
 * --------------------------------------------------------------- */
function _listall_recvEntryListUserContinue(recvEntryList)
{
	_listall_recvEntryListUser(recvEntryList);
	AddUser();
}


/* >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> *
 *			[Edit Control]	Delete
 * >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> */
/* --------------------------------------------------------------- *
 * Delete OK
 * --------------------------------------------------------------- */
function Delete()
{
	/* 茫聝聴茫聝颅茫聜掳茫聝卢茫聜鹿茫聝聬茫聝录茫聜聮忙露聢茫聛聶 */
	g_objAdrsListLoad.loadCompDisp();
	var result = 0;
	/* 忙聹陋茅聛赂忙聤聻 */
	if( g_objAdrsSelectEntry.selectIdList.length == 0 )
	{
		alert( g_textRes_guidance_noEntry );
		return;
	}

	result = window.confirm( g_textRes_guidance_confDelete );
	if( false == result )
	{
		return;
	}
	
	$("#DELETE_PT").show();
	$("#CENTRA_PT").hide();
	centra_progressMsg("DELETE_PROG_G");
	
	/* 氓聫聳氓戮聴茫聜聮盲赂颅忙聳颅茫聛聶茫聜聥 */
	g_objAdrsListLoad.loadPause();
	
	var multipartData = new Object();
	var deleteEntries = "";
	jQuery.each(g_objAdrsSelectEntry.selectIdList, function()
	{
		deleteEntries += this+",";
	});
	
	multipartData["entryIndex"] = deleteEntries;
	
	g_objConnectMachine.get(
		"adrsDeleteEntries.cgi",
		"",
		g_objModalDialog.updateBodyOnly,
		multipartData,
		$("#div_progress").html()
	);
}

/* --------------------------------------------------------------- *
 * recv entry list(delete)
 * --------------------------------------------------------------- */
function adrsListDelete(deleteEntries,userCodeNum)
{
	var deleteEntryArray;
	try
	{
		deleteEntryArray = eval("["+deleteEntries+"]");
	}
	catch(error)
	{
		/* 茅聙職盲驴隆茫聜篓茫聝漏茫聝录 */
		$(".message").append("<span class='meserror'>"+g_textRes_errorMessage+"</span>");
		return;
	}

	/* 茫聝娄茫聝录茫聜露茫聝录茫聜鲁茫聝录茫聝聣忙聝聟氓聽卤莽聰篓氓聡娄莽聬聠 */
	$("#span_numOfUserCode").html(userCodeNum);

	if( deleteEntryArray.length == 0 )
	{
		return;
	}
	g_objListEntry.del( deleteEntryArray );
	
	/* 茫聜陆茫聝录茫聝聢 */
	g_objListEntry.sort(null);
}

/* >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> *
 *			[Add/Edit User/Group]	Common
 * >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> */
/* --------------------------------------------------------------- *
 * submit form
 * --------------------------------------------------------------- */
function formSubmit(form)
{
	aplAvailSet();

	var postData = $(form).serialize();

	g_objConnectMachine.set(
		form.action,
		postData,
		g_objModalDialog.updateBodyOnly
	);
	
	g_objModalDialog.update("");

	return;
}

function uploadSubmit(form)
{
	ajax_upload( form, g_objModalDialog.updateBodyOnly );
	g_objModalDialog.update("");

}
function jumpButtonURL()
{
	g_objModalDialog.hide();
	adrsCentraModalClose();
}


/* >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> *
 *						List Edit Control
 * >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> */
function Maintenance(mode)
{
	/* CSRF氓炉戮氓驴聹 */
	var wimTokenNum = $("input[name='wimToken']").val()

	location.href = ADRS_MAINTENANCE + "?mode="+mode+"&wimToken="+wimTokenNum;
	ItemDisable_PageDisable(document.getElementById(MODALDIALOG_PARENT_ID));
}

function UserTemplate()
{
	/* CSRF氓炉戮氓驴聹 */
	var wimTokenNum = $("input[name='wimToken']").val()

	location.href = ADRS_GET_USER_TEMPLATE + "?mode=USER_TEMPLATE&outputSpecifyModeIn=DEFAULT&wimToken="+wimTokenNum;
	ItemDisable_PageDisable(document.getElementById(MODALDIALOG_PARENT_ID));
}

function AdrsCentra()
{
	/* CSRF氓炉戮氓驴聹 */
	var wimTokenNum = $("input[name='wimToken']").val()

	location.href = ADRS_CENTRA + "?mode=CENTRA&wimToken="+wimTokenNum;
	ItemDisable_PageDisable(document.getElementById(MODALDIALOG_PARENT_ID));
}

function Reload()
{
	location.href = ADRS_LIST;
}
/* --------------------------------------------------------------- *
 * Delete Cancel
 * --------------------------------------------------------------- */
function adrsListJump()
{
	g_objModalDialog.hide();
}

function adrsGenErrOk()
{
	openTopPage();
}

function adrsServerSyncOk()
{
	$("#syncNotify").hide();
	adrsCentraListJump();
}

function adrsCliSyncOk()
{
	Reload();
}

function adrsCentraListJump()
{
	adrsCentraModalClose();
}
function adrsCentraModalClose()
{
	if( gl_centraModalDialog )
	{
		gl_centraModalDialog.hidden(MODALDIALOG_PARENT_ID);
	}
}

