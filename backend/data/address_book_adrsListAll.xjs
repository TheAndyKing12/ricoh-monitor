/* --------------------------------------------------------------- *
 * Add User ShowModalDialog
 * --------------------------------------------------------------- */
function AddUser()
{
	/* 茫聝聴茫聝颅茫聜掳茫聝卢茫聜鹿茫聝聬茫聝录茫聜聮忙露聢茫聛聶 */
	g_objAdrsListLoad.loadCompDisp();
	/* 氓聫聳氓戮聴茫聜聮盲赂颅忙聳颅茫聛聶茫聜聥 */
	g_objAdrsListLoad.loadPause();
	
	gl_curEntryType = ENTRYTYPE_USER;
	var isQuick = g_objAdrsEditMode.isQuick();
	var sendAddr = ADRS_GET_USER_WIZARD;
	var recvFunc = g_objModalDialog.updateWizard;
	g_wizardMode = MODE_ADDUSER;
	if( isQuick != true )
	{
		sendAddr = ADRS_GET_USER;
		recvFunc = g_objModalDialog.updateBodyOnly;
	}
	
	g_objConnectMachine.get(
		sendAddr,
		"mode=ADDUSER&outputSpecifyModeIn=DEFAULT",
		recvFunc
	);

}

