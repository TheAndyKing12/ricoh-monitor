/* --------------------------------------------------------------- *
 * recv entry list(group)
 * --------------------------------------------------------------- */
function _listall_recvEntryListGroup(recvEntryList)
{
	/* 茫聜掳茫聝芦茫聝录茫聝聴忙聝聟氓聽卤茫聛篓茫聝娄茫聝录茫聜露茫聝录茫聜鲁茫聝录茫聝聣忙聝聟氓聽卤茫聜聮茫聙聛氓聢楼茫聙聟茫聛芦氓聡娄莽聬聠茫聛聶茫聜聥 */

	/* 茫聝娄茫聝录茫聜露茫聝录茫聜鲁茫聝录茫聝聣忙聝聟氓聽卤莽聰篓氓聡娄莽聬聠 */
	$("#span_numOfUserCode").html(recvEntryList[1][0]);
	recvEntryList.splice(1,1);

	/* 茫聜掳茫聝芦茫聝录茫聝聴忙聝聟氓聽卤莽聰篓氓聡娄莽聬聠 */
	var addNum = g_objListEntry.edit(recvEntryList);

	/* 氓聙陇忙聸麓忙聳掳 */
	g_objAdrsCount.updateEntryCnt( 0 , addNum );
	
	g_objModalDialog.hide();
}

