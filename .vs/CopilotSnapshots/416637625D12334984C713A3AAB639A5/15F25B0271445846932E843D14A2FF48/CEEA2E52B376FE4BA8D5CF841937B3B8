import requests
import re

def get_ricoh_http_counters(ip):
    url = f"http://{ip}/web/guest/es/websys/status/getUnificationCounter.cgi"
    try:
        r = requests.get(url, timeout=5)
        html = r.text
        # buscar contadores
        bw_match = re.search(r"Blanco y Negro.*?(\d+)", html, re.DOTALL | re.IGNORECASE)
        color_match = re.search(r"A todo color.*?(\d+)", html, re.DOTALL | re.IGNORECASE)
        # intentar contadores adicionales (copias / impresiones)
        copy_bw_match = re.search(r"Copias?\s*(?:B[/\\]N|blanco y negro).*?(\d+)", html, re.DOTALL | re.IGNORECASE)
        copy_color_match = re.search(r"Copias?\s*(?:Color|a todo color).*?(\d+)", html, re.DOTALL | re.IGNORECASE)
        print_bw_match = re.search(r"Impresi[oó]n(?:es)?\s*(?:B[/\\]N|blanco y negro).*?(\d+)", html, re.DOTALL | re.IGNORECASE)
        print_color_match = re.search(r"Impresi[oó]n(?:es)?\s*(?:Color|a todo color).*?(\d+)", html, re.DOTALL | re.IGNORECASE)

        bw = int(bw_match.group(1)) if bw_match else None
        color = int(color_match.group(1)) if color_match else None
        copy_bw = int(copy_bw_match.group(1)) if copy_bw_match else None
        copy_color = int(copy_color_match.group(1)) if copy_color_match else None
        print_bw = int(print_bw_match.group(1)) if print_bw_match else None
        print_color = int(print_color_match.group(1)) if print_color_match else None

        total = None
        if bw is not None and color is not None:
            try:
                total = bw + color
            except Exception:
                total = None

        return {
            "bw_pages": bw,
            "color_pages": color,
            "total_pages": total,
            "copy_bw": copy_bw,
            "copy_color": copy_color,
            "print_bw": print_bw,
            "print_color": print_color
        }
    except Exception as e:
        print("HTTP counter error:", e)
        return None