from pysnmp.hlapi import SnmpEngine, CommunityData, UdpTransportTarget, ContextData, ObjectType, ObjectIdentity, getCmd, nextCmd


def get_snmp_values(ip, community, oids, timeout=1, retries=0):
    """Perform a single SNMP GET for multiple OIDs and return a dict oid->value.

    Returns None for OIDs that could not be retrieved.
    """
    if not oids:
        return {}
    object_types = [ObjectType(ObjectIdentity(oid)) for oid in oids]
    iterator = getCmd(
        SnmpEngine(),
        CommunityData(community, mpModel=1),
        UdpTransportTarget((ip, 161), timeout=timeout, retries=retries),
        ContextData(),
        *object_types
    )
    try:
        error_indication, error_status, error_index, var_binds = next(iterator)
    except StopIteration:
        return {oid: None for oid in oids}
    if error_indication or error_status:
        return {oid: None for oid in oids}
    result = {}
    for i, var_bind in enumerate(var_binds):
        try:
            result[oids[i]] = var_bind[1]
        except Exception:
            result[oids[i]] = None
    return result


def get_snmp_value(ip, community, oid, timeout=1, retries=0):
    vals = get_snmp_values(ip, community, [oid], timeout=timeout, retries=retries)
    if not vals:
        return None
    return vals.get(oid)


def get_snmp_walk(ip, community, oid_prefix='1.3.6.1.2.1', max_rows=1000, timeout=1, retries=0):
    """Perform an SNMP walk (GETNEXT) starting at oid_prefix.

    Returns a list of (oid_str, value_str) tuples up to max_rows.
    """
    rows = []
    iterator = nextCmd(
        SnmpEngine(),
        CommunityData(community, mpModel=1),
        UdpTransportTarget((ip, 161), timeout=timeout, retries=retries),
        ContextData(),
        ObjectType(ObjectIdentity(oid_prefix)),
        lexicographicMode=False
    )
    try:
        for i, (error_indication, error_status, error_index, var_binds) in enumerate(iterator):
            if error_indication:
                break
            if error_status:
                break
            for var_bind in var_binds:
                try:
                    oid = str(var_bind[0])
                    val = var_bind[1]
                    rows.append((oid, str(val)))
                except Exception:
                    continue
            if len(rows) >= max_rows:
                break
    except Exception:
        pass
    return rows