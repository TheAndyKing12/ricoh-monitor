from fastapi import APIRouter, Depends, HTTPException, Query
from pydantic import BaseModel
from sqlalchemy.orm import Session
from pathlib import Path
import json
import threading
import os
import re
import time
import base64
import requests

from ..database import SessionLocal
from .. import crud

router = APIRouter(prefix="/printers", tags=["AddressBook"])

STORE_LOCK = threading.Lock()
STORE_PATH = Path(__file__).resolve().parents[2] / "data" / "address_book_store.json"
DEFAULT_STORAGE_MODE = "ricoh-real"
SUPPORTED_STORAGE_MODES = {"local-safe", "ricoh-real"}
RICOH_HTTP_TIMEOUT = 8
RAW_DUMP_PATH = Path(__file__).resolve().parents[2] / "data" / "address_book_last_raw_response.html"
ADRSLIST_DUMP_PATH = Path(__file__).resolve().parents[2] / "data" / "address_book_last_page.html"


class AddressBookEntryBase(BaseModel):
    name: str
    key_display: str | None = None
    freq: bool = True
    title1: str | None = None
    title2: str | None = None
    title3: str | None = None
    user_code: str | None = None
    email_address: str | None = None
    folder: str | None = None
    status: str | None = "Activo"


class AddressBookEntryCreate(AddressBookEntryBase):
    registration_no: str | None = None


class AddressBookEntryUpdate(BaseModel):
    name: str | None = None
    key_display: str | None = None
    freq: bool | None = None
    title1: str | None = None
    title2: str | None = None
    title3: str | None = None
    user_code: str | None = None
    email_address: str | None = None
    folder: str | None = None
    status: str | None = None


class AddressBookEntry(AddressBookEntryBase):
    registration_no: str


class AddressBookListResponse(BaseModel):
    printer_id: int
    printer_ip: str
    storage_mode: str
    entries: list[AddressBookEntry]


def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()


def _ensure_store_dir():
    STORE_PATH.parent.mkdir(parents=True, exist_ok=True)


def _load_store() -> dict:
    _ensure_store_dir()
    if not STORE_PATH.exists():
        return {}
    try:
        return json.loads(STORE_PATH.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _save_store(data: dict):
    _ensure_store_dir()
    STORE_PATH.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")


def _get_printer_or_404(db: Session, printer_id: int):
    printer = crud.get_printer_by_id(db, printer_id)
    if not printer:
        raise HTTPException(status_code=404, detail="Printer not found")
    return printer


def _sort_entries(entries: list[dict]) -> list[dict]:
    def is_zero_registration(value) -> bool:
        text = str(value or "").strip()
        return text.isdigit() and int(text) == 0

    cleaned = [item for item in (entries or []) if not is_zero_registration(item.get("registration_no"))]
    return sorted(cleaned, key=lambda item: int(str(item.get("registration_no") or "0")))


def _next_registration_no(entries: list[dict]) -> str:
    max_value = 0
    for entry in entries:
        try:
            max_value = max(max_value, int(str(entry.get("registration_no") or "0")))
        except Exception:
            continue
    return str(max_value + 1).zfill(5)


def _get_storage_mode(override_mode: str | None = None) -> str:
    if override_mode:
        mode = override_mode.strip().lower()
        if mode in SUPPORTED_STORAGE_MODES:
            return mode
    mode = (os.getenv("ADDRESS_BOOK_STORAGE_MODE", DEFAULT_STORAGE_MODE) or DEFAULT_STORAGE_MODE).strip().lower()
    return mode if mode in SUPPORTED_STORAGE_MODES else DEFAULT_STORAGE_MODE


def _get_local_entries(printer_id: int) -> list[dict]:
    with STORE_LOCK:
        store = _load_store()
        return _sort_entries(store.get(str(printer_id), []))


def _create_local_entry(printer_id: int, payload: AddressBookEntryCreate) -> dict:
    with STORE_LOCK:
        store = _load_store()
        entries = store.setdefault(str(printer_id), [])
        registration_no = (payload.registration_no or "").strip() or _next_registration_no(entries)
        if any(str(item.get("registration_no")) == registration_no for item in entries):
            raise HTTPException(status_code=400, detail="Registration number already exists")
        entry = payload.dict()
        entry["registration_no"] = registration_no
        entries.append(entry)
        store[str(printer_id)] = _sort_entries(entries)
        _save_store(store)
    return entry


def _update_local_entry(printer_id: int, registration_no: str, payload: AddressBookEntryUpdate) -> dict:
    with STORE_LOCK:
        store = _load_store()
        entries = store.get(str(printer_id), [])
        target = next((item for item in entries if str(item.get("registration_no")) == registration_no), None)
        if not target:
            raise HTTPException(status_code=404, detail="Address book entry not found")
        for key, value in payload.dict(exclude_unset=True).items():
            target[key] = value
        store[str(printer_id)] = _sort_entries(entries)
        _save_store(store)
    return target


def _delete_local_entry(printer_id: int, registration_no: str):
    with STORE_LOCK:
        store = _load_store()
        entries = store.get(str(printer_id), [])
        new_entries = [item for item in entries if str(item.get("registration_no")) != registration_no]
        if len(new_entries) == len(entries):
            raise HTTPException(status_code=404, detail="Address book entry not found")
        store[str(printer_id)] = _sort_entries(new_entries)
        _save_store(store)


def _ricoh_credentials() -> tuple[str, str]:
    user = (os.getenv("RICOH_ADDRESSBOOK_USER", "admin") or "admin").strip()
    password = os.getenv("RICOH_ADDRESSBOOK_PASSWORD", "") or ""
    return user, password


def _ricoh_build_session(printer_ip: str) -> requests.Session:
    session = requests.Session()
    session.headers.update({"User-Agent": "Mozilla/5.0 (compatible)"})
    session.cookies.set("cookieOnOffChecker", "on", path="/")
    return session


def _ricoh_login_address_book(session: requests.Session, printer_ip: str):
    user, password = _ricoh_credentials()
    auth_url = f"http://{printer_ip}/web/guest/es/websys/webArch/authForm.cgi?open=address/adrsList.cgi"
    login_url = f"http://{printer_ip}/web/guest/es/websys/webArch/login.cgi"

    auth_resp = session.get(auth_url, timeout=RICOH_HTTP_TIMEOUT)
    if auth_resp.status_code != 200:
        raise HTTPException(status_code=502, detail="Ricoh auth form not available")

    token_match = re.search(r'name=["\']wimToken["\'][^>]*value=["\']([^"\']*)["\']', auth_resp.text, re.IGNORECASE)
    token = token_match.group(1) if token_match else ""

    payload = {
        "userid_work": "",
        "userid": base64.b64encode(user.encode("utf-8")).decode("ascii"),
        "password_work": "",
        "password": base64.b64encode(password.encode("utf-8")).decode("ascii"),
        "open": "address/adrsList.cgi",
        "wimToken": token,
    }

    login_resp = session.post(login_url, data=payload, timeout=RICOH_HTTP_TIMEOUT)
    if login_resp.status_code != 200:
        raise HTTPException(status_code=502, detail="Ricoh login failed")

    session.get(f"http://{printer_ip}/web/entry/es/address/adrsList.cgi", timeout=RICOH_HTTP_TIMEOUT)


def _is_noise_name(value: str) -> bool:
    text = (value or "").strip().lower()
    if not text:
        return True
    noise_tokens = (
        "location",
        "concat(",
        "background-color",
        "function(",
        "var ",
        "document.",
        "window.",
        "http://",
        "https://",
        "websys/",
        "cgi",
        "<script",
        "</script",
        "{",
        "}",
        ";",
    )
    return any(token in text for token in noise_tokens)


def _is_plausible_reg(reg: str) -> bool:
    s = str(reg or "").strip()
    if not re.fullmatch(r"\d{1,6}", s):
        return False
    n = int(s)
    return 1 <= n <= 99999


def _entry_dict(reg: str, name: str) -> dict:
    return {
        "registration_no": str(reg).zfill(5),
        "name": name,
        "key_display": None,
        "freq": True,
        "title1": None,
        "title2": None,
        "title3": None,
        "user_code": None,
        "email_address": None,
        "folder": None,
        "status": "Activo",
    }


def _ricoh_parse_entries_from_html(content: str) -> list[dict]:
    entries: list[dict] = []
    html = content or ""
    rows = re.findall(r"<tr[^>]*>(.*?)</tr>", html, flags=re.IGNORECASE | re.DOTALL)
    for row in rows:
        cols_raw = re.findall(r"<t[dh][^>]*>(.*?)</t[dh]>", row, flags=re.IGNORECASE | re.DOTALL)
        if not cols_raw:
            continue
        cols = [re.sub(r"<[^>]+>", " ", c) for c in cols_raw]
        cols = [re.sub(r"\s+", " ", c).strip() for c in cols]
        reg = None
        for col in cols:
            if re.fullmatch(r"\d{1,6}", col or "") and _is_plausible_reg(col):
                reg = col
                break
        if not reg:
            continue
        name = ""
        for col in cols:
            if col and not re.fullmatch(r"\d{1,6}", col):
                if not _is_noise_name(col):
                    name = col
                    break
        if not name:
            continue
        entries.append(_entry_dict(reg, name))

    if not entries:
        for reg, name in re.findall(r"[\"'](\d{1,6})[\"']\s*[,;]\s*[\"']([^\"']{1,120})[\"']", html):
            clean_name = re.sub(r"\s+", " ", name).strip()
            if _is_plausible_reg(reg) and clean_name and not _is_noise_name(clean_name):
                entries.append(_entry_dict(reg, clean_name))

    dedup: dict[str, dict] = {}
    for entry in entries:
        dedup[entry["registration_no"]] = entry
    return _sort_entries(list(dedup.values()))


def _ricoh_parse_entries(content: str) -> list[dict]:
    content = content or ""
    stripped = content.strip()
    if not stripped:
        return []

    try:
        payload = json.loads(stripped)
        candidates = payload if isinstance(payload, list) else payload.get("entries") if isinstance(payload, dict) else None
        if isinstance(candidates, list):
            parsed: list[dict] = []
            for item in candidates:
                if not isinstance(item, dict):
                    continue
                registration_no = str(item.get("registration_no") or item.get("registrationNo") or item.get("regNo") or "").strip()
                name = str(item.get("name") or item.get("displayName") or item.get("userName") or "").strip()
                if not _is_plausible_reg(registration_no):
                    continue
                if not name or _is_noise_name(name):
                    continue
                parsed.append({
                    "registration_no": registration_no.zfill(5),
                    "name": name,
                    "key_display": item.get("key_display") or item.get("keyDisplay"),
                    "freq": bool(item.get("freq", True)),
                    "title1": item.get("title1"),
                    "title2": item.get("title2"),
                    "title3": item.get("title3"),
                    "user_code": item.get("user_code") or item.get("userCode"),
                    "email_address": item.get("email_address") or item.get("emailAddress"),
                    "folder": item.get("folder"),
                    "status": item.get("status") or "Activo",
                })
            if parsed:
                return _sort_entries(parsed)
    except Exception:
        pass

    js_like_rows = re.findall(r"\[\s*(\d+)\s*,\s*(\d+)\s*,\s*'([^']+)'\s*,\s*'([^']+)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*\]", stripped)
    if js_like_rows:
        parsed_js: list[dict] = []
        for _, freq_flag, reg, name, user_code, _, email, folder in js_like_rows:
            reg_text = (reg or "").strip()
            name_text = (name or "").strip()
            if not _is_plausible_reg(reg_text):
                continue
            if not name_text or _is_noise_name(name_text):
                continue
            parsed_js.append({
                "registration_no": reg_text.zfill(5),
                "name": name_text,
                "key_display": name_text,
                "freq": str(freq_flag).strip() == "1",
                "title1": None,
                "title2": None,
                "title3": None,
                "user_code": (user_code or "").strip() or None,
                "email_address": (email or "").strip() or None,
                "folder": (folder or "").strip() or None,
                "status": "Activo",
            })
        if parsed_js:
            dedup: dict[str, dict] = {}
            for entry in parsed_js:
                dedup[entry["registration_no"]] = entry
            return _sort_entries(list(dedup.values()))

    lines = [ln.strip() for ln in re.split(r"\r?\n", stripped) if ln.strip()]
    parsed_lines: list[dict] = []
    for line in lines:
        if line.startswith("<"):
            continue
        if _is_noise_name(line):
            continue
        parts = [p.strip() for p in re.split(r"\t|;|\|", line) if p.strip()]
        reg = next((p for p in parts if _is_plausible_reg(p)), None)
        if not reg:
            m = re.search(r"\b(\d{1,6})\b", line)
            reg = m.group(1) if m and _is_plausible_reg(m.group(1)) else None
        if not reg:
            continue
        name = None
        for p in parts:
            if p != reg and not re.fullmatch(r"\d{1,6}", p) and not _is_noise_name(p):
                name = p
                break
        if not name:
            m_name = re.search(r"\b\d{1,6}\b\s+([A-Za-zÁÉÍÓÚÑáéíóúñ0-9 .,_\-()]{2,120})", line)
            candidate = m_name.group(1).strip() if m_name else ""
            name = candidate if candidate and not _is_noise_name(candidate) else None
        if not name:
            continue
        parsed_lines.append(_entry_dict(reg, name))
    if parsed_lines:
        dedup: dict[str, dict] = {}
        for entry in parsed_lines:
            dedup[entry["registration_no"]] = entry
        return _sort_entries(list(dedup.values()))

    return _ricoh_parse_entries_from_html(content)


def _get_ricoh_entries(printer) -> list[dict]:
    session = _ricoh_build_session(printer.ip)
    _ricoh_login_address_book(session, printer.ip)

    list_page_resp = session.get(f"http://{printer.ip}/web/entry/es/address/adrsList.cgi", timeout=RICOH_HTTP_TIMEOUT)
    ADRSLIST_DUMP_PATH.parent.mkdir(parents=True, exist_ok=True)
    ADRSLIST_DUMP_PATH.write_text(list_page_resp.text or "", encoding="utf-8", errors="ignore")

    endpoint = f"http://{printer.ip}/web/entry/es/address/adrsListLoadEntry.cgi"
    params = {
        "_": str(int(time.time() * 1000)),
        "listCountIn": "50",
        "getCountIn": "1",
    }
    headers = {
        "Accept": "text/plain, */*",
        "X-Requested-With": "XMLHttpRequest",
        "Referer": f"http://{printer.ip}/web/entry/es/address/adrsList.cgi",
    }

    response = session.get(endpoint, params=params, headers=headers, timeout=RICOH_HTTP_TIMEOUT)
    if response.status_code != 200:
        raise HTTPException(status_code=502, detail=f"Ricoh address-book list request failed ({response.status_code})")

    if "Tiempo de sesión agotado" in (response.text or ""):
        _ricoh_login_address_book(session, printer.ip)
        response = session.get(endpoint, params=params, headers=headers, timeout=RICOH_HTTP_TIMEOUT)
        if response.status_code != 200:
            raise HTTPException(status_code=502, detail=f"Ricoh address-book retry failed ({response.status_code})")

    try:
        RAW_DUMP_PATH.parent.mkdir(parents=True, exist_ok=True)
        RAW_DUMP_PATH.write_text(response.text or "", encoding="utf-8", errors="ignore")
    except Exception:
        pass

    if "Ricoh Monitor Dashboard" in (response.text or ""):
        raise HTTPException(
            status_code=502,
            detail="La respuesta no es de la Ricoh (se detectó HTML del dashboard). Revise IP/ruta/proxy."
        )

    entries = _ricoh_parse_entries(response.text)
    return _sort_entries(entries)


def _ricoh_real_not_ready() -> None:
    raise HTTPException(
        status_code=501,
        detail="Ricoh real address book write integration is not configured yet"
    )


def _create_ricoh_entry(printer, payload: AddressBookEntryCreate) -> dict:
    return _create_local_entry(printer.id, payload)


def _update_ricoh_entry(printer, registration_no: str, payload: AddressBookEntryUpdate) -> dict:
    return _update_local_entry(printer.id, registration_no, payload)


def _delete_ricoh_entry(printer, registration_no: str):
    return _delete_local_entry(printer.id, registration_no)


def _merge_entries(base_entries: list[dict], overlay_entries: list[dict]) -> list[dict]:
    merged: dict[str, dict] = {}
    for entry in base_entries or []:
        reg = str(entry.get("registration_no") or "").strip()
        if reg:
            merged[reg] = entry
    for entry in overlay_entries or []:
        reg = str(entry.get("registration_no") or "").strip()
        if reg:
            merged[reg] = entry
    return _sort_entries(list(merged.values()))


@router.get("/{printer_id}/address-book", response_model=AddressBookListResponse)
def list_address_book(printer_id: int, storage_mode: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    storage_mode = _get_storage_mode(storage_mode)
    if storage_mode == "ricoh-real":
        ricoh_entries = _get_ricoh_entries(printer)
        overlay_entries = _get_local_entries(printer_id)
        entries = _merge_entries(ricoh_entries, overlay_entries)
    else:
        entries = _get_local_entries(printer_id)
    return {
        "printer_id": printer.id,
        "printer_ip": printer.ip,
        "storage_mode": storage_mode,
        "entries": entries,
    }


@router.post("/{printer_id}/address-book", response_model=AddressBookEntry)
def create_address_book_entry(printer_id: int, payload: AddressBookEntryCreate, storage_mode: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    storage_mode = _get_storage_mode(storage_mode)
    if storage_mode == "ricoh-real":
        return _create_ricoh_entry(printer, payload)
    return _create_local_entry(printer_id, payload)


@router.put("/{printer_id}/address-book/{registration_no}", response_model=AddressBookEntry)
def update_address_book_entry(printer_id: int, registration_no: str, payload: AddressBookEntryUpdate, storage_mode: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    storage_mode = _get_storage_mode(storage_mode)
    if storage_mode == "ricoh-real":
        return _update_ricoh_entry(printer, registration_no, payload)
    return _update_local_entry(printer_id, registration_no, payload)


@router.delete("/{printer_id}/address-book/{registration_no}")
def delete_address_book_entry(printer_id: int, registration_no: str, storage_mode: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    storage_mode = _get_storage_mode(storage_mode)
    if storage_mode == "ricoh-real":
        _delete_ricoh_entry(printer, registration_no)
    else:
        _delete_local_entry(printer_id, registration_no)
    return {"message": "Address book entry deleted"}
