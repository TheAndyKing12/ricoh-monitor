<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Ricoh Monitor Dashboard</title>
    <link rel="stylesheet" href="style.css">
<style>
*{box-sizing:border-box}
body{margin:0;font-family:Arial,sans-serif;background:#111827;color:#f3f4f6}
.layout{display:flex;min-height:100vh}
.sidebar{width:240px;background:#0f172a;border-right:1px solid #1f2937;padding:20px}
.sidebar h2{margin:0 0 20px 0;font-size:22px}
.menu-button{width:100%;background:#111827;color:#e5e7eb;border:1px solid #374151;border-radius:10px;padding:12px 14px;text-align:left;font-size:14px;cursor:pointer;margin-bottom:10px;transition:.2s ease}
.menu-button:hover{background:#1f2937}
.sidebar{width:64px;background:#0f172a;border-right:1px solid #1f2937;padding:12px 8px;transition:width .28s ease}
.sidebar:hover{width:240px;padding:20px}
.sidebar h2{margin:0 0 12px 0;font-size:18px;transition:opacity .18s ease,transform .18s ease}
.sidebar-title{display:inline-block;opacity:1;transform:none;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .sidebar-title{opacity:0;transform:translateX(-8px)}
.menu-button{display:flex;align-items:center;gap:10px;justify-content:center}
.sidebar:hover .menu-button{justify-content:flex-start}
.menu-label{display:inline-block;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .menu-label{opacity:0;transform:translateX(-6px);width:0;overflow:hidden}
.content{flex:1;display:flex;flex-direction:column}
header{padding:14px 20px;background:#0f172a;border-bottom:1px solid #1f2937;display:flex;flex-direction:column;gap:12px}
h1{margin:0;font-size:24px}
.subtitle{font-size:13px;color:#9ca3af;margin-top:4px}
.badge{padding:8px 12px;border-radius:999px;background:#1f2937;font-size:13px}
.tab{display:none;padding:12px}
.tab.active{display:block;animation:tabFadeIn .18s ease}
@keyframes tabFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:12px}
.summary-card{background:#1f2937;border:1px solid #374151;border-radius:14px;padding:18px}
.summary-card h3{margin:0 0 8px;font-size:14px;color:#9ca3af;font-weight:normal}
.summary-card .value{font-size:28px;font-weight:bold}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:18px}
.card{background:#1f2937;border:1px solid #374151;border-radius:16px;padding:18px;box-shadow:0 2px 12px rgba(0,0,0,.25)}
.card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px}
.printer-name{font-size:18px;font-weight:bold;margin:0}
.printer-model{margin-top:4px;font-size:13px;color:#9ca3af}
.status-pill{padding:6px 10px;border-radius:999px;font-size:12px;font-weight:bold;text-transform:uppercase;white-space:nowrap}
.status-online{background:rgba(34,197,94,.18);color:#22c55e;border:1px solid rgba(34,197,94,.4)}
.status-offline{background:rgba(239,68,68,.18);color:#ef4444;border:1px solid rgba(239,68,68,.4)}
.info-row{font-size:13px;color:#d1d5db;margin-bottom:6px}
.toner-section{margin-top:16px}
.toner-title{font-size:13px;color:#9ca3baf;margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em}
.toner-item{margin-bottom:12px}
.toner-label-row{display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px}
.bar{width:100%;height:12px;background:#111827;border-radius:999px;overflow:hidden;border:1px solid #374151}
.bar-fill{height:100%;border-radius:999px;transition:width .4s ease}
.bar-black{background:#e5e7eb}.bar-cyan{background:#06b6d4}.bar-magenta{background:#d946ef}.bar-yellow{background:#eab308}
.empty-state,.placeholder-card{text-align:center;padding:60px 20px;color:#9ca3af;background:#1f2937;border-radius:16px;border:1px solid #374151}
.warning-text{color:#f59e0b;font-size:12px;margin-top:8px}
.critical-text{color:#ef4444;font-size:12px;margin-top:8px}
.section-title{margin-top:0;margin-bottom:16px;font-size:24px}
.action-row{display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap}
.action-button{background:#2563eb;color:#fff;border:none;border-radius:10px;padding:12px 16px;cursor:pointer;font-size:14px}
.action-button:hover{background:#1d4ed8}
.action-button-danger{background:#dc2626}
.action-button-danger:hover{background:#b91c1c}
.action-button-secondary{background:#475569}
.action-button-secondary:hover{background:#334155}
.table-wrapper{background:#1f2937;border:1px solid #374151;border-radius:16px;overflow:auto;max-width:100%;max-height:70vh}
table{width:100%;border-collapse:collapse;min-width:1100px}
th,td{padding:14px;text-align:left;border-bottom:1px solid #374151;font-size:14px;vertical-align:top}
th{background:#111827;color:#9ca3af}
tr:last-child td{border-bottom:none}
/* Form layout improvements */
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.form-grid > div{display:flex;flex-direction:column;gap:6px}
.form-grid label{display:block;font-size:13px;color:#cbd5e1;font-weight:600}
input,select{padding:10px;border-radius:8px;border:1px solid #374151;background:#111827;color:white;width:100%}
/* Header styling */
.dashboard-title{font-size:24px;font-weight:700;color:#f8fafc;line-height:1.1}
.dashboard-header{width:100%;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.dashboard-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.dashboard-topbar{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:8px;flex-wrap:wrap}
.dashboard-topbar-left{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.filter-toggle-btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;min-width:220px;min-height:44px;background:linear-gradient(180deg,#1e293b 0%,#162033 100%);border:1px solid #3b4d65;color:#f8fafc;border-radius:999px;padding:10px 16px;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.22);transition:.2s ease}
.filter-toggle-btn:hover{transform:translateY(-1px);background:linear-gradient(180deg,#25344b 0%,#1a2638 100%)}
.filter-toggle-btn.is-open{background:linear-gradient(180deg,#1d4ed8 0%,#1e40af 100%);border-color:#60a5fa;box-shadow:0 6px 18px rgba(37,99,235,.28)}
.filter-toggle-btn.is-open .filter-toggle-state{color:#dbeafe}
.filter-toggle-icon{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:999px;background:#111827;border:1px solid #334155;font-size:12px;color:#cbd5e1;flex:0 0 auto}
.filter-toggle-btn.is-open .filter-toggle-icon{background:rgba(15,23,42,.6);border-color:#93c5fd;color:#eff6ff}
.fullscreen .sidebar{display:none !important}
</style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <h2><span class="sidebar-title">Ricoh Monitor</span></h2>
        <button class="menu-button" onclick="showTab('dashboard')"><span class="menu-label">Dashboard</span></button>
        <button class="menu-button" onclick="showTab('printers')"><span class="menu-label">Impresoras</span></button>
        <button class="menu-button" onclick="showTab('counters')"><span class="menu-label">Contadores</span></button>
        <button class="menu-button" onclick="showTab('inventory')"><span class="menu-label">Inventario</span></button>
        <button class="menu-button" onclick="showTab('tonerControl')"><span class="menu-label">Control de Toner</span></button>
    </aside>

    <main class="content">
        <!-- Header moved inside the dashboard tab so it only appears on that tab -->

        <div id="dashboard" class="tab dashboard-shell">
            <header>
                <div class="dashboard-header" style="width:100%;display:flex;justify-content:space-between;align-items:center;gap:12px">
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <div class="dashboard-title">Ricoh Monitor Dashboard</div>
                        <div class="badge" id="lastUpdate" style="padding:6px 10px;font-size:12px">Actualizando...</div>
                    </div>
                    <div class="dashboard-actions" style="display:flex;gap:8px;align-items:center">
                        <button id="dashboardFilterBtn" class="filter-toggle-btn" type="button" onclick="toggleDashboardFilters()">
                            <span class="filter-toggle-icon" id="filterToggleIcon">▾</span>
                            <span>Filtros del dashboard</span>
                            <span class="filter-toggle-state" id="filterToggleState">Ocultos</span>
                        </button>
                        <button id="fullscreenBtn" class="filter-toggle-btn" type="button" onclick="toggleDashboardFullscreen()" title="Pantalla completa">
                            <span class="filter-toggle-icon" id="fullscreenBtnIcon">⛶</span>
                            <span id="fullscreenBtnLabel">Pantalla completa</span>
                        </button>
                    </div>
                </div>

                <!-- Move summary cards into header to show metrics at top -->
                <div class="summary" style="width:100%;margin:0;">
                    <div class="summary-card"><h3>Total impresoras</h3><div class="value" id="totalPrinters">0</div></div>
                    <div class="summary-card"><h3>Online</h3><div class="value" id="onlinePrinters">0</div></div>
                    <div class="summary-card"><h3>Offline</h3><div class="value" id="offlinePrinters">0</div></div>
                    <div class="summary-card"><h3>Tóner bajo</h3><div class="value" id="lowTonerPrinters">0</div></div>
                </div>
            </header>
            <div class="dashboard-topbar">
                <div class="dashboard-topbar-left"></div>
            </div>

            <div id="dashboardFilters" class="dashboard-filters closed">
                <!-- Orden: búsqueda, vista, densidad, estado, tipo, error, orden -->
                <input id="searchInput" class="toolbar-input" type="text" placeholder="Buscar por shared name, name, IP, modelo o serie">

                <div style="display:flex; gap:10px; align-items:center;">
                    <select id="viewMode" class="toolbar-select">
                        <option value="table">Vista tabla</option>
                        <option value="cards">Vista tarjetas</option>
                    </select>
                    <select id="densityMode" class="toolbar-select" onchange="setDensityMode(this.value)">
                        <option value="standard">Densidad: Estándar</option>
                        <option value="compact">Densidad: Compacta</option>
                        <option value="large">Densidad: Grande</option>
                    </select>
                    <button class="toolbar-button secondary" onclick="resetFilters()">Limpiar</button>
                </div>

                <select id="statusFilter" class="toolbar-select">
                    <option value="all">Estado: Todas</option>
                    <option value="online">Estado: Online</option>
                    <option value="offline">Estado: Offline</option>
                </select>

                <select id="typeFilter" class="toolbar-select">
                    <option value="all">Tipo: Todas</option>
                    <option value="color">Tipo: Color</option>
                    <option value="mono">Tipo: Blanco y negro</option>
                </select>

                <select id="errorFilter" class="toolbar-select">
                    <option value="all">Error: Todos</option>
                    <option value="ok">Error: Sin error</option>
                    <option value="low">Error: Tóner bajo</option>
                    <option value="critical">Error: Tóner crítico</option>
                    <option value="other">Error: Otros</option>
                </select>

                <select id="sortFilter" class="toolbar-select">
                    <option value="relevance_desc">Orden: Relevancia ↓</option>
                    <option value="relevance_asc">Orden: Relevancia ↑</option>
                    <option value="shared_name_asc">Orden: Shared Name A-Z</option>
                    <option value="shared_name_desc">Orden: Shared Name Z-A</option>
                    <option value="name_asc">Orden: Name A-Z</option>
                    <option value="name_desc">Orden: Name Z-A</option>
                    <option value="ip_asc">Orden: IP ↑</option>
                    <option value="ip_desc">Orden: IP ↓</option>
                    <option value="model_asc">Orden: Modelo A-Z</option>
                    <option value="model_desc">Orden: Modelo Z-A</option>
                </select>
            </div>

            

            <div id="dashboardCardsView" class="dashboard-view-wrap"><div class="grid" id="printersGrid"></div></div>

            <div id="dashboardTableView" class="dashboard-view-wrap" style="display:none;">
                <div class="table-wrapper dashboard-table-wrap">
                    <table class="dashboard-table">
                        <thead>
                            <tr>
                                <th>Shared Name</th>
                                <th>Name</th>
                                <th>Modelo</th>
                                <th>Serie</th>
                                <th>IP</th>
                                <th>Status</th>
                                <th>Error</th>
                                <th>Tóner</th>
                            </tr>
                        </thead>
                        <tbody id="dashboardTableBody"><tr><td colspan="8">Cargando...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="printers" class="tab">
            <h2 class="section-title">Gestión de impresoras</h2>

            <div class="card" style="margin-bottom:20px;">
                <h3 id="printerFormTitle" style="margin-top:0;">Agregar impresora manualmente</h3>
                <input type="hidden" id="editingPrinterId">
                <div class="form-grid">
                    <div><label>Shared Name</label><input id="printerSharedName" placeholder="Ej: IMP-FINANZAS"></div>
                    <div><label>Nombre</label><input id="printerName" placeholder="Nombre descriptivo"></div>
                    <div><label>Modelo</label><input id="printerModel" placeholder="Ej: IM C3000"></div>
                    <div><label>IP</label><input id="printerIp" placeholder="192.168.1.x"></div>
                    <div><label>Serie</label><input id="printerSerial" placeholder="Número de serie"></div>
                    <div><label>Ubicación</label><input id="printerLocation" placeholder="Ej: Piso 2"></div>
                    <div>
                        <label>Tipo</label>
                        <select id="printerIsColor">
                            <option value="true">Color</option>
                            <option value="false">Blanco y negro</option>
                        </select>
                    </div>
                    <div><label>SNMP Community</label><input id="printerCommunity" value="public"></div>
                </div>
                <div class="action-row" style="margin-top:14px;">
                    <button class="action-button" onclick="savePrinter()">Guardar impresora</button>
                    <button class="action-button action-button-secondary" onclick="resetPrinterForm()">Limpiar</button>
                </div>
            </div>

            <div class="card" style="margin-bottom:20px;">
                <h3 style="margin-top:0;">Buscar impresoras en red</h3>
                <div class="action-row">
                    <button class="action-button" onclick="discoverPrinters()">Buscar impresoras</button>
                    <button class="action-button" onclick="importPrinters()">Importar encontradas</button>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Shared Name</th>
                                <th>IP</th>
                                <th>Modelo</th>
                                <th>Serie</th>
                                <th>Tipo</th>
                            </tr>
                        </thead>
                        <tbody id="printersList"><tr><td colspan="5">Presione buscar para descubrir impresoras</td></tr></tbody>
                    </table>
                </div>
            </div>

            <div class="card">
                <h3 style="margin-top:0;">Impresoras registradas</h3>
                <div class="action-row">
                    <input id="printerSearch" placeholder="Buscar impresora..." oninput="filterSavedPrinters()" style="max-width:340px;">
                    <select id="printerSort" onchange="loadSavedPrinters()" style="max-width:240px;">
                        <option value="id">Ordenar por ID</option>
                        <option value="shared_name">Shared Name</option>
                        <option value="name">Nombre</option>
                        <option value="ip">IP</option>
                        <option value="model">Modelo</option>
                        <option value="serial">Serial</option>
                    </select>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Shared Name</th>
                                <th>Nombre</th>
                                <th>IP</th>
                                <th>Modelo</th>
                                <th>Serie</th>
                                <th>Tipo</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="savedPrintersList"><tr><td colspan="8">Cargando impresoras...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="counters" class="tab">
            <h2 class="section-title">Contadores de impresión</h2>
            <div class="action-row" style="align-items:center; margin-bottom:8px;">
                <button class="action-button" onclick="loadCounters()">Refrescar contadores</button>
                <label style="display:inline-flex;align-items:center;gap:8px;margin-left:8px;color:#cbd5e1;font-size:13px">
                    <input type="checkbox" id="countersAuto" onchange="toggleCountersAuto(this.checked)"> Auto
                    <input id="countersAutoInterval" type="number" value="60" style="width:72px;margin-left:6px;padding:6px;border-radius:6px;background:#0f172a;border:1px solid #374151;color:#fff">s
                </label>
                <div style="margin-left:auto;">
                    <span class="badge" id="countersLastUpdate" style="padding:6px 10px;font-size:12px">Última: -</span>
                </div>
            </div>
            <div class="table-wrapper">
                <table class="counters-table">
                    <thead>
                        <tr>
                            <th class="sticky-left-1 col-name text-left">Impresora</th>
                            <th class="sticky-left-2 col-serial text-left">Serie</th>
                            <th class="sticky-left-3 col-ip text-left">IP</th>
                            <th class="col-total num-right col-number">Total páginas</th>
                            <th class="col-copy num-right col-number">Copiado B/N</th>
                            <th class="col-copy num-right col-number">Copiado Color</th>
                            <th class="col-print num-right col-number">Impresión B/N</th>
                            <th class="col-print num-right col-number">Impresión Color</th>
                            <th class="col-total num-right col-number">Blanco y negro</th>
                            <th class="col-total num-right col-number">Color</th>
                        </tr>
                    </thead>
                    <tbody id="countersList"><tr><td colspan="10">Cargando contadores...</td></tr></tbody>
                </table>
            </div>
        </div>

        <div id="inventory" class="tab">
            <h2 class="section-title">Inventario de tóner</h2>
            <div class="card">
                <div class="form-grid">
                    <input id="invName" placeholder="Nombre (Ej: Toner Black)">
                    <input id="invModel" placeholder="Modelo impresora">
                    <select id="invType">
                        <option value="toner">Toner</option>
                        <option value="drum">Drum</option>
                        <option value="fuser">Fuser</option>
                    </select>
                    <input id="invQty" type="number" placeholder="Cantidad">
                    <input id="invMin" type="number" placeholder="Stock mínimo">
                </div>
                <div style="margin-top:14px;">
                    <button class="action-button" onclick="addInventoryItem()">Agregar</button>
                </div>
            </div>
            <br>
            <div class="table-wrapper">
                <table>
                    <thead><tr><th>ID</th><th>Nombre</th><th>Modelo</th><th>Tipo</th><th>Cantidad</th><th>Mínimo</th><th></th></tr></thead>
                    <tbody id="inventoryList"></tbody>
                </table>
            </div>
        </div>

        <div id="tonerControl" class="tab">
            <h2 class="section-title">Control de Tóner</h2>
            <div class="action-row">
                <button class="action-button" onclick="loadTonerControl()">Refrescar</button>
            </div>
            <div class="table-wrapper toner-control-wrapper">
                <table class="toner-control-table">
                    <thead>
                        <tr>
                            <th class="tc-col-shared">Shared Name</th>
                            <th class="tc-col-name">Name</th>
                            <th class="tc-col-model">Modelo</th>
                            <th class="tc-col-serial">Serie</th>
                            <th class="tc-col-check">Check</th>
                            <th class="tc-col-k">K</th>
                            <th class="tc-col-c">C</th>
                            <th class="tc-col-m">M</th>
                            <th class="tc-col-y">Y</th>
                            <th class="tc-col-bk">Backup K</th>
                            <th class="tc-col-bc">Backup C</th>
                            <th class="tc-col-bm">Backup M</th>
                            <th class="tc-col-by">Backup Y</th>
                            <th class="tc-col-location">Ubicación</th>
                            <th class="tc-col-pedido">Pedido</th>
                            <th class="tc-col-wo">WO</th>
                            <th class="tc-col-notas">Notas</th>
                            <th class="tc-col-action">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="tonerControlList">
                        <tr><td colspan="18">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>


        <script>
            let dashboardRawData = [];
            let dashboardFilteredData = [];
            let dashboardSortColumn = "shared_name";
            let dashboardSortDirection = "asc";
            // realtime / pagination / density state
            let realtimeConnected = false;
            let printersEventSource = null;
            let currentPage = 1;
            let pageSize = 50;
            const VIRTUALIZE_THRESHOLD = 300;
            // When true, render a simplified table row (no small bars) to speed up large renders
            let simpleTableMode = false;

            // Fetch control + polling for printers
            let printersFetchController = null;
            let printersPollInterval = null;
            const PRINTERS_POLL_MS = 30000;
            let searchDebounceTimer = null;
            // Virtualization state used when rendering very large tables
            let __virtualState = null;

            function teardownVirtualTable() {
                if (!__virtualState) return;
                try {
                    const tw = __virtualState.tableWrap;
                    if (tw && __virtualState.scrollHandler) tw.removeEventListener('scroll', __virtualState.scrollHandler);
                } catch (e) {}
                __virtualState = null;
            }

            function setupVirtualTable(tableWrap, tableBody, data, colsCount) {
                teardownVirtualTable();
                if (!tableWrap || !tableBody) return;
                const total = data.length;
                // measure row height using a hidden temporary row
                let rowHeight = 44;
                if (total > 0) {
                    try {
                        const tmp = document.createElement('template');
                        tmp.innerHTML = buildDashboardTableRow(data[0]);
                        const tmpTr = tmp.content.querySelector('tr');
                        if (tmpTr) {
                            tmpTr.style.visibility = 'hidden';
                            tableBody.appendChild(tmpTr);
                            rowHeight = tmpTr.getBoundingClientRect().height || rowHeight;
                            tableBody.removeChild(tmpTr);
                        }
                    } catch (e) {}
                }
                const buffer = 10;
                const render = () => {
                    const scrollTop = tableWrap.scrollTop;
                    const viewportH = tableWrap.clientHeight || window.innerHeight;
                    const visible = Math.max(1, Math.ceil(viewportH / rowHeight));
                    const start = Math.max(0, Math.floor(scrollTop / rowHeight) - buffer);
                    const end = Math.min(total, start + visible + buffer * 2);
                    const slice = data.slice(start, end);
                    const rowsHtml = slice.map(buildDashboardTableRow).join('');
                    const topH = start * rowHeight;
                    const bottomH = Math.max(0, (total - end) * rowHeight);
                    tableBody.innerHTML = `<tr data-spacer-top style="height:${topH}px"><td colspan="${colsCount}"></td></tr>` + rowsHtml + `<tr data-spacer-bottom style="height:${bottomH}px"><td colspan="${colsCount}"></td></tr>`;
                };
                const handler = () => { requestAnimationFrame(render); };
                tableWrap.addEventListener('scroll', handler);
