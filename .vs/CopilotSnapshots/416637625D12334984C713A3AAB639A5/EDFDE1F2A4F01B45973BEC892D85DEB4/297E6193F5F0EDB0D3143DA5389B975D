                    if (sortValue === 'shared_name_desc') return sharedB.localeCompare(sharedA);
                    if (sortValue === 'name_asc') return nameA.localeCompare(nameB);
                    if (sortValue === 'name_desc') return nameB.localeCompare(nameA);
                    if (sortValue === 'model_asc') return modelA.localeCompare(modelB);
                    if (sortValue === 'model_desc') return modelB.localeCompare(modelA);
