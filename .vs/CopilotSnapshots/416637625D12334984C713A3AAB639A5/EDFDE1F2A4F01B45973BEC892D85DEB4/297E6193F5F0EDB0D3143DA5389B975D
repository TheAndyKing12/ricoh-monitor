            async function discoverPrinters() {
                try {
                    const response = await fetch("/printers/discover");
                    const data = await response.json();
                    const list = document.getElementById("printersList");
                    list.innerHTML = "";
                    if (!Array.isArray(data) || data.length === 0) { list.innerHTML = `<tr><td colspan="5">No se encontraron impresoras.</td></tr>`; return; }
                    data.forEach(printer => {
                        list.innerHTML += `<tr><td>${printer.shared_name ?? "-"}</td><td>${printer.ip ?? "-"}</td><td>${printer.model ?? "-"}</td><td>${printer.serial ?? "-"}</td><td>${printer.is_color ? "Color" : "Blanco y negro"}</td></tr>`;
                    });
                } catch (error) {
                    console.error("discoverPrinters error:", error);
                    document.getElementById("printersList").innerHTML = `<tr><td colspan="5">No se pudo descubrir impresoras.</td></tr>`;
                }
            }

            async function importPrinters() {
                try {
                    const response = await fetch("/printers/import-discovered", { method: "POST" });
                    const data = await response.json();
                    alert(`Importadas: ${data.imported_count} | Omitidas: ${data.skipped_count}`);
                    loadPrinters(); loadSavedPrinters();
                } catch (error) { alert("No se pudieron importar las impresoras."); console.error(error); }
            }

            function filterSavedPrinters() {
                const search = (document.getElementById("printerSearch")?.value || "").toLowerCase().trim();
                document.querySelectorAll("#savedPrintersList tr").forEach(row => {
                    row.style.display = row.textContent.toLowerCase().includes(search) ? "" : "none";
                });
            }

            function resetPrinterForm() {
                document.getElementById("editingPrinterId").value = "";
                document.getElementById("printerFormTitle").textContent = "Agregar impresora manualmente";
                document.getElementById("printerSharedName").value = "";
                document.getElementById("printerName").value = "";
                document.getElementById("printerModel").value = "";
                document.getElementById("printerIp").value = "";
                document.getElementById("printerSerial").value = "";
                document.getElementById("printerLocation").value = "";
                document.getElementById("printerIsColor").value = "true";
                document.getElementById("printerCommunity").value = "public";
            }

            function editPrinter(printer) {
                document.getElementById("editingPrinterId").value = printer.id;
                document.getElementById("printerFormTitle").textContent = `Editar impresora ID ${printer.id}`;
                document.getElementById("printerSharedName").value = printer.shared_name ?? "";
                document.getElementById("printerName").value = printer.name ?? "";
                document.getElementById("printerModel").value = printer.model ?? "";
                document.getElementById("printerIp").value = printer.ip ?? "";
                document.getElementById("printerSerial").value = printer.serial ?? "";
                document.getElementById("printerLocation").value = printer.location ?? "";
                document.getElementById("printerIsColor").value = printer.is_color ? "true" : "false";
                document.getElementById("printerCommunity").value = printer.snmp_community ?? "public";
                showTab("printers"); window.scrollTo({ top: 0, behavior: "smooth" });
            }

            async function savePrinter() {
                const editingId = document.getElementById("editingPrinterId").value.trim();
                const payload = {
                    shared_name: document.getElementById("printerSharedName").value.trim() || null,
                    name: document.getElementById("printerName").value.trim() || null,
                    model: document.getElementById("printerModel").value.trim(),
                    ip: document.getElementById("printerIp").value.trim(),
                    serial: document.getElementById("printerSerial").value.trim() || null,
                    location: document.getElementById("printerLocation").value.trim() || null,
                    is_color: document.getElementById("printerIsColor").value === "true",
                    snmp_community: document.getElementById("printerCommunity").value.trim() || "public"
                };
                if (!payload.ip || !payload.model) { alert("IP y modelo son obligatorios."); return; }
                try {
                    let response;
                    if (editingId) {
                        response = await fetch(`/printers/${editingId}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
                    } else {
                        response = await fetch("/printers/", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
                    }
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.detail || "Error guardando impresora");
                    alert(editingId ? "Impresora actualizada correctamente." : "Impresora agregada correctamente.");
                    resetPrinterForm(); loadSavedPrinters(); loadPrinters();
                } catch (error) { alert(error.message || "No se pudo guardar la impresora."); console.error(error); }
            }

            async function addPrinterManual() { await savePrinter(); }

            async function loadSavedPrinters() {
                try {
                    const response = await fetch("/printers/");
                    let data = await response.json();
                    const sortBy = document.getElementById("printerSort")?.value || "id";
                    data.sort((a, b) => sortBy === "id" ? Number(a.id) - Number(b.id) : ((a[sortBy] ?? "").toString().toLowerCase()).localeCompare((b[sortBy] ?? "").toString().toLowerCase()));
                    const list = document.getElementById("savedPrintersList");
                    list.innerHTML = "";
                    if (!Array.isArray(data) || data.length === 0) { list.innerHTML = `<tr><td colspan="8">No hay impresoras guardadas.</td></tr>`; return; }
                    data.forEach(printer => {
                        const printerJson = JSON.stringify(printer).replace(/'/g, "&apos;");
                        list.innerHTML += `<tr><td>${printer.id}</td><td>${printer.shared_name ?? "-"}</td><td>${printer.name ?? "-"}</td><td>${printer.ip ?? "-"}</td><td>${printer.model ?? "-"}</td><td>${printer.serial ?? "-"}</td><td>${printer.is_color ? "Color" : "Blanco y negro"}</td><td><div class="action-row" style="margin-bottom:0;"><button class="action-button" onclick='editPrinter(${printerJson})'>Editar</button><button class="action-button action-button-danger" onclick="deletePrinter(${printer.id})">Eliminar</button></div></td></tr>`;
                    });
                    filterSavedPrinters();
                } catch (error) {
                    console.error("loadSavedPrinters error:", error);
                    document.getElementById("savedPrintersList").innerHTML = `<tr><td colspan="8">No se pudieron cargar las impresoras guardadas.</td></tr>`;
                }
            }

            async function deletePrinter(printerId) {
                if (!confirm(`¿Eliminar la impresora con ID ${printerId}?`)) return;
                try {
                    const response = await fetch(`/printers/${printerId}`, { method: "DELETE" });
                    if (!response.ok) throw new Error("No se pudo eliminar");
                    loadSavedPrinters(); loadPrinters();
                } catch (error) { alert("No se pudo eliminar la impresora."); console.error(error); }
            }

            let countersAutoTimer = null;
            let countersAutoInterval = 60;

            function toggleCountersAuto(checked) {
                if (checked) startCountersAuto(); else stopCountersAuto();
            }

            function startCountersAuto() {
                const iv = Number(document.getElementById('countersAutoInterval')?.value) || 60;
                countersAutoInterval = Math.max(5, iv);
                if (countersAutoTimer) clearInterval(countersAutoTimer);
                countersAutoTimer = setInterval(loadCounters, countersAutoInterval * 1000);
                loadCounters();
            }

            function stopCountersAuto() {
                if (countersAutoTimer) { clearInterval(countersAutoTimer); countersAutoTimer = null; }
            }

            async function loadCounters() {
                const list = document.getElementById("countersList");
                const lastEl = document.getElementById('countersLastUpdate');
                if (!list) return;
                try {
                    list.innerHTML = `<tr><td colspan="10">Actualizando contadores...</td></tr>`;
                    if (lastEl) lastEl.textContent = 'Actualizando...';
                    fetch("/printers/counters")
                        .then(response => response.json())
                        .then(data => {
                            if (!Array.isArray(data) || data.length === 0) {
                                list.innerHTML = `<tr><td colspan="10">No hay datos.</td></tr>`;
                                if (lastEl) lastEl.textContent = 'Última: -';
                                return;
                            }
                            const fmt = value => {
                                if (value === null || value === undefined || value === '' || value === '-') return '-';
                                const n = Number(value);
                                return Number.isNaN(n) ? value : n.toLocaleString('es-CR');
                            };
                            const frag = document.createDocumentFragment();
                            data.forEach(p => {
                                const tr = document.createElement('tr');
                                tr.innerHTML = `
                                    <td class="sticky-left-1 col-name text-left">${p.name ?? "-"}</td>
                                    <td class="sticky-left-2 col-serial text-left">${p.serial ?? "-"}</td>
                                    <td class="sticky-left-3 col-ip text-left ip-cell">${p.ip ?? "-"}</td>
                                    <td class="col-total num-right">${fmt(p.total_pages)}</td>
                                    <td class="col-copy num-right">${fmt(p.copy_bw)}</td>
                                    <td class="col-copy num-right">${fmt(p.copy_color)}</td>
                                    <td class="col-print num-right">${fmt(p.print_bw)}</td>
                                    <td class="col-print num-right">${fmt(p.print_color)}</td>
                                    <td class="col-total num-right">${fmt(p.bw_pages)}</td>
                                    <td class="col-total num-right">${fmt(p.color_pages)}</td>
                                `;
                                frag.appendChild(tr);
                            });
                            list.innerHTML = '';
                            list.appendChild(frag);
                            if (lastEl) lastEl.textContent = 'Actualizado: ' + new Date().toLocaleTimeString();
                        })
                        .catch(error => {
                            list.innerHTML = `<tr><td colspan="10">No se pudieron cargar los contadores.</td></tr>`;
                            if (lastEl) lastEl.textContent = 'Error';
                            console.error("loadCounters error:", error);
                        });
                } catch (error) {
                    list.innerHTML = `<tr><td colspan="10">No se pudieron cargar los contadores.</td></tr>`;
                    if (lastEl) lastEl.textContent = 'Error';
                    console.error("loadCounters error:", error);
                }
            }

            async function loadInventory() {
                try {
                    const response = await fetch("/inventory/");
                    const data = await response.json();
                    const list = document.getElementById("inventoryList");
                    list.innerHTML = "";
                    if (!Array.isArray(data) || data.length === 0) { list.innerHTML = `<tr><td colspan="7">No hay inventario registrado.</td></tr>`; return; }
                    data.forEach(item => { list.innerHTML += `<tr><td>${item.id}</td><td>${item.name}</td><td>${item.model}</td><td>${item.type}</td><td>${item.quantity}</td><td>${item.min_stock}</td><td><button class="action-button action-button-danger" onclick="deleteInventory(${item.id})">Eliminar</button></td></tr>`; });
                } catch (error) { console.error(error); }
            }

            async function addInventoryItem() {
                const payload = { name: document.getElementById("invName").value.trim(), model: document.getElementById("invModel").value.trim(), type: document.getElementById("invType").value, quantity: Number(document.getElementById("invQty").value), min_stock: Number(document.getElementById("invMin").value) };
                if (!payload.name || !payload.model || Number.isNaN(payload.quantity) || Number.isNaN(payload.min_stock)) { alert("Completa todos los campos del inventario."); return; }
                try {
                    await fetch("/inventory/", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
                    document.getElementById("invName").value = ""; document.getElementById("invModel").value = ""; document.getElementById("invType").value = "toner"; document.getElementById("invQty").value = ""; document.getElementById("invMin").value = "";
                    loadInventory();
                } catch (error) { alert("No se pudo agregar el inventario."); console.error(error); }
            }

            async function deleteInventory(id) {
                try { await fetch(`/inventory/${id}`, { method: "DELETE" }); loadInventory(); }
                catch (error) { alert("No se pudo eliminar el inventario."); console.error(error); }
            }

            async function loadTonerControl() {
                try {
                    const response = await fetch("/toner-control/");
                    const data = await response.json();
                    const list = document.getElementById("tonerControlList");
                    if (!list) return;
                    list.innerHTML = "";
                    if (!Array.isArray(data) || data.length === 0) {
                        list.innerHTML = `<tr><td colspan="18">No hay impresoras</td></tr>`;
                        return;
                    }
                    data.forEach(p => {
                        list.innerHTML += `
                        <tr>
                        <td class="tc-col-shared tc-shared-cell" title="${p.shared_name ?? "-"}">${p.shared_name ?? "-"}</td>
                        <td class="tc-col-name tc-name-cell" title="${p.name ?? "-"}">${p.name ?? "-"}</td>
                        <td class="tc-col-model tc-model-cell" title="${p.model ?? "-"}">${p.model ?? "-"}</td>
                        <td class="tc-col-serial tc-serial-cell">${p.serial ?? "-"}</td>
                        <td class="tc-col-check"><input class="tc-input-check" value="${p.check_date ?? ""}" id="check_${p.printer_id}"></td>
                        <td class="tc-col-k td-k tc-toner-cell"><span class="${tonerClass(p.toner_black, 'toner-k')}">${tonerDisplay(p.toner_black)}</span></td>
                        <td class="tc-col-c td-c tc-toner-cell">${p.is_color ? `<span class="${tonerClass(p.toner_cyan, 'toner-c')}">${tonerDisplay(p.toner_cyan)}</span>` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-m td-m tc-toner-cell">${p.is_color ? `<span class="${tonerClass(p.toner_magenta, 'toner-m')}">${tonerDisplay(p.toner_magenta)}</span>` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-y td-y tc-toner-cell">${p.is_color ? `<span class="${tonerClass(p.toner_yellow, 'toner-y')}">${tonerDisplay(p.toner_yellow)}</span>` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-bk"><input class="tc-input-backup" type="number" value="${p.backup_black ?? 0}" id="bk_${p.printer_id}"></td>
                        <td class="tc-col-bc">${p.is_color ? `<input class="tc-input-backup" type="number" value="${p.backup_cyan ?? 0}" id="bc_${p.printer_id}">` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-bm">${p.is_color ? `<input class="tc-input-backup" type="number" value="${p.backup_magenta ?? 0}" id="bm_${p.printer_id}">` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-by">${p.is_color ? `<input class="tc-input-backup" type="number" value="${p.backup_yellow ?? 0}" id="by_${p.printer_id}">` : `<span class="tc-muted">-</span>`}</td>
                        <td class="tc-col-location" title="${p.location ?? "-"}">${p.location ?? "-"}</td>
                        <td class="tc-col-pedido"><input class="tc-input-text" value="${p.pedido ?? ""}" id="pedido_${p.printer_id}"></td>
                        <td class="tc-col-wo"><input class="tc-input-text" value="${p.work_order ?? ""}" id="wo_${p.printer_id}"></td>
                        <td class="tc-col-notas"><input class="tc-input-text" value="${p.notas ?? ""}" id="notas_${p.printer_id}"></td>
                        <td class="tc-col-action"><button class="action-button" onclick="saveBackup(${p.printer_id}, ${p.is_color})">Guardar</button></td>
                        </tr>`;
                    });
                } catch (error) {
                    const list = document.getElementById("tonerControlList");
                    if (list) {
                        list.innerHTML = `<tr><td colspan="18">Error cargando datos</td></tr>`;
                    }
                    console.error("loadTonerControl error:", error);
                }
            }

            async function saveBackup(id, isColor) {
                const data = { check_date: document.getElementById("check_" + id).value, backup_black: Number(document.getElementById("bk_" + id).value) || 0, pedido: document.getElementById("pedido_" + id).value, work_order: document.getElementById("wo_" + id).value, notas: document.getElementById("notas_" + id).value };
                if (isColor) {
                    data.backup_cyan = Number(document.getElementById("bc_" + id).value) || 0;
                    data.backup_magenta = Number(document.getElementById("bm_" + id).value) || 0;
                    data.backup_yellow = Number(document.getElementById("by_" + id).value) || 0;
                }
                try {
                    await fetch(`/toner-control/${id}`, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
                    alert("Guardado"); loadTonerControl();
                } catch (error) { alert("Error guardando backup"); console.error(error); }
            }

            (function attachFilterListeners(){
                const searchEl = document.getElementById('searchInput');
                if (searchEl) searchEl.addEventListener('input', () => debounceApplyFilters(300));
                ['viewMode','densityMode','statusFilter','typeFilter','errorFilter','sortFilter'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.addEventListener('change', () => applyFilters());
                });
            })();

            showTab('dashboard');
            setDensityMode('standard');
            initRealtime();
            setTimeout(() => { if (!realtimeConnected) startPrintersPolling(); }, 300);
        </script>
</body>
</html>
