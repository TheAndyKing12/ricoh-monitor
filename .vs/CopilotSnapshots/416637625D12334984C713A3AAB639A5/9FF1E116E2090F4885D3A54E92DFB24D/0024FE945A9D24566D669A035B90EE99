function renderTonerBar(label,value,cssClass){const numeric=safeValue(value);const display=numeric===null?'-':`${numeric}%`;const width=numeric===null?0:Math.max(0,Math.min(100,numeric));return `<div class="toner-item"><div class="toner-label-row"><span>${label}</span><span>${display}</span></div><div class="bar"><div class="bar-fill ${cssClass}" style="width:${width}%"></div></div>${label==='Black'?tonerAlertText(numeric):''}</div>`;}
function renderTonerMini(label,value,cssClass){const numeric=safeValue(value);if(numeric===null)return `<span class="tc-muted">-</span>`;const width=Math.max(0,Math.min(100,numeric));return `<div class="toner-mini" title="${label}: ${numeric}%"><div class="mini-bar"><div class="fill ${cssClass}" style="width:${width}%"></div></div><span class="mini-label">${numeric}%</span></div>`;}
function normalizeErrorType(errorText){const text=(errorText||'Sin error').toLowerCase();if(!text||text==='sin error')return 'ok';if(text.includes('crítico')||text.includes('critical'))return 'critical';if(text.includes('low toner')||text.includes('tóner bajo'))return 'low';return 'other';}
function getErrorClass(errorText,status){if((status||'').toLowerCase()!=='online')return 'error-critical';const type=normalizeErrorType(errorText);if(type==='critical')return 'error-critical';if(type==='low')return 'error-warn';if(type==='other')return 'error-critical';return 'error-ok';}
function buildCard(printer){const status=(printer.status||'offline').toLowerCase();const statusClass=status==='online'?'status-online':'status-offline';const shared=printer.shared_name||'Sin shared name';const nameLine=printer.name?`<div class="printer-secondary">${printer.name}</div>`:'';let tonerHtml=renderTonerBar('Black',printer.toner_black,'bar-black');if(printer.is_color){tonerHtml+=renderTonerBar('Cyan',printer.toner_cyan,'bar-cyan');tonerHtml+=renderTonerBar('Magenta',printer.toner_magenta,'bar-magenta');tonerHtml+=renderTonerBar('Yellow',printer.toner_yellow,'bar-yellow');}return `<div class="card"><div class="card-header"><div><div class="printer-name">${shared}</div>${nameLine}<div class="printer-model">${printer.model??'-'}</div></div><div class="status-pill ${statusClass}">${status==='online'?'ONLINE':'OFFLINE'}</div></div><div class="info-row"><strong>Serie:</strong> ${printer.serial??'-'}</div><div class="info-row"><strong>IP:</strong> ${printer.ip??'-'}</div><div class="info-row"><strong>Ubicación:</strong> ${printer.location??'-'}</div><div class="info-row"><strong>Error:</strong> <span class="${getErrorClass(printer.error_message,printer.status)}">${printer.error_message??'Sin error'}</span></div><div class="info-row"><strong>Tipo:</strong> ${printer.is_color?'Color':'Blanco y negro'}</div><div class="toner-section"><div class="toner-title">Consumibles</div>${tonerHtml}</div></div>`;}
function buildDashboardTableRow(printer){const status=(printer.status||'offline').toLowerCase();const statusHtml=status==='online'?`<span class="status-badge status-badge-online">Online</span>`:`<span class="status-badge status-badge-offline">Offline</span>`;const errorClass=getErrorClass(printer.error_message,printer.status);const errorText=printer.error_message||'Sin error';const normalized=normalizeErrorType(printer.error_message);let rowClass='';if(status!=='online')rowClass='row-error';else if(normalized==='critical')rowClass='row-error';else if(normalized==='low')rowClass='row-low';const tonerPieces=[renderTonerMini('K',printer.toner_black,'bar-black')];if(printer.is_color){tonerPieces.push(renderTonerMini('C',printer.toner_cyan,'bar-cyan'));tonerPieces.push(renderTonerMini('M',printer.toner_magenta,'bar-magenta'));tonerPieces.push(renderTonerMini('Y',printer.toner_yellow,'bar-yellow'));}return `<tr class="${rowClass}"><td>${printer.shared_name??'-'}</td><td>${printer.name??'-'}</td><td>${printer.model??'-'}</td><td>${printer.serial??'-'}</td><td>${printer.ip??'-'}</td><td>${statusHtml}</td><td class="${errorClass}">${errorText}</td><td><div class="toner-inline">${tonerPieces.join('')}</div></td></tr>`;}
function compareDashboardValues(a,b,column){const av=((a[column]??'')+'').toLowerCase().trim();const bv=((b[column]??'')+'').toLowerCase().trim();if(column==='ip'){const aip=av.split('.').map(x=>parseInt(x||'0',10));const bip=bv.split('.').map(x=>parseInt(x||'0',10));for(let i=0;i<4;i++){if((aip[i]||0)<(bip[i]||0))return -1;if((aip[i]||0)>(bip[i]||0))return 1;}return 0;}return av.localeCompare(bv);}
function sortDashboardTableColumns(data){const sorted=[...data];sorted.sort((a,b)=>{let result=compareDashboardValues(a,b,dashboardSortColumn);if(dashboardSortDirection==='desc')result*=-1;return result;});return sorted;}
function toggleTableSort(column){if(dashboardSortColumn===column){dashboardSortDirection=dashboardSortDirection==='asc'?'desc':'asc';}else{dashboardSortColumn=column;dashboardSortDirection='asc';}loadPrinters();}
function getDashboardRelevance(printer){const status=(printer.status||'offline').toLowerCase();const errorText=(printer.error_message||'Sin error').toLowerCase();const black=safeValue(printer.toner_black);let score=0;if(status!=='online')score+=100;if(errorText.includes('crítico')||errorText.includes('critical'))score+=80;else if(errorText.includes('low toner')||errorText.includes('tóner bajo'))score+=40;else if(errorText!=='sin error')score+=20;if(black!==null)score+=Math.max(0,100-black);return score;}
function normalizeErrorType(errorText){const text=(errorText||'Sin error').toLowerCase();if(!text||text==='sin error')return 'ok';if(text.includes('crítico')||text.includes('critical'))return 'critical';if(text.includes('low toner')||text.includes('tóner bajo'))return 'low';return 'other';}
function getErrorClass(errorText,status){if((status||'').toLowerCase()!=='online')return 'error-critical';const type=normalizeErrorType(errorText);if(type==='critical')return 'error-critical';if(type==='low')return 'error-warn';if(type==='other')return 'error-critical';return 'error-ok';}
function buildCard(printer){const status=(printer.status||'offline').toLowerCase();const statusClass=status==='online'?'status-online':'status-offline';const shared=printer.shared_name||'Sin shared name';const nameLine=printer.name?`<div class="printer-secondary">${printer.name}</div>`:'';let tonerHtml=renderTonerBar('Black',printer.toner_black,'bar-black');if(printer.is_color){tonerHtml+=renderTonerBar('Cyan',printer.toner_cyan,'bar-cyan');tonerHtml+=renderTonerBar('Magenta',printer.toner_magenta,'bar-magenta');tonerHtml+=renderTonerBar('Yellow',printer.toner_yellow,'bar-yellow');}return `<div class="card"><div class="card-header"><div><div class="printer-name">${shared}</div>${nameLine}<div class="printer-model">${printer.model??'-'}</div></div><div class="status-pill ${statusClass}">${status==='online'?'ONLINE':'OFFLINE'}</div></div><div class="info-row"><strong>Serie:</strong> ${printer.serial??'-'}</div><div class="info-row"><strong>IP:</strong> ${printer.ip??'-'}</div><div class="info-row"><strong>Ubicación:</strong> ${printer.location??'-'}</div><div class="info-row"><strong>Error:</strong> <span class="${getErrorClass(printer.error_message,printer.status)}">${printer.error_message??'Sin error'}</span></div><div class="info-row"><strong>Tipo:</strong> ${printer.is_color?'Color':'Blanco y negro'}</div><div class="toner-section"><div class="toner-title">Consumibles</div>${tonerHtml}</div></div>`;}
function buildDashboardTableRow(printer){const status=(printer.status||'offline').toLowerCase();const statusHtml=status==='online'?`<span class="status-badge status-badge-online">Online</span>`:`<span class="status-badge status-badge-offline">Offline</span>`;const errorClass=getErrorClass(printer.error_message,printer.status);const errorText=printer.error_message||'Sin error';const normalized=normalizeErrorType(printer.error_message);let rowClass='';if(status!=='online')rowClass='row-error';else if(normalized==='critical')rowClass='row-error';else if(normalized==='low')rowClass='row-low';const tonerPieces=[renderTonerMini('K',printer.toner_black,'bar-black')];if(printer.is_color){tonerPieces.push(renderTonerMini('C',printer.toner_cyan,'bar-cyan'));tonerPieces.push(renderTonerMini('M',printer.toner_magenta,'bar-magenta'));tonerPieces.push(renderTonerMini('Y',printer.toner_yellow,'bar-yellow'));}return `<tr class="${rowClass}"><td>${printer.shared_name??'-'}</td><td>${printer.name??'-'}</td><td>${printer.model??'-'}</td><td>${printer.serial??'-'}</td><td>${printer.ip??'-'}</td><td>${statusHtml}</td><td class="${errorClass}">${errorText}</td><td><div class="toner-inline">${tonerPieces.join('')}</div></td></tr>`;}
function compareDashboardValues(a,b,column){const av=((a[column]??'')+'').toLowerCase().trim();const bv=((b[column]??'')+'').toLowerCase().trim();if(column==='ip'){const aip=av.split('.').map(x=>parseInt(x||'0',10));const bip=bv.split('.').map(x=>parseInt(x||'0',10));for(let i=0;i<4;i++){if((aip[i]||0)<(bip[i]||0))return -1;if((aip[i]||0)>(bip[i]||0))return 1;}return 0;}return av.localeCompare(bv);}
function sortDashboardTableColumns(data){const sorted=[...data];sorted.sort((a,b)=>{let result=compareDashboardValues(a,b,dashboardSortColumn);if(dashboardSortDirection==='desc')result*=-1;return result;});return sorted;}
function toggleTableSort(column){if(dashboardSortColumn===column){dashboardSortDirection=dashboardSortDirection==='asc'?'desc':'asc';}else{dashboardSortColumn=column;dashboardSortDirection='asc';}loadPrinters();}
function getDashboardRelevance(printer){const status=(printer.status||'offline').toLowerCase();const errorText=(printer.error_message||'Sin error').toLowerCase();const black=safeValue(printer.toner_black);let score=0;if(status!=='online')score+=100;if(errorText.includes('crítico')||errorText.includes('critical'))score+=80;else if(errorText.includes('low toner')||errorText.includes('tóner bajo'))score+=40;else if(errorText!=='sin error')score+=20;if(black!==null)score+=Math.max(0,100-black);return score;}
function ipToNumber(ip){return String(ip||'').split('.').reduce((acc,part)=>(acc*256)+(parseInt(part,10)||0),0);}
function sortDashboardData(data,sortValue){const sorted=[...data];sorted.sort((a,b)=>{const sharedA=(a.shared_name||'').toLowerCase();const sharedB=(b.shared_name||'').toLowerCase();const nameA=(a.name||'').toLowerCase();const nameB=(b.name||'').toLowerCase();const modelA=(a.model||'').toLowerCase();const modelB=(b.model||'').toLowerCase();if(sortValue==='relevance_desc')return getDashboardRelevance(b)-getDashboardRelevance(a);if(sortValue==='relevance_asc')return getDashboardRelevance(a)-getDashboardRelevance(b);if(sortValue==='shared_name_asc')return sharedA.localeCompare(sharedB);if(sortValue==='shared_name_desc')return sharedB.localeCompare(sharedA);if(sortValue==='name_asc')return nameA.localeCompare(nameB);if(sortValue==='name_desc')return nameB.localeCompare(nameA);if(sortValue==='model_asc')return modelA.localeCompare(modelB);if(sortValue==='model_desc')return modelB.localeCompare(modelA);if(sortValue==='ip_asc')return ipToNumber(a.ip)-ipToNumber(b.ip);if(sortValue==='ip_desc')return ipToNumber(b.ip)-ipToNumber(a.ip);return 0;});return sorted;}
async function loadPrinters(){try{if(printersFetchController){try{printersFetchController.abort();}catch(e){}}printersFetchController=new AbortController();const response=await fetch('/printers/status',{signal:printersFetchController.signal});let data=await response.json();if(!Array.isArray(data))data=[];const search=(document.getElementById('searchInput')?.value||'').toLowerCase().trim();const statusFilter=document.getElementById('statusFilter')?.value||'all';const typeFilter=document.getElementById('typeFilter')?.value||'all';const errorFilter=document.getElementById('errorFilter')?.value||'all';const sortFilter=document.getElementById('sortFilter')?.value||'relevance_desc';const viewMode=document.getElementById('viewMode')?.value||'table';if(search){data=data.filter(p=>((p.shared_name||'')+' '+(p.name||'')+' '+(p.ip||'')+' '+(p.model||'')+' '+(p.serial||'')).toLowerCase().includes(search));}data=data.filter(p=>{const status=(p.status||'').toLowerCase();const errorType=normalizeErrorType(p.error_message);const matchesStatus=statusFilter==='all'||(statusFilter==='online'&&status==='online')||(statusFilter==='offline'&&status!=='online');const matchesType=typeFilter==='all'||(typeFilter==='color'&&!!p.is_color)||(typeFilter==='mono'&&!p.is_color);const matchesError=errorFilter==='all'||
(p.error_message||'Sin error').toLowerCase().includes(errorFilter);return matchesStatus&&matchesType&&matchesError;});data=sortDashboardData(data,sortFilter);data=sortDashboardTableColumns(data);dashboardRawData=[...data];const cardsView=document.getElementById('dashboardCardsView');const tableView=document.getElementById('dashboardTableView');const grid=document.getElementById('printersGrid');const tableBody=document.getElementById('dashboardTableBody');grid.innerHTML='';tableBody.innerHTML='';if(!data.length){grid.innerHTML='<div class="empty-state">No hay impresoras para mostrar con esos filtros.</div>';tableBody.innerHTML='<tr><td colspan="8">No hay impresoras para mostrar.</td></tr>';document.getElementById('totalPrinters').textContent='0';document.getElementById('onlinePrinters').textContent='0';document.getElementById('offlinePrinters').textContent='0';document.getElementById('lowTonerPrinters').textContent='0';document.getElementById('lastUpdate').textContent='Sin datos';}else{let onlineCount=0,offlineCount=0,lowTonerCount=0;data.forEach(printer=>{const status=(printer.status||'offline').toLowerCase();if(status==='online')onlineCount++;else offlineCount++;const black=safeValue(printer.toner_black);if(black!==null&&black<30)lowTonerCount++;if(viewMode==='cards'){const t=document.createElement('template');t.innerHTML=buildCard(printer).trim();if(t.content.firstElementChild)grid.appendChild(t.content.firstElementChild);}else{tableBody.insertAdjacentHTML('beforeend',buildDashboardTableRow(printer));}});document.getElementById('totalPrinters').textContent=String(data.length);document.getElementById('onlinePrinters').textContent=String(onlineCount);document.getElementById('offlinePrinters').textContent=String(offlineCount);document.getElementById('lowTonerPrinters').textContent=String(lowTonerCount);document.getElementById('lastUpdate').textContent='Actualizado: '+new Date().toLocaleTimeString();}cardsView.style.display=viewMode==='cards'?'block':'none';tableView.style.display=viewMode==='table'?'block':'none';}catch(error){if(error.name!=='AbortError')console.error('loadPrinters error:',error);}finally{printersFetchController=null;}}
function startPrintersPolling(){stopPrintersPolling();loadPrinters();printersPollInterval=setInterval(()=>{const dash=document.getElementById('dashboard');if(dash&&dash.classList.contains('active'))loadPrinters();},PRINTERS_POLL_MS);}function stopPrintersPolling(){if(printersPollInterval){clearInterval(printersPollInterval);printersPollInterval=null;}if(printersFetchController){try{printersFetchController.abort();}catch(e){}printersFetchController=null;}}
function resetFilters(){document.getElementById('searchInput').value='';document.getElementById('statusFilter').value='all';document.getElementById('typeFilter').value='all';document.getElementById('errorFilter').value='all';document.getElementById('sortFilter').value='relevance_desc';document.getElementById('viewMode').value='table';loadPrinters();}
function getSelectedDiscoveredPrinters(){return discoveredPrintersCache.filter((_,index)=>document.getElementById(`discoverSelect_${index}`)?.checked);}
function toggleAllDiscovered(checked){discoveredPrintersCache.forEach((_,index)=>{const checkbox=document.getElementById(`discoverSelect_${index}`);if(checkbox)checkbox.checked=checked;});}
function clearDiscoveredPrinters(){discoveredPrintersCache=[];const list=document.getElementById('printersList');const selectAll=document.getElementById('selectAllDiscovered');if(list)list.innerHTML='<tr><td colspan="7">Configure la búsqueda y presione buscar.</td></tr>';if(selectAll)selectAll.checked=false;}
function openAddressBook(printer){currentAddressBookPrinter=printer||null;const title=document.getElementById('addressBookPrinterTitle');const meta=document.getElementById('addressBookPrinterMeta');const status=document.getElementById('addressBookStatus');const list=document.getElementById('addressBookList');const displayName=printer?.shared_name||printer?.name||printer?.model||'Impresora';if(title)title.textContent=`Libreta de direcciones - ${displayName}`;if(meta)meta.textContent=`IP: ${printer?.ip??'-'} | Modelo: ${printer?.model??'-'} | Serie: ${printer?.serial??'-'}`;if(status)status.textContent='Vista preparada. El siguiente paso es conectar la libreta real de la Ricoh sin tocar la configuración existente.';if(list)list.innerHTML='<tr><td colspan="12">Interfaz preparada. Aún no se ha conectado la lectura/escritura real de la libreta de direcciones.</td></tr>';showTab('addressBook');}
function showAddressBookPendingMessage(){const status=document.getElementById('addressBookStatus');if(status)status.textContent=currentAddressBookPrinter?`Pendiente conectar la libreta real de ${currentAddressBookPrinter.ip}. La estructura ya quedó lista para agregar, editar y eliminar usuarios.`:'Abra primero una impresora desde el botón amarillo de la tabla para preparar su libreta de direcciones.';}
(function attachFilterListeners(){const searchEl=document.getElementById('searchInput');if(searchEl)searchEl.addEventListener('input',()=>loadPrinters());['viewMode','densityMode','statusFilter','typeFilter','errorFilter','sortFilter'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('change',()=>loadPrinters());});const printerIpEl=document.getElementById('printerIp');if(printerIpEl){printerIpEl.addEventListener('input',()=>validatePrinterIpField());printerIpEl.addEventListener('blur',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});printerIpEl.addEventListener('change',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});}['discoverStartIp','discoverEndIp','discoverSingleIp'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',()=>validateDiscoverFields());});toggleDiscoverModeFields();})();
showTab('dashboard');setDensityMode('standard');
</script>
