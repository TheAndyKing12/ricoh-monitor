def safe_int(value):

    try:

        return int(value)

    except:

        return None


def decode_printer_error_state(raw_value):

    if raw_value is None:

        return []

    try:

        octets = list(raw_value.asNumbers())

    except:

        try:

            octets = list(bytes(raw_value))

        except:

            return []

    bit_names = [

        "Low Paper",             # 0

        "No Paper",              # 1

        "Low Toner",             # 2

        "No Toner",              # 3

        "Door Open",             # 4

        "Paper Jam",             # 5

        "Offline",               # 6

        "Service Requested",     # 7

        "Input Tray Missing",    # 8

        "Output Tray Missing",   # 9

        "Marker Supply Missing", # 10

        "Output Near Full",      # 11

        "Output Full",           # 12

        "Input Tray Empty",      # 13

        "Maintenance Required"   # 14

    ]

    errors = []

    for byte_index, byte_value in enumerate(octets):

        for bit_index in range(8):

            global_bit_index = byte_index * 8 + bit_index

            if global_bit_index >= len(bit_names):

                continue

            mask = 0x80 >> bit_index

            if byte_value & mask:

                errors.append(bit_names[global_bit_index])

    return errors


def detect_is_color(printer):

    if hasattr(printer, "is_color") and printer.is_color is not None:

        return bool(printer.is_color)

    model_upper = (printer.model or "").upper().strip()

    return (

        model_upper.startswith("IM C") or

        model_upper.startswith("MP C") or

        model_upper.startswith("P C") or

        "IM C" in model_upper or

        "MP C" in model_upper or

        "P C" in model_upper

    )
 

def detect_is_color_from_model(model_str: str):

    model_upper = (model_str or "").upper()

    return (

        "IM C" in model_upper or

        "MP C" in model_upper or

        "P C" in model_upper

    )


def build_fast_printer_status(printer):

    is_color = detect_is_color(printer)

    sys_name_oid = "1.3.6.1.2.1.1.5.0"
    oids = [
        "1.3.6.1.2.1.43.11.1.1.9.1.1",
        "1.3.6.1.2.1.25.3.5.1.1.1",
        "1.3.6.1.2.1.25.3.5.1.2.1",
        sys_name_oid,
    ]
    if is_color:
        oids += [
            "1.3.6.1.2.1.43.11.1.1.9.1.2",
            "1.3.6.1.2.1.43.11.1.1.9.1.3",
            "1.3.6.1.2.1.43.11.1.1.9.1.4"
        ]

    try:
        values = get_snmp_values(printer.ip, printer.snmp_community, oids)
    except Exception:
        values = None

    def _v(oid):
        if not values:
            return None
        return values.get(oid)

    live_name = _v(sys_name_oid)
    if live_name is not None:
        live_name = str(live_name).strip()
        if "." in live_name:
            live_name = live_name.split(".")[0]
    if not live_name:
        live_name = printer.name

    toner_black = safe_int(_v("1.3.6.1.2.1.43.11.1.1.9.1.1"))
    status_code = safe_int(_v("1.3.6.1.2.1.25.3.5.1.1.1"))
    error_state_raw = _v("1.3.6.1.2.1.25.3.5.1.2.1")
    error_list = decode_printer_error_state(error_state_raw)

    status = "online" if toner_black is not None else "offline"
    printer_state = "unknown"
    if status_code == 3:
        printer_state = "idle"
    elif status_code == 4:
        printer_state = "printing"
    elif status_code == 5:
        printer_state = "warmup"
    elif status_code == 6:
        printer_state = "stopped"

    if status == "offline":
        error_message = "Sin respuesta SNMP"
    elif error_list:
        error_message = ", ".join(error_list)
    elif toner_black is not None and toner_black < 10:
        error_message = "Tóner crítico"
    elif toner_black is not None and toner_black < 30:
        error_message = "Low Toner"
    else:
        error_message = "Sin error"

    printer_data = {
        "id": printer.id,
        "shared_name": getattr(printer, "shared_name", None),
        "name": live_name,
        "model": printer.model,
        "serial": printer.serial,
        "ip": printer.ip,
        "location": printer.location,
        "is_color": is_color,
        "status": status,
        "printer_state": printer_state,
        "error_message": error_message,
        "toner_black": toner_black
    }

    if is_color:
        toner_cyan = safe_int(_v("1.3.6.1.2.1.43.11.1.1.9.1.2"))
        toner_magenta = safe_int(_v("1.3.6.1.2.1.43.11.1.1.9.1.3"))
        toner_yellow = safe_int(_v("1.3.6.1.2.1.43.11.1.1.9.1.4"))
        printer_data["toner_cyan"] = toner_cyan
        printer_data["toner_magenta"] = toner_magenta
        printer_data["toner_yellow"] = toner_yellow

    return printer_data


def resolve_hostname_value(ip: str, community: str = "public") -> str | None:
    hostname = None

    try:
        hostname = get_ricoh_http_hostname(ip)
    except Exception:
        hostname = None

    if not hostname:
        try:
            hostname = socket.gethostbyaddr(ip)[0]
        except Exception:
            hostname = None

    if not hostname:
        try:
            snmp_name = get_snmp_value(ip, community, "1.3.6.1.2.1.1.5.0")
            if snmp_name is not None:
                hostname = str(snmp_name).strip()
        except Exception:
            hostname = None

    if hostname and "." in hostname:
        hostname = hostname.split(".")[0]

    return hostname


@router.post("/", response_model=schemas.PrinterResponse)
def create_printer(printer: schemas.PrinterCreate, db: Session = Depends(get_db)):
    existing = crud.get_printer_by_ip(db, printer.ip)
    if existing:
        raise HTTPException(status_code=400, detail="Ya existe una impresora con esa IP")

    printer_data = printer.dict()
    resolved_name = resolve_hostname_value(printer.ip, printer.snmp_community)
    if resolved_name:
        printer_data["name"] = resolved_name

    created = crud.create_printer(db, schemas.PrinterCreate(**printer_data))
    clear_all_cache()
    return created


@router.get("/", response_model=list[schemas.PrinterResponse])
def list_printers(db: Session = Depends(get_db)):
    printers = crud.get_printers(db)
    for printer in printers:
        resolved_name = resolve_hostname_value(printer.ip, printer.snmp_community)
        if resolved_name and resolved_name != (printer.name or "").strip():
            crud.update_printer(db, printer.id, {"name": resolved_name})
            printer.name = resolved_name
    return printers


@router.put("/{printer_id}", response_model=schemas.PrinterResponse)
def update_printer(printer_id: int, printer: schemas.PrinterUpdate, db: Session = Depends(get_db)):
    existing = crud.get_printer_by_id(db, printer_id)
    if not existing:
        raise HTTPException(status_code=404, detail="Printer not found")

    data = printer.dict(exclude_unset=True)
    if "ip" in data and data["ip"] != existing.ip:
        duplicate = crud.get_printer_by_ip(db, data["ip"])
        if duplicate:
            raise HTTPException(status_code=400, detail="Ya existe una impresora con esa IP")

    target_ip = data.get("ip", existing.ip)
    target_community = data.get("snmp_community", existing.snmp_community)
    resolved_name = resolve_hostname_value(target_ip, target_community)
    if resolved_name:
        data["name"] = resolved_name

    updated = crud.update_printer(db, printer_id, data)
    clear_all_cache()
    return updated


@router.delete("/{printer_id}")
def delete_printer(printer_id: int, db: Session = Depends(get_db)):
    printer = crud.get_printer_by_id(db, printer_id)
    if not printer:
        raise HTTPException(status_code=404, detail="Printer not found")

    crud.delete_printer(db, printer_id)
    clear_all_cache()
    return {"message": "Printer deleted"}


@router.get("/status")
def get_printers_status(db: Session = Depends(get_db)):
    now = time.time()

    if (

        STATUS_CACHE["data"] is not None and

        (now - STATUS_CACHE["timestamp"]) < STATUS_CACHE_TTL

    ):

        return STATUS_CACHE["data"]

    printers = crud.get_printers(db)

    # If there is no cached data yet, return a lightweight placeholder and refresh in background

    if STATUS_CACHE["data"] is None:

        placeholder = []

        for p in printers:

            placeholder.append({

                "id": p.id,

                "shared_name": getattr(p, "shared_name", None),

                "name": p.name,

                "model": p.model,

                "serial": p.serial,

                "ip": p.ip,

                "location": p.location,

                "is_color": detect_is_color(p),

                "status": "unknown",

                "printer_state": "unknown",

                "error_message": "Cargando...",

                "toner_black": None

            })

        STATUS_CACHE["timestamp"] = now

        STATUS_CACHE["data"] = placeholder

        def refresh_cache():

            try:

                with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:

                    results = list(executor.map(build_fast_printer_status, printers))

                STATUS_CACHE["timestamp"] = time.time()

                STATUS_CACHE["data"] = results

            finally:

                with REFRESH_LOCK:

                    global REFRESH_IN_PROGRESS

                    REFRESH_IN_PROGRESS = False

        with REFRESH_LOCK:

            global REFRESH_IN_PROGRESS

            if not REFRESH_IN_PROGRESS:

                REFRESH_IN_PROGRESS = True

                threading.Thread(target=refresh_cache, daemon=True).start()

        return placeholder

    # otherwise perform synchronous refresh

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:

        results = list(executor.map(build_fast_printer_status, printers))

    STATUS_CACHE["timestamp"] = now

    STATUS_CACHE["data"] = results

    return results


def build_printer_counters(printer):
    # basic counters (batch SNMP)
    oids = [
        "1.3.6.1.2.1.43.10.2.1.4.1.1",  # total
        "1.3.6.1.4.1.367.3.2.1.7.2.9.1.2.1",  # bw pages
        "1.3.6.1.4.1.367.3.2.1.7.2.9.1.2.3"   # color pages
    ]
    try:
        vals = get_snmp_values(printer.ip, printer.snmp_community, oids)
    except Exception:
        vals = None

    def _v(oid):
        if not vals:
            return None
        return vals.get(oid)

    total_pages = safe_int(_v(oids[0]))
    bw_pages = safe_int(_v(oids[1]))
    color_pages = safe_int(_v(oids[2]))

    # additional counters: copies and prints (may be available via HTTP on Ricoh devices)
    copy_bw = None
    copy_color = None
    print_bw = None
    print_color = None

    http_data = get_ricoh_http_counters(printer.ip)
    if http_data:
        if http_data.get("bw_pages") is not None:
            bw_pages = safe_int(http_data["bw_pages"])
        if http_data.get("color_pages") is not None:
            color_pages = safe_int(http_data["color_pages"])
        if http_data.get("total_pages") is not None:
            total_pages = safe_int(http_data["total_pages"])
        if http_data.get("copy_bw") is not None:
            copy_bw = safe_int(http_data["copy_bw"])
        if http_data.get("copy_color") is not None:
            copy_color = safe_int(http_data["copy_color"])
        if http_data.get("print_bw") is not None:
            print_bw = safe_int(http_data["print_bw"])
        if http_data.get("print_color") is not None:
            print_color = safe_int(http_data["print_color"])

    # if copy/print counters are available prefer summing them for BW and Color
    if copy_bw is not None or print_bw is not None:
        bw_pages = (copy_bw or 0) + (print_bw or 0)
    if copy_color is not None or print_color is not None:
        color_pages = (copy_color or 0) + (print_color or 0)

    # recompute total if possible
    if (bw_pages is not None) and (color_pages is not None):
        total_pages = bw_pages + color_pages

    return {
        "name": getattr(printer, "shared_name", None) or printer.name or printer.model,
        "serial": printer.serial,
        "ip": printer.ip,
        "total_pages": total_pages,
        "copy_bw": copy_bw,
        "copy_color": copy_color,
        "print_bw": print_bw,
        "print_color": print_color,
        "bw_pages": bw_pages,
        "color_pages": color_pages
    }


@router.get("/counters")
def get_printers_counters(db: Session = Depends(get_db)):
    now = time.time()

    if (COUNTERS_CACHE["data"] is not None and (now - COUNTERS_CACHE["timestamp"]) < COUNTERS_CACHE_TTL):

        return COUNTERS_CACHE["data"]

    printers = crud.get_printers(db)

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:

        results = list(executor.map(build_printer_counters, printers))

    COUNTERS_CACHE["timestamp"] = now

    COUNTERS_CACHE["data"] = results

    return results


class DiscoveredPrinterImport(BaseModel):
    shared_name: str | None = None
    name: str | None = None
    model: str
    ip: str
    serial: str | None = None
    is_color: bool | None = None
    snmp_community: str = "public"


def build_discovery_targets(mode: str, start_ip: str | None = None, end_ip: str | None = None, ip: str | None = None):
    mode = (mode or "range").lower()

    if mode == "ip":
        if not ip:
            raise HTTPException(status_code=400, detail="Debe indicar una IP para buscar")
        try:
            return [str(ip_address(ip))]
        except ValueError:
            raise HTTPException(status_code=400, detail="La IP indicada no es válida")

    if mode != "range":
        raise HTTPException(status_code=400, detail="Modo de búsqueda no válido")

    if not start_ip or not end_ip:
        raise HTTPException(status_code=400, detail="Debe indicar IP inicial e IP final")

    try:
        start = ip_address(start_ip)
        end = ip_address(end_ip)
    except ValueError:
        raise HTTPException(status_code=400, detail="El rango de IP no es válido")

    if int(start) > int(end):
        raise HTTPException(status_code=400, detail="La IP inicial no puede ser mayor que la IP final")

    total = int(end) - int(start) + 1
    if total > 1024:
        raise HTTPException(status_code=400, detail="El rango es demasiado grande. Use un máximo de 1024 IPs")

    return [str(ip_address(value)) for value in range(int(start), int(end) + 1)]


def discover_printers_on_targets(target_ips: list[str], community: str = "public"):
    discovered = []

    for ip_str in target_ips:
        device_name = get_snmp_value(ip_str, community, "1.3.6.1.2.1.1.5.0")
        if device_name is None:
            continue

        full_model = get_snmp_value(ip_str, community, "1.3.6.1.2.1.1.1.0")
        if full_model is None:
            continue

        full_model_str = str(full_model)
        full_model_upper = full_model_str.upper()
        if "RICOH" not in full_model_upper:
            continue

        serial = get_snmp_value(ip_str, community, "1.3.6.1.2.1.43.5.1.1.17.1")
        short_model = str(device_name).strip()
        is_color = detect_is_color_from_model(short_model)

        hostname = None
        try:
            hostname = get_ricoh_http_hostname(ip_str)
        except Exception:
            hostname = None

        if not hostname and device_name is not None:
            hostname = str(device_name).strip()

        if hostname and "." in hostname:
            hostname = hostname.split(".")[0]

        discovered.append({
            "shared_name": None,
            "name": hostname,
            "ip": ip_str,
            "model": short_model,
            "serial": str(serial) if serial else None,
            "is_color": is_color,
            "snmp_community": community,
        })

    return discovered


@router.get("/discover")
def discover_printers(mode: str = "range", start_ip: str | None = None, end_ip: str | None = None, ip: str | None = None, community: str = "public"):
    target_ips = build_discovery_targets(mode=mode, start_ip=start_ip, end_ip=end_ip, ip=ip)
    return discover_printers_on_targets(target_ips, community)


@router.post("/import-discovered")
def import_discovered_printers(discovered_printers: list[DiscoveredPrinterImport] = Body(default=[]), db: Session = Depends(get_db)):
    imported = []
    skipped = []

    if not discovered_printers:
        return {
            "imported_count": 0,
            "skipped_count": 0,
            "imported": [],
            "skipped": [{"reason": "No hay impresoras descubiertas para importar"}]
        }

    for item in discovered_printers:
        existing = crud.get_printer_by_ip(db, item.ip)
        if existing:
            skipped.append({"ip": item.ip, "reason": "already exists"})
            continue

        resolved_name = item.name or resolve_hostname_value(item.ip, item.snmp_community or "public")
        printer_data = schemas.PrinterCreate(
            shared_name=item.shared_name,
            name=resolved_name,
            model=item.model,
            ip=item.ip,
            serial=item.serial,
            location=None,
            is_color=item.is_color if item.is_color is not None else detect_is_color_from_model(item.model),
            snmp_community=item.snmp_community or "public"
        )

        created = crud.create_printer(db, printer_data)
        imported.append({
            "id": created.id,
            "shared_name": created.shared_name,
            "name": created.name,
            "ip": created.ip,
            "model": created.model,
            "serial": created.serial,
            "is_color": created.is_color
        })

    clear_all_cache()

    return {
        "imported_count": len(imported),
        "skipped_count": len(skipped),
        "imported": imported,
        "skipped": skipped
    }


@router.get("/snmp-walk")
def snmp_walk(ip: str, community: str = "public", oid: str = "1.3.6.1.2.1", max_rows: int = 500):
    """Run an SNMP walk on the backend host for debugging/mapping OIDs.

    Returns a list of { oid: str, value: str } entries.
    """
    try:
        rows = get_snmp_walk(ip, community, oid_prefix=oid, max_rows=max_rows)
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
    return {"ip": ip, "oid": oid, "rows": [{"oid": r[0], "value": r[1]} for r in rows]}


def clear_status_cache():

    STATUS_CACHE["timestamp"]=0

    STATUS_CACHE["data"]= None


def clear_counters_cache():

    COUNTERS_CACHE["timestamp"]=0

    COUNTERS_CACHE["data"]=None


def clear_all_cache():

    clear_status_cache()

    clear_counters_cache()


@router.post("/import-discovered")

def import_discovered_printers(db: Session = Depends(get_db)):

    network = ip_network("10.131.105.0/24", strict=False)

    community = "public"

    imported = []

    skipped = []

    for ip in network.hosts():

        ip_str = str(ip)

        device_name = get_snmp_value(ip_str, community, "1.3.6.1.2.1.1.5.0")

        if device_name is None:

            continue

        full_model = get_snmp_value(ip_str, community, "1.3.6.1.2.1.1.1.0")

        if full_model is None:

            continue

        full_model_str = str(full_model)

        full_model_upper = full_model_str.upper()

        if "RICOH" not in full_model_upper:

            continue

        serial = get_snmp_value(ip_str, community, "1.3.6.1.2.1.43.5.1.1.17.1")

        short_model = str(device_name).strip()

        is_color = detect_is_color_from_model(short_model)

        existing = crud.get_printer_by_ip(db, ip_str)

        if existing:

            skipped.append({"ip": ip_str, "reason": "already exists"})

            continue

        printer_data = schemas.PrinterCreate(shared_name=None, name=None, model=short_model, ip=ip_str, serial=str(serial) if serial else None, location=None, is_color=is_color, snmp_community=community)

        created = crud.create_printer(db, printer_data)

        imported.append({"id": created.id, "shared_name": created.shared_name, "name": created.name, "ip": created.ip, "model": created.model, "serial": created.serial, "is_color": created.is_color})

    return {

        "imported_count": len(imported),

        "skipped_count": len(skipped),

        "imported": imported,

        "skipped": skipped

    }


