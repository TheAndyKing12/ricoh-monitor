import re
import html as html_lib

# Temporary debug flag to print HTTP fetch and parsing information
RICOH_HTTP_DEBUG = True


def _parse_int(text):
    if text is None:
        return None
    s = re.sub(r"[^0-9]", "", str(text))
    if s == "":
        return None
    try:
        return int(s)
    except Exception:
        return None


def _html_to_text(content):
    if not content:
        return ""
    text = re.sub(r"<script.*?</script>", " ", content, flags=re.IGNORECASE | re.DOTALL)
    text = re.sub(r"<style.*?</style>", " ", text, flags=re.IGNORECASE | re.DOTALL)
    text = re.sub(r"<[^>]+>", " ", text)
    text = html_lib.unescape(text)
    text = re.sub(r"\s+", " ", text)
    return text.strip()


def _find_pair(section_text):
    """Extract (color, bw) numbers from a section of HTML/text."""
    if not section_text:
        return None, None
    m_color = re.search(r"A\s*todo\s*color\s*[:ďĽš]?\s*([0-9,\.]+)", section_text, re.IGNORECASE)
    m_bw = re.search(r"Blanco\s*y\s*Negro\s*[:ďĽš]?\s*([0-9,\.]+)", section_text, re.IGNORECASE)
    color = _parse_int(m_color.group(1)) if m_color else None
    bw = _parse_int(m_bw.group(1)) if m_bw else None
    if (color is None or bw is None):
        m_alt = re.search(r"Blanco\s*y\s*Negro\s*[:ďĽš]?\s*([0-9,\.]+).*?A\s*todo\s*color\s*[:ďĽš]?\s*([0-9,\.]+)", section_text, re.IGNORECASE | re.DOTALL)
        if m_alt:
            bw = _parse_int(m_alt.group(1))
            color = _parse_int(m_alt.group(2))
    return color, bw


def _extract_sections(text):
    copy_color = copy_bw = print_color = print_bw = None
    m_copy = re.search(r"Copiadora(.*?)(?:Impresora|Fax|$)", text, re.IGNORECASE | re.DOTALL)
    if m_copy:
        copy_color, copy_bw = _find_pair(m_copy.group(1))
    m_print = re.search(r"Impresora(.*?)(?:Fax|Escaner|Scanner|$)", text, re.IGNORECASE | re.DOTALL)
    if m_print:
        print_color, print_bw = _find_pair(m_print.group(1))
    return copy_bw, copy_color, print_bw, print_color


def get_ricoh_http_counters(ip):
    """Attempt to extract Ricoh counters via HTTP. Returns dict with counters or None."""
    candidate_urls = [
        f"http://{ip}/web/entry/es/websys/webArch/mainFrame.cgi",
        f"http://{ip}/web/entry/es/websys/webArch/topPage.cgi",
        f"http://{ip}/web/entry/es/websys/webArch/header.cgi",
        f"http://{ip}/web/guest/es/websys/webArch/mainFrame.cgi",
        f"http://{ip}/web/guest/es/websys/webArch/topPage.cgi",
        f"http://{ip}/web/guest/es/websys/webArch/header.cgi",
        f"http://{ip}/web/guest/es/websys/status/getUnificationCounter.cgi",
    ]

    copy_bw = copy_color = print_bw = print_color = None
    final_html = None
    final_text = None

    session = requests.Session()
    session.headers.update({"User-Agent": "Mozilla/5.0 (compatible)"})

    def try_get(u):
        if RICOH_HTTP_DEBUG:
            def short_url(url):
                return re.sub(r"(http[s]?://[^/]+)(/.*)", r"\1/...", url)
            print(f"[RICOH_HTTP] try_get: {short_url(u)}")
        try:
            r = session.get(u, timeout=6, allow_redirects=True)
            if r is not None and r.status_code == 200 and r.text:
                if RICOH_HTTP_DEBUG:
                    print(f"[RICOH_HTTP] got {len(r.text)} bytes (200) from {short_url(u)}")
                return r.text
        except Exception as e:
            if RICOH_HTTP_DEBUG:
                print(f"[RICOH_HTTP] request error {short_url(u)}: {e}")
        try:
            r = session.get(u, timeout=6, auth=("admin", ""), allow_redirects=True)
            if r is not None and r.status_code == 200 and r.text:
                if RICOH_HTTP_DEBUG:
                    print(f"[RICOH_HTTP] got {len(r.text)} bytes (200, auth) from {short_url(u)}")
                return r.text
        except Exception:
            pass
        if RICOH_HTTP_DEBUG:
            print(f"[RICOH_HTTP] no content from {short_url(u)}")
        return None

    for url in candidate_urls:
        html = try_get(url)
        if not html:
            continue

        form = re.search(r"<form[^>]+action=[\"']([^\"']*message\.cgi)[\"'][^>]*>(.*?)</form>", html, re.IGNORECASE | re.DOTALL)
        if form:
            form_body = form.group(2)
            inputs = dict(re.findall(r"<input[^>]+name=[\"']([^\"']+)[\"'][^>]+value=[\"']([^\"']*)[\"']", form_body, re.IGNORECASE))
            btn = inputs.get("buttonURL")
            if btn:
                if btn.lower().startswith("http"):
                    btn_url = btn
                else:
                    m = re.match(r"(https?://[^/]+)", url)
                    host_root = m.group(1) if m else f"http://{ip}"
                    btn_url = host_root + btn
                html2 = try_get(btn_url)
                if html2:
                    html = html2

        if re.search(r"<frameset|<frame", html, re.IGNORECASE):
            frames = re.findall(r"<frame[^>]+src=[\"']([^\"']+)[\"']", html, re.IGNORECASE)
            for src in frames:
                if src.lower().startswith("http"):
                    src_url = src
                elif src.startswith("/"):
                    m = re.match(r"(https?://[^/]+)", url)
                    host_root = m.group(1) if m else f"http://{ip}"
                    src_url = host_root + src
                else:
                    src_url = url.rsplit("/", 1)[0] + "/" + src.lstrip("/")
                fhtml = try_get(src_url)
                if not fhtml:
                    continue
                ftext = _html_to_text(fhtml)
                cbw, ccolor, pbw, pcolor = _extract_sections(ftext)
                if cbw is not None:
                    copy_bw = cbw
                if ccolor is not None:
                    copy_color = ccolor
                if pbw is not None:
                    print_bw = pbw
                if pcolor is not None:
                    print_color = pcolor
                final_html = fhtml
                final_text = ftext
            if copy_color is not None or copy_bw is not None or print_color is not None or print_bw is not None:
                break
        else:
            text = _html_to_text(html)
            cbw, ccolor, pbw, pcolor = _extract_sections(text)
            if cbw is not None:
                copy_bw = cbw
            if ccolor is not None:
                copy_color = ccolor
            if pbw is not None:
                print_bw = pbw
            if pcolor is not None:
                print_color = pcolor
            final_html = html
            final_text = text
            if copy_color is not None or copy_bw is not None or print_color is not None or print_bw is not None:
                break

    if final_text and ((copy_color is None and print_color is None) or (copy_bw is None and print_bw is None)):
        all_color_matches = re.findall(r"A\s*todo\s*color\s*[:ďĽš]?\s*([0-9,\.]+)", final_text, re.IGNORECASE)
        all_bw_matches = re.findall(r"Blanco\s*y\s*Negro\s*[:ďĽš]?\s*([0-9,\.]+)", final_text, re.IGNORECASE)
        try:
            if len(all_color_matches) >= 1 and copy_color is None:
                copy_color = _parse_int(all_color_matches[0])
            if len(all_color_matches) >= 2 and print_color is None:
                print_color = _parse_int(all_color_matches[1])
            if len(all_bw_matches) >= 1 and copy_bw is None:
                copy_bw = _parse_int(all_bw_matches[0])
            if len(all_bw_matches) >= 2 and print_bw is None:
                print_bw = _parse_int(all_bw_matches[1])
        except Exception:
            pass

    bw_pages = None
    color_pages = None
    total_pages = None
    if (copy_bw is not None) or (print_bw is not None):
        bw_pages = (copy_bw or 0) + (print_bw or 0)
    if (copy_color is not None) or (print_color is not None):
        color_pages = (copy_color or 0) + (print_color or 0)
    if bw_pages is not None and color_pages is not None:
        total_pages = bw_pages + color_pages

    if RICOH_HTTP_DEBUG:
        print(f"[RICOH_HTTP] result for {ip}: copy_bw={copy_bw}, copy_color={copy_color}, print_bw={print_bw}, print_color={print_color}, bw_pages={bw_pages}, color_pages={color_pages}, total_pages={total_pages}")
        if final_text:
            print(f"[RICOH_HTTP] final_text snippet: {final_text[:800]}")

    return {
        "bw_pages": bw_pages,
        "color_pages": color_pages,
        "total_pages": total_pages,
        "copy_bw": copy_bw,
        "copy_color": copy_color,
        "print_bw": print_bw,
        "print_color": print_color,
    }
