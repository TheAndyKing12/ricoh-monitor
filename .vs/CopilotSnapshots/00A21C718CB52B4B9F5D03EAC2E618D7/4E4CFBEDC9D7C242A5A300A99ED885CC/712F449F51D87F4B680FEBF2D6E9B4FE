<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Ricoh Monitor Dashboard</title>
<link rel="stylesheet" href="style.css">
<link rel="stylesheet" href="bootstrap-icons.min.css">
<link rel="stylesheet" href="inter.css">
<style>
*{box-sizing:border-box}
body{margin:0;font-family:'Inter',Arial,sans-serif;background:#111827;color:#f3f4f6}
.layout{display:flex;min-height:100vh}
.sidebar{width:64px;background:#0f172a;border-right:1px solid #1f2937;padding:12px 8px;transition:width .28s ease}
.sidebar:hover{width:240px;padding:20px}
.sidebar h2{margin:0 0 12px 0;font-size:18px;transition:opacity .18s ease,transform .18s ease}
.sidebar-title{display:inline-block;opacity:1;transform:none;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .sidebar-title{opacity:0;transform:translateX(-8px)}
.menu-button{width:100%;display:flex;align-items:center;gap:10px;justify-content:center;background:#111827;color:#e5e7eb;border:1px solid #374151;border-radius:10px;padding:12px 14px;text-align:left;font-size:14px;cursor:pointer;margin-bottom:10px;transition:background .2s ease,border-color .2s ease,box-shadow .2s ease,color .2s ease,transform .15s ease;position:relative}
.menu-button:nth-child(2){transition-delay:30ms}
.menu-button:nth-child(3){transition-delay:60ms}
.menu-button:nth-child(4){transition-delay:90ms}
.menu-button:nth-child(5){transition-delay:120ms}
.menu-button:nth-child(6){transition-delay:150ms}
.menu-button:hover{background:#1f2937}
.sidebar:hover .menu-button{justify-content:flex-start}
.menu-button.active{background:rgba(37,99,235,0.12);border-color:rgba(59,130,246,0.45);color:#93c5fd;box-shadow:inset 3px 0 0 #3b82f6}
.menu-button.active .menu-icon i{color:#60a5fa}
.menu-icon{font-size:18px;flex-shrink:0;width:20px;text-align:center;line-height:1;position:relative}
.menu-icon i{display:inline-block;transition:transform .22s cubic-bezier(.34,1.56,.64,1),color .18s ease}
.menu-button:hover .menu-icon i{transform:scale(1.28);color:#60a5fa}
.menu-badge{position:absolute;top:-7px;right:-9px;background:#ef4444;color:#fff;font-size:9px;font-weight:700;min-width:15px;height:15px;border-radius:999px;display:none;align-items:center;justify-content:center;padding:0 3px;line-height:1;border:1.5px solid #0f172a;animation:badgePop .25s cubic-bezier(.34,1.56,.64,1)}
.menu-badge.warn{background:#f59e0b}
@keyframes badgePop{from{transform:scale(0)}to{transform:scale(1)}}
.menu-label{display:inline-block;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .menu-label{opacity:0;transform:translateX(-6px);width:0;overflow:hidden}
.content{flex:1;display:flex;flex-direction:column}
header{padding:14px 20px;background:#0f172a;border-bottom:1px solid #1f2937;display:flex;flex-direction:column;gap:12px}
.badge{padding:8px 12px;border-radius:999px;background:#1f2937;font-size:13px}
.tab{display:none;padding:12px}
.tab.active{display:block;animation:tabFadeIn .18s ease}
@keyframes tabFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:12px}
.summary-card{background:#1f2937;border:1px solid #374151;border-radius:14px;padding:18px;position:relative;overflow:hidden;transition:transform .2s ease,box-shadow .2s ease}
.summary-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(255,255,255,.1)}
.summary-card-total{border-color:#2563eb}
.summary-card-online{border-color:#22c55e}
.summary-card-offline{border-color:#ef4444}
.summary-card-toner{border-color:#eab308}
.summary-card h3{margin:0 0 8px;font-size:13px;color:#9ca3af;font-weight:normal;display:flex;align-items:center;gap:6px}
.summary-card .value{font-size:28px;font-weight:bold}
.summary-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 14px 14px}
.summary-card-total::after{background:#2563eb}
.summary-card-online::after{background:#22c55e}
.summary-card-offline::after{background:#ef4444}
.summary-card-toner::after{background:#eab308}
.card-icon-bg
.summary-card:hover .card-icon-bg{opacity:.13}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:18px}
.card{background:#1f2937;border:1px solid #374151;border-radius:16px;padding:18px;box-shadow:0 2px 12px rgba(0,0,0,.25);transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease}
.card:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(0,0,0,.4);border-color:#4b5563}
.card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px}
.printer-name{font-size:18px;font-weight:bold;margin:0}
.printer-model{margin-top:4px;font-size:13px;color:#9ca3af}
.printer-secondary{margin-top:4px;font-size:13px;color:#d1d5db}
.status-pill{padding:6px 10px;border-radius:999px;font-size:12px;font-weight:bold;text-transform:uppercase;white-space:nowrap}
.status-online{background:rgba(34,197,94,.18);color:#22c55e;border:1px solid rgba(34,197,94,.4)}
.status-offline{background:rgba(239,68,68,.18);color:#ef4444;border:1px solid rgba(239,68,68,.4)}
.info-row{font-size:13px;color:#d1d5e1;margin-bottom:6px}
.toner-section{margin-top:16px}
.toner-title{font-size:13px;color:#9ca3baf;margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em}
.toner-item{margin-bottom:12px}
.toner-label-row{display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px}
.bar{width:100%;height:12px;background:#111827;border-radius:999px;overflow:hidden;border:1px solid #374151}
.bar-fill{height:100%;border-radius:999px;transition:width .4s ease}
.bar-black{background:linear-gradient(90deg,#64748b,#e5e7eb)}
.bar-cyan{background:linear-gradient(90deg,#0891b2,#22d3ee)}
.bar-magenta{background:linear-gradient(90deg,#a21caf,#e879f9)}
.bar-yellow{background:linear-gradient(90deg,#b45309,#fde047)}
.empty-state{text-align:center;padding:60px 20px;color:#9ca3baf;background:#1f2937;border-radius:16px;border:1px solid #374151}
.warning-text{color:#f59e0b;font-size:12px;margin-top:8px}
.critical-text{color:#ef4444;font-size:12px;margin-top:8px}
.section-title{padding-left:14px;border-left:3px solid #3b82f6}
.action-row{display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap}
.action-button{background:#2563eb;color:#fff;border:none;border-radius:10px;padding:12px 16px;cursor:pointer;font-size:14px}
.action-button:hover{background:#1d4ed8}
.action-button-danger{background:#dc2626}
.action-button-danger:hover{background:#b91c1c}
.action-button-secondary{background:#475569}
.action-button-secondary:hover{background:#334155}
.action-button-warning{background:#eab308;color:#111827;font-weight:700}
.action-button-warning:hover{background:#ca8a04}
.action-button-success{background:#16a34a}
.action-button-success:hover{background:#15803d}
.table-wrapper{background:#1f2937;border:1px solid #374151;border-radius:16px;overflow:auto;max-width:100%;max-height:70vh}
table{width:100%;border-collapse:collapse;min-width:1100px}
th,td{padding:14px;text-align:left;border-bottom:1px solid #374151;font-size:14px;vertical-align:top}
th{background:#111827;color:#9ca3af}
tr:last-child td{border-bottom:none}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.form-grid>div{display:flex;flex-direction:column;gap:6px}
.form-grid label{display:block;font-size:13px;color:#cbd5e1;font-weight:600}
input,select{padding:10px;border-radius:8px;border:1px solid #374151;background:#111827;color:white;width:100%}
.dashboard-title{font-size:24px;font-weight:700;color:#f8fafc;line-height:1.1}
.dashboard-header{width:100%;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.dashboard-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.filter-toggle-btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;min-width:220px;min-height:44px;background:linear-gradient(180deg,#1e293b 0%,#162033 100%);border:1px solid #3b4d65;color:#f8fafc;border-radius:999px;padding:10px 16px;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.22);transition:.2s ease}
.filter-toggle-btn:hover{transform:translateY(-1px);background:linear-gradient(180deg,#25344b 0%,#1a2638 100%)}
.filter-toggle-btn.is-open{background:linear-gradient(180deg,#1d4ed8 0%,#1e40af 100%);border-color:#60a5fa;box-shadow:0 6px 18px rgba(37,99,235,.28)}
.filter-toggle-btn.is-open .filter-toggle-state{color:#dbeafe}
.filter-toggle-icon{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:999px;background:#111827;border:1px solid #334155;font-size:12px;color:#cbd5e1;flex:0 0 auto}
.filter-toggle-btn.is-open .filter-toggle-icon{background:rgba(15,23,42,.6);border-color:#93c5fd;color:#eff6ff}
.dashboard-filters{display:grid;grid-template-columns:minmax(240px,2fr) repeat(5,minmax(120px,1fr)) minmax(96px,auto);gap:8px;margin:0 0 12px;align-items:center;transition:max-height .25s ease,opacity .2s ease,transform .2s ease;max-height:600px;opacity:1;transform:none;overflow:visible;pointer-events:auto}
.dashboard-filters.closed{max-height:0;opacity:0;transform:translateY(-8px);margin:0;gap:0;overflow:hidden;pointer-events:none}
.toolbar-input,.toolbar-select{min-height:34px;padding:7px 10px;border-radius:8px;border:1px solid #374151;background:#0f172a;color:#e5e7eb;font-size:12px;width:100%}
.toolbar-button{min-height:34px;padding:7px 12px;border-radius:8px;border:1px solid #374151;background:#1f2937;color:#e5e7eb;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap}
.toolbar-button:hover{background:#273244}
.warning-text,.error-warn,.toner-low{color:#f59e0b !important;font-weight:700}
.critical-text,.error-critical,.toner-critical{color:#ef4444 !important;font-weight:700}
.error-ok{color:#cbd5e1}
.printer-collapsible{display:none}
.printer-collapsible.is-open{display:block}
.discover-fields{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:14px}
.discover-fields>div{display:flex;flex-direction:column;gap:6px}
.field-help{font-size:12px;margin-top:4px;color:#9ca3b8}
.field-help.error{color:#ef4444}
.field-help.success{color:#22c55e}
.input-invalid{border-color:#ef4444 !important;box-shadow:0 0 0 1px rgba(239,68,68,.35)}
.input-valid{border-color:#22c55e !important;box-shadow:0 0 0 1px rgba(34,197,94,.25)}
.discover-select-col{width:56px;text-align:center}
.discover-checkbox{width:18px;height:18px;accent-color:#2563eb;cursor:pointer}
.sortable-th{cursor:pointer;user-select:none;white-space:nowrap}
.sortable-th:hover{color:#e5e7eb}
.row-error{background:rgba(239,68,68,.07)}.row-low{background:rgba(234,179,8,.07)}
.status-badge{padding:4px 8px;border-radius:999px;font-size:12px;font-weight:700}
.status-badge-online{background:rgba(34,197,94,.18);color:#22c55e}
.status-badge-offline{background:rgba(239,68,68,.18);color:#ef4444}
.toner-inline{display:flex;gap:8px;flex-wrap:wrap}
.toner-mini{display:flex;align-items:center;gap:6px;min-width:80px}.mini-bar{width:42px;height:8px;background:#111827;border:1px solid #374151;border-radius:999px;overflow:hidden}.mini-bar .fill{height:100%}.mini-label{font-size:12px}.tc-muted{color:#94a3b8}
.sort-ind{font-size:11px;color:inherit;opacity:0.5;margin-left:5px;min-width:10px;display:inline-block;transition:opacity 0.15s,font-weight:600}
.sort-ind.active{opacity:1;text-shadow:none;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);display:none;align-items:center;justify-content:center;z-index:1000;padding:16px;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex;animation:modalFadeIn .18s ease}
@keyframes modalFadeIn{from{opacity:0}to{opacity:1}}
.modal-box{background:#1e293b;border:1px solid #334155;border-radius:20px;padding:28px;width:100%;max-width:560px;max-height:88vh;overflow-y:auto;position:relative;animation:modalSlideUp .22s cubic-bezier(.34,1.56,.64,1)}
@keyframes modalSlideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-close{position:absolute;top:14px;right:14px;background:none;border:none;color:#64748b;font-size:18px;cursor:pointer;padding:4px 8px;border-radius:8px;line-height:1}
.modal-close:hover{background:#334155;color:#e2e8f0}
.modal-title{font-size:20px;font-weight:700;color:#f8fafc;margin:0 0 4px;padding-right:32px}
.modal-subtitle{font-size:13px;color:#94a3b8;margin:0 0 20px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.modal-section{margin-bottom:20px}
.modal-section-title{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#475569;margin:0 0 10px;font-weight:700}
.modal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.modal-field{background:#111827;border:1px solid #1f2937;border-radius:10px;padding:10px 14px}
.modal-field-label{font-size:10px;color=#475569;margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em}
.modal-field-value{font-size:13px;color:#e2e8f0;font-weight:500}
.modal-toner-item{margin-bottom:12px}
.modal-toner-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:5px;color:#cbd5e1}
.modal-bar{width:100%;height:10px;background:#0f172a;border-radius:999px;overflow:hidden;border:1px solid #1f2937}
.modal-bar-fill{height:100%;border-radius:999px;transition:width .5s ease}
.modal-actions{display:flex;gap:10px;margin-top:22px;justify-content:flex-end;border-top:1px solid #1f2937;padding-top:18px}
.clickable-name{cursor:pointer;color:#93c5fd}
.clickable-name:hover{text-decoration:underline}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:900;display:none;cursor:pointer;backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px)}
.drawer-overlay.open{display:block}
.drawer-panel{position:fixed;top:0;right:0;height:100vh;width:460px;max-width:96vw;background:#1e293b;border-left:1px solid #334155;z-index=901;transform:translateX(110%);transition:transform .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-8px 0 40px rgba(0,0,0,.45)}
.drawer-panel.open{transform:translateX(0);animation:drawerSlideIn .35s cubic-bezier(.34,1.56,.64,1)}
.drawer-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px 16px;border-bottom:1px solid #334155;flex-shrink:0}
.drawer-title{font-size:16px;font-weight:700;color:#f8fafc;margin:0}
.drawer-close{background:none;border:none;color:#64748b;font-size:20px;cursor:pointer;padding:4px 8px;border-radius:8px;line-height:1}
.drawer-close:hover{background:#334155;color:#e2e8f0}
.drawer-body{flex:1;overflow-y:auto;padding:20px 24px}
.drawer-footer{padding:16px 24px;border-top:1px solid #334155;display:flex;gap:10px;justify-content:flex-end;flex-shrink:0}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#0f172a}
::-webkit-scrollbar-thumb{background:#334155;border-radius:999px}
::-webkit-scrollbar-thumb:hover{background:#475569}
tbody tr:hover td{background:rgba(255,255,255,.035);transition:background .15s ease}
.toast{position:fixed;bottom:24px;right:24px;background:#1e293b;border:1px solid #334155;color:#f8fafc;padding:14px 20px;border-radius:12px;font-size:14px;z-index:2000;box-shadow:0 8px 24px rgba(0,0,0,.4);transform:translateY(20px);opacity:0;transition:transform .25s ease,opacity .25s ease;pointer-events:none;max-width:320px}
.toast.show{transform:translateY(0);opacity:1}
.toast.toast-success{border-color:rgba(34,197,94,.4)}
.toast.toast-error{border-color:rgba(239,68,68,.4)}
.toast{display:flex;align-items:center}
tbody tr:nth-child(even) td{background:rgba(255,255,255,.018)}
thead th{position:sticky;top:0;z-index:2;box-shadow:0 1px 0 #374151}
input:focus,select:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 2px rgba(59,130,246,.18)}
.section-title{padding-left:14px;border-left:3px solid #3b82f6}
.drawer-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#2563eb,#60a5fa);z-index:1}
@keyframes offlinePulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}50%{box-shadow:0 0 0 5px rgba(239,68,68,.13)}}
.status-offline{animation:offlinePulse 2.8s ease-in-out infinite}
.action-button:active{transform:scale(.97)}
.sidebar:not(:hover) .menu-button[data-tooltip]::after{content:attr(data-tooltip);position:absolute;left:calc(100% + 10px);top:50%;transform:translateY(-50%);background:#1e293b;color:#f8fafc;padding:6px 12px;border-radius:8px;font-size:12px;white-space:nowrap;pointer-events:none;opacity:0;border:1px solid #334155;box-shadow:0 4px 14px rgba(0,0,0,.35);z-index:9999;transition:opacity .15s ease}
.sidebar:not(:hover) .menu-button[data-tooltip]:hover::after{opacity:1}
.status-badge-online::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:#22c55e;margin-right:5px;vertical-align:middle;animation:statusDotPulse 2.2s ease-in-out infinite}
.status-badge-offline::before{content:'';display:inline-block;width:6px,height:6px;border-radius:50%;background:#ef4444;margin-right:5px;vertical-align:middle}
@keyframes statusDotPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
@keyframes drawerSlideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes drawerSlideOut{from{transform:translateX(0);opacity:1}to{transform:translateX(100%);opacity:0}}
.drawer-panel.closing{animation:drawerSlideOut .28s cubic-bezier(.4,0,.2,1) forwards}
.loading-spinner-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 20px;gap:14px}
.loading-spinner{width:36px;height:36px;border:3px solid #1f2937;border-top-color:#3b82f6;border-radius:50%;animation:spinnerRotate .7s linear infinite}
@keyframes spinnerRotate{to{transform:rotate(360deg)}}
.loading-spinner-text{font-size:13px;color:#64748b}
.summary-card-total:hover{box-shadow:0 0 24px rgba(37,99,235,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-online:hover{box-shadow:0 0 24px rgba(34,197,94,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-offline:hover{box-shadow:0 0 24px rgba(239,68,68,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-toner:hover{box-shadow:0 0 24px rgba(234,179,8,.28),0 8px 28px rgba(255,255,255,.1)}
@keyframes badgeShake{0%,100%{transform:translateX(0)}20%{transform:translateX(-2px)}40%{transform:translateX(2px)}60%{transform:translateX(-1.5px)}80%{transform:translateX(1.5px)}}
.menu-badge[style*="flex"]{animation:badgePop .25s cubic-bezier(.34,1.56,.64,1),badgeShake .4s ease .3s 2}
@keyframes barShimmer{from{left:-100%}to{left:100%}}
.bar-fill{position:relative;overflow:hidden}
.bar-fill::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.18),transparent);animation:barShimmer 2.4s ease-in-out infinite}
@keyframes rowSlideIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.stagger-row{animation:rowSlideIn .22s ease both}
.action-button,.filter-toggle-btn,.toolbar-button{position:relative;overflow:hidden}
.btn-ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.22);transform:scale(0);animation:rippleAnim .5s ease-out;pointer-events:none}
@keyframes rippleAnim{to{transform:scale(4);opacity:0}}
@keyframes skeletonPulse{0%{background-position:-200% 0}100%{background-position:200% 0}}
.skeleton{background:linear-gradient(90deg,#1f2937 25%,#2a3a50 50%,#1f2937 75%);background-size:200% 100%;animation:skeletonPulse 1.5s ease-in-out infinite;border-radius:8px;min-height:16px}
.skeleton-row{display:flex;gap:12px;padding:10px 14px}.skeleton-cell{flex:1;height:14px}
.modal-saving-overlay{position:absolute;inset:0;background:rgba(15,23,42,.88);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;border-radius:20px;z-index:10;animation:modalFadeIn .18s ease}
.search-highlight{background:#fde047;color:#111827;border-radius:2px;padding:0 2px}
.app-modal-form .form-grid{gap:10px}
.app-modal-form .form-grid label{font-size:12px;color:#94a3b8;margin-bottom:2px}
.app-confirm-message{font-size:14px;color:#cbd5e1;line-height:1.6}
.kbd{display:inline-block;background:#1f2937;border:1px solid #374151;border-radius:4px;padding:1px 6px;font-size:11px;font-family:monospace;color:#94a3b8;margin:0 2px;vertical-align:middle}
.inv-qty-input{width:72px;padding:5px 8px;border-radius:8px;border:2px solid #374151;background:#0f172a;color:#f8fafc;font-size:14px;font-weight:700;text-align:center;transition:border-color .2s,box-shadow .2s,color .2s;-moz-appearance:textfield}
.inv-qty-input::-webkit-inner-spin-button,.inv-qty-input::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
.inv-qty-input:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 2px rgba(59,130,246,.25)}
.inv-qty-input.qty-ok{border-color:#22c55e;color:#22c55e}
.inv-qty-input.qty-low{border-color:#f59e0b;color:#f59e0b}
.inv-qty-input.qty-critical{border-color:#ef4444;color:#ef4444}
.inv-toolbar{display:flex;align-items:center;gap:10px;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:12px;margin-bottom:12px;flex-wrap:wrap}
.inv-toolbar-sep{width:1px;align-self:stretch;background:#334155;margin:0 4px;min-height:28px}
.inv-search-wrap{position:relative;min-width:200px;max-width:340px;flex:1}
.inv-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#64748b;font-size:13px;pointer-events:none}
.inv-search-wrap .toolbar-input{padding-left:32px;width:100%}
.tc-cell-k{background:rgba(100,116,139,.22);color:#e2e8f0;font-weight:700;text-align:center}
.tc-cell-c{background:rgba(8,145,178,.18);color:#22d3ee;font-weight:700;text-align:center}
.tc-cell-m{background:rgba(162,28,175,.18);color:#e879f9;font-weight:700;text-align:center}
.tc-cell-y{background:rgba(180,83,9,.18);color:#fde047;font-weight:700;text-align:center}
.tc-cell-k.tc-low{background:rgba(245,158,11,.18);color:#fbbf24;border-left:3px solid #f59e0b}
.tc-cell-c.tc-low{background:rgba(245,158,11,.18);color:#fbbf24;border-left:3px solid #f59e0b}
.tc-cell-m.tc-low{background:rgba(245,158,11,.18);color:#fbbf24;border-left:3px solid #f59e0b}
.tc-cell-y.tc-low{background:rgba(245,158,11,.18);color:#fbbf24;border-left:3px solid #f59e0b}
.tc-cell-k.tc-crit{background:rgba(239,68,68,.18);color:#f87171;border-left:3px solid #ef4444;animation:offlinePulse 2.8s ease-in-out infinite}
.tc-cell-c.tc-crit{background:rgba(239,68,68,.18);color:#f87171;border-left:3px solid #ef4444;animation:offlinePulse 2.8s ease-in-out infinite}
.tc-cell-m.tc-crit{background:rgba(239,68,68,.18);color:#f87171;border-left:3px solid #ef4444;animation:offlinePulse 2.8s ease-in-out infinite}
.tc-cell-y.tc-crit{background:rgba(239,68,68,.18);color:#f87171;border-left:3px solid #ef4444;animation:offlinePulse 2.8s ease-in-out infinite}
.tc-backup-zero{color:#64748b}
.tc-backup-alert{background:rgba(239,68,68,.15);border-left:3px solid #ef4444}
.tc-backup-alert .tc-inline{color:#f87171}
.tc-backup-warn{background:rgba(245,158,11,.12);border-left:3px solid #f59e0b}
.tc-backup-warn .tc-inline{color:#fbbf24}
.tc-notes-cell{max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tc-toolbar{display:flex;align-items:center;gap:10px;padding:10px 14px;background:#1e293b;border:1px solid #334155;border-radius:12px;margin-bottom:12px;flex-wrap:wrap}
.tc-search-wrap{position:relative;min-width:200px;max-width:340px;flex:1}
.tc-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#64748b;font-size:13px;pointer-events:none}
.tc-search-wrap .toolbar-input{padding-left:32px;width:100%}
.tc-inline{padding:4px 6px;border-radius:6px;border:1px solid transparent;background:transparent;color:#e5e7eb;font-size:12px;width:100%;min-height:28px;transition:border-color .2s,background .2s}
.tc-inline:hover{border-color:#334155;background:#0f172a}
.tc-inline:focus{outline:none;border-color:#3b82f6;background:#0f172a;box-shadow:0 0 0 2px rgba(59,130,246,.18)}
.tc-inline-num{width:48px;text-align:center;-moz-appearance:textfield}
.tc-inline-num::-webkit-inner-spin-button,.tc-inline-num::-webkit-outer-spin-button{-webkit-appearance:none;margin:0}
.tc-inline-date{width:120px}
.tc-inline-text{min-width:70px;max-width:120px}
.tc-inline-notes{min-width:90px;max-width:150px}
.tc-saving{opacity:.5;pointer-events:none}
</style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <h2><span class="sidebar-title">Ricoh Monitor</span></h2>
        <button class="menu-button" onclick="showTab('dashboard')" data-tooltip="Dashboard"><span class="menu-icon"><i class="bi bi-display"></i><span class="menu-badge warn" id="badge_toner"></span></span><span class="menu-label">Dashboard</span></button>
        <button class="menu-button" onclick="showTab('printers')" data-tooltip="Impresoras"><span class="menu-icon"><i class="bi bi-printer"></i><span class="menu-badge" id="badge_offline"></span></span><span class="menu-label">Impresoras</span></button>
        <button class="menu-button" onclick="showTab('counters')" data-tooltip="Contadores"><span class="menu-icon"><i class="bi bi-clipboard-data"></i></span><span class="menu-label">Contadores</span></button>
        <button class="menu-button" onclick="showTab('inventory')" data-tooltip="Inventario"><span class="menu-icon"><i class="bi bi-boxes"></i></span><span class="menu-label">Control de Inventario</span></button>
        <button class="menu-button" onclick="showTab('tonerControl')" data-tooltip="Control de Toner"><span class="menu-icon"><i class="bi bi-layers"></i></span><span class="menu-label">Control de Toner</span></button>
    </aside>

    <main class="content">
        <div id="dashboard" class="tab dashboard-shell">
            <header>
                <div class="dashboard-header">
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <div class="dashboard-title"><i class="bi bi-display" style="margin-right:8px;color:#60a5fa;font-size:22px;vertical-align:middle"></i>Ricoh Monitor Dashboard</div>
                        <div class="badge" id="lastUpdate" style="padding:6px 10px;font-size:12px">Actualizando...</div>
                    </div>
                    <div class="dashboard-actions">
                        <button id="dashboardFilterBtn" class="filter-toggle-btn" type="button" onclick="toggleDashboardFilters()">
                            <span class="filter-toggle-icon" id="filterToggleIcon">&#9662;</span>
                            <span>Filtros del dashboard</span>
                            <span class="filter-toggle-state" id="filterToggleState">Ocultos</span>
                        </button>
                        <button id="fullscreenBtn" class="filter-toggle-btn" type="button" onclick="toggleDashboardFullscreen()" title="Pantalla completa">
                            <span class="filter-toggle-icon" id="fullscreenBtnIcon">&#9974;</span>
                            <span id="fullscreenBtnLabel">Pantalla completa</span>
                        </button>
                    </div>
                </div>
                <div class="summary" style="width:100%;margin:0;">
                    <div class="summary-card summary-card-total"><h3><i class="bi bi-printer"></i>Total impresoras</h3><div class="value" id="totalPrinters">0</div><span class="card-icon-bg"><i class="bi bi-printer"></i></span></div>
                    <div class="summary-card summary-card-online"><h3><i class="bi bi-wifi"></i>Online</h3><div class="value" id="onlinePrinters">0</div><span class="card-icon-bg"><i class="bi bi-wifi"></i></span></div>
                    <div class="summary-card summary-card-offline"><h3><i class="bi bi-wifi-off"></i>Offline</h3><div class="value" id="offlinePrinters">0</div><span class="card-icon-bg"><i class="bi bi-wifi-off"></i></span></div>
                    <div class="summary-card summary-card-toner"><h3><i class="bi bi-exclamation-triangle"></i>Tóner bajo</h3><div class="value" id="lowTonerPrinters">0</div><span class="card-icon-bg"><i class="bi bi-exclamation-triangle"></i></span></div>
                </div>
            </header>

            <div id="dashboardFilters" class="dashboard-filters closed">
                <input id="searchInput" class="toolbar-input" type="text" placeholder="Buscar por shared name, name, IP, modelo o serie">
                <select id="viewMode" class="toolbar-select"><option value="table">Vista tabla</option><option value="cards">Vista tarjetas</option></select>
                <select id="statusFilter" class="toolbar-select"><option value="all">Estado: Todas</option><option value="online">Estado: Online</option><option value="offline">Estado: Offline</option></select>
                <select id="typeFilter" class="toolbar-select"><option value="all">Tipo: Todas</option><option value="color">Tipo: Color</option><option value="mono">Tipo: Blanco y negro</option></select>
                <select id="errorFilter" class="toolbar-select"><option value="all">Error: Todos</option><option value="ok">Error: Sin error</option><option value="low">Error: Tóner bajo</option><option value="critical">Error: Tóner crítico</option><option value="other">Error: Otros</option></select>
                <select id="sortFilter" class="toolbar-select"><option value="relevance_desc">Orden: Relevancia ↓</option><option value="relevance_asc">Orden: Relevancia ↑</option><option value="shared_name_asc">Orden: Shared Name A-Z</option><option value="shared_name_desc">Orden: Shared Name Z-A</option><option value="name_asc">Orden: Name A-Z</option><option value="name_desc">Orden: Name Z-A</option><option value="ip_asc">Orden: IP ↑</option><option value="ip_desc">Orden: IP ↓</option><option value="model_asc">Orden: Modelo A-Z</option><option value="model_desc">Orden: Modelo Z-A</option></select>
                <button class="toolbar-button" onclick="resetFilters()">Limpiar</button>
            </div>

            <div id="dashboardCardsView" class="dashboard-view-wrap"><div class="grid" id="printersGrid"></div></div>
            <div id="dashboardTableView" class="dashboard-view-wrap" style="display:none;">
                <div class="table-wrapper dashboard-table-wrap">
                    <table class="dashboard-table">
                        <thead>
                            <tr>
                                <th class="sortable-th" onclick="toggleTableSort('shared_name')">Shared Name <span class="sort-ind" id="dsort_shared_name"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('name')">Name <span class="sort-ind" id="dsort_name"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('model')">Modelo <span class="sort-ind" id="dsort_model"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('serial')">Serie <span class="sort-ind" id="dsort_serial"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('ip')">IP <span class="sort-ind" id="dsort_ip"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('location')">Ubicación <span class="sort-ind" id="dsort_location"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('status')">Status <span class="sort-ind" id="dsort_status"></span></th>
                                <th class="sortable-th" onclick="toggleTableSort('error_message')">Error <span class="sort-ind" id="dsort_error_message"></span></th>
                                <th>Tóner</th>
                            </tr>
                        </thead>
                        <tbody id="dashboardTableBody"><tr><td colspan="9">Cargando...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="printers" class="tab">
            <h2 class="section-title">Gestión de impresoras</h2>
            <div class="action-row" style="margin-bottom:16px;">
                <button class="action-button" type="button" onclick="openDrawer(null)">Agregar impresora manualmente</button>
                <button class="action-button action-button-secondary" type="button" onclick="togglePrinterSection('discoverPrinterCard')">Buscar impresoras en red</button>
            </div>

            <div id="discoverPrinterCard" class="card printer-collapsible" style="margin-bottom:20px;">
                <h3 style="margin-top:0;">Buscar impresoras en red</h3>
                <div class="discover-fields">
                    <div><label>Buscar por</label><select id="discoverMode" onchange="toggleDiscoverModeFields()"><option value="range">Rango de IP</option><option value="ip">IP específica</option></select></div>
                    <div id="discoverStartWrap"><label>IP inicial</label><input id="discoverStartIp" placeholder="Ej: 10.131.105.1"><div id="discoverStartIpHelp" class="field-help"></div></div>
                    <div id="discoverEndWrap"><label>IP final</label><input id="discoverEndIp" placeholder="Ej: 10.131.105.254"><div id="discoverEndIpHelp" class="field-help"></div></div>
                    <div id="discoverSingleWrap" style="display:none;"><label>IP impresora</label><input id="discoverSingleIp" placeholder="Ej: 10.131.105.25"><div id="discoverSingleIpHelp" class="field-help"></div></div>
                    <div><label>SNMP Community</label><input id="discoverCommunity" value="public"></div>
                </div>
                <div class="action-row">
                    <button class="action-button" onclick="discoverPrinters()">Buscar impresoras</button>
                    <button class="action-button" onclick="importPrinters()">Importar encontradas</button>
                </div>
                <div class="table-wrapper"><table><thead><tr><th class="discover-select-col"><input id="selectAllDiscovered" class="discover-checkbox" type="checkbox" onchange="toggleAllDiscovered(this.checked)"></th><th>Shared Name</th><th>Nombre</th><th>IP</th><th>Modelo</th><th>Serie</th><th>Tipo</th></tr></thead><tbody id="printersList"><tr><td colspan="7">Configure la búsqueda y presione buscar.</td></tr></tbody></table></div>
            </div>

            <div class="card">
                <h3 style="margin-top:0;">Impresoras registradas</h3>
                <div class="action-row"><input id="printerSearch" placeholder="Buscar impresora..." oninput="filterSavedPrinters()" style="max-width:340px;"></div>
                <div class="table-wrapper"><table><thead><tr><th class="sortable-th" onclick="toggleSavedPrintersSort('id')">ID <span id="savedPrintersSort_id">&#9650;</span></th><th class="sortable-th" onclick="toggleSavedPrintersSort('shared_name')">Shared Name <span id="savedPrintersSort_shared_name">&#8597;</span></th><th class="sortable-th" onclick="toggleSavedPrintersSort('name')">Nombre <span id="savedPrintersSort_name">&#8597;</span></th><th class="sortable-th" onclick="toggleSavedPrintersSort('ip')">IP <span id="savedPrintersSort_ip">&#8597;</span></th><th>Modelo</th><th>Serie</th><th>Tipo</th><th>Acciones</th></tr></thead><tbody id="savedPrintersList"><tr><td colspan="8">Cargando impresoras...</td></tr></tbody></table></div>
            </div>
        </div>

        <div id="addressBook" class="tab">
            <h2 class="section-title">Libreta de direcciones</h2>
            <div class="action-row">
                <button class="action-button action-button-secondary" type="button" onclick="showTab('printers')">Volver a impresoras</button>
                <button class="action-button action-button-warning" type="button" onclick="createAddressBookEntry()">Agregar usuario</button>
                <button class="action-button" type="button" onclick="loadAddressBookEntries()">Refrescar</button>
                <button class="action-button action-button-secondary" type="button" onclick="applyAddressBookChanges()">Aplicar cambios a impresora</button>
            </div>
            <div class="card">
                <h3 id="addressBookPrinterTitle" style="margin-top:0;">Seleccione una impresora</h3>
                <div id="addressBookPrinterMeta" style="font-size:13px;color:#94a3b8;margin-top:6px;">Abra esta vista desde el botón amarillo en la tabla de acciones.</div>
                <div id="addressBookStatus" class="field-help" style="margin-top:14px;">Fase segura: esta pantalla usa almacenamiento local aislado.</div>
            </div>
            <div class="table-wrapper"><table><thead><tr><th>Registration No.</th><th>Name</th><th>Key Display</th><th>Freq.</th><th>Title 1</th><th>Title 2</th><th>Title 3</th><th>User Code</th><th>E-mail Address</th><th>Folder</th><th>Status</th><th>Acciones</th></tr></thead><tbody id="addressBookList"><tr><td colspan="12">Seleccione una impresora para preparar la libreta de direcciones.</td></tr></tbody></table></div>
        </div>

        <div id="counters" class="tab"><h2 class="section-title">Contadores de impresión</h2>
            <div class="action-row" style="align-items:center; margin-bottom:8px; flex-wrap:wrap;"><button class="action-button" onclick="loadCounters()">Refrescar contadores</button><label style="display:inline-flex;align-items:center;gap:8px;margin-left:8px;color:#cbd5e6;font-size:13px"><input type="checkbox" id="countersAuto" onchange="toggleCountersAuto(this.checked)"> Auto <input id="countersAutoInterval" type="number" value="60" style="width:72px;margin-left:6px;padding:6px;border-radius:6px;background:#0f172a;border:1px solid #374151;color:#fff">s</label><button class="action-button action-button-success" type="button" onclick="generateCountersReport()">Generar reporte</button><button class="action-button action-button-secondary" type="button" onclick="exportCountersCSV()"><i class="bi bi-filetype-csv"></i> Exportar CSV</button><div style="margin-left:auto;display:flex;gap:8px;"><span class="badge" id="countersSummaryTotal" style="padding:6px 10px;font-size:12px">Impresoras: 0</span><span class="badge" id="countersLastUpdate" style="padding:6px 10px;font-size:12px">Última: -</span></div></div>
            <div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;align-items:center;"><input id="countersSearch" class="toolbar-input" type="text" placeholder="Buscar por nombre, IP o serie" style="max-width:280px;" oninput="loadCounters()"><select id="countersStatusFilter" class="toolbar-select" style="max-width:160px;" onchange="loadCounters()"><option value="all">Estado: Todas</option><option value="online">Online</option><option value="offline">Offline</option></select><select id="countersTypeFilter" class="toolbar-select" style="max-width:160px;" onchange="loadCounters()"><option value="all">Tipo: Todas</option><option value="color">Color</option><option value="mono">B/N</option></select><select id="countersIncompleteFilter" class="toolbar-select" style="max-width:180px;" onchange="loadCounters()"><option value="all">Datos: Todos</option><option value="true">Incompletos</option><option value="false">Completos</option></select></div>
            <div class="table-wrapper"><table class="counters-table"><thead><tr><th class="sortable-th" onclick="toggleCountersSort('name')">Impresora <span class="sort-ind" id="csort_name"></span></th><th class="sortable-th" onclick="toggleCountersSort('serial')">Serie <span class="sort-ind" id="csort_serial"></span></th><th class="sortable-th" onclick="toggleCountersSort('ip')">IP <span class="sort-ind" id="csort_ip"></span></th><th class="sortable-th" onclick="toggleCountersSort('total_pages')">Total páginas <span class="sort-ind" id="csort_total_pages"></span></th><th class="sortable-th" onclick="toggleCountersSort('copy_bw')">Copiado B/N <span class="sort-ind" id="csort_copy_bw"></span></th><th class="sortable-th" onclick="toggleCountersSort('copy_color')">Copiado Color <span class="sort-ind" id="csort_copy_color"></span></th><th class="sortable-th" onclick="toggleCountersSort('print_bw')">Impresión B/N <span class="sort-ind" id="csort_print_bw"></span></th><th class="sortable-th" onclick="toggleCountersSort('print_color')">Impresión Color <span class="sort-ind" id="csort_print_color"></span></th><th class="sortable-th" onclick="toggleCountersSort('bw_pages')">Blanco y negro <span class="sort-ind" id="csort_bw_pages"></span></th><th class="sortable-th" onclick="toggleCountersSort('color_pages')">Color <span class="sort-ind" id="csort_color_pages"></span></th></tr></thead><tbody id="countersList"><tr><td colspan="10">Cargando contadores...</td></tr></tbody><tfoot id="countersTfoot" style="display:none;"><tr style="font-weight:700;background:#111827;"><td>TOTALES</td><td></td><td></td><td id="countersTotalPages">-</td><td id="countersTotalCopyBW">-</td><td id="countersTotalCopyColor">-</td><td id="countersTotalPrintBW">-</td><td id="countersTotalPrintColor">-</td><td id="countersTotalBW">-</td><td id="countersTotalColor">-</td></tr></tfoot></table></div></div>
        <div id="inventory" class="tab">
            <h2 class="section-title"><i class="bi bi-boxes" style="margin-right:8px;color:#60a5fa"></i>Control de Inventario</h2>
            <div class="summary" style="margin-bottom:14px;">
                <div class="summary-card summary-card-total"><h3><i class="bi bi-box-seam" style="color:#60a5fa"></i>Total items</h3><div class="value" id="invTotalItems">0</div></div>
                <div class="summary-card summary-card-offline"><h3><i class="bi bi-exclamation-triangle" style="color:#f87171"></i>Stock bajo</h3><div class="value" id="invLowStock">0</div></div>
                <div class="summary-card summary-card-online"><h3><i class="bi bi-droplet-half" style="color:#34d399"></i>Toner</h3><div class="value" id="invTonerCount">0</div></div>
                <div class="summary-card summary-card-toner"><h3><i class="bi bi-disc" style="color:#a78bfa"></i>Drum / Fuser</h3><div class="value" id="invOtherCount">0</div></div>
            </div>
            <div class="inv-toolbar">
                <button class="filter-toggle-btn" type="button" onclick="toggleInventoryForm()" style="min-width:160px;"><span class="filter-toggle-icon" style="background:#16a34a;border-color:#22c55e;color:#fff"><i class="bi bi-plus-lg"></i></span><span>Agregar item</span></button>
                <button class="action-button action-button-secondary" type="button" onclick="loadInventory()" style="min-height:38px;padding:8px 14px;font-size:13px;"><i class="bi bi-arrow-clockwise"></i> Refrescar</button>
                <div class="inv-toolbar-sep"></div>
                <div class="inv-search-wrap">
                    <i class="bi bi-search inv-search-icon"></i>
                    <input id="invSearch" class="toolbar-input" type="text" placeholder="Buscar nombre, modelo o N° parte..." oninput="renderInventoryTable()">
                </div>
                <select id="invTypeFilter" class="toolbar-select" style="max-width:150px;" onchange="renderInventoryTable()"><option value="all">Tipo: Todos</option><option value="toner">Toner</option><option value="drum">Drum</option><option value="fuser">Fuser</option></select>
                <select id="invStockFilter" class="toolbar-select" style="max-width:160px;" onchange="renderInventoryTable()"><option value="all">Stock: Todos</option><option value="low">Stock bajo</option><option value="ok">Stock OK</option></select>
                <button class="toolbar-button" type="button" onclick="resetInventoryFilters()"><i class="bi bi-x-lg"></i> Limpiar</button>
            </div>
            <div class="table-wrapper"><table><thead><tr><th class="sortable-th" onclick="toggleInventorySort('id')">ID <span class="sort-ind" id="invsort_id"></span></th><th class="sortable-th" onclick="toggleInventorySort('name')">Nombre <span class="sort-ind" id="invsort_name"></span></th><th class="sortable-th" onclick="toggleInventorySort('model')">Modelo <span class="sort-ind" id="invsort_model"></span></th><th class="sortable-th" onclick="toggleInventorySort('type')">Tipo <span class="sort-ind" id="invsort_type"></span></th><th class="sortable-th" onclick="toggleInventorySort('part_number')">N° Parte <span class="sort-ind" id="invsort_part_number"></span></th><th class="sortable-th" onclick="toggleInventorySort('quantity')">Cantidad <span class="sort-ind" id="invsort_quantity"></span></th><th class="sortable-th" onclick="toggleInventorySort('min_stock')">Mínimo <span class="sort-ind" id="invsort_min_stock"></span></th><th class="sortable-th" onclick="toggleInventorySort('location')">Ubicación <span class="sort-ind" id="invsort_location"></span></th><th>Notas</th><th>Acciones</th></tr></thead><tbody id="inventoryList"><tr><td colspan="10">Cargando inventario...</td></tr></tbody></table></div>
        </div>
        <div id="tonerControl" class="tab">
