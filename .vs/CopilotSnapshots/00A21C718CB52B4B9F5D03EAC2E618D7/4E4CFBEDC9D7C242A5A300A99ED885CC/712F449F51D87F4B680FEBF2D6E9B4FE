async function saveTonerControl(){if(!currentTonerControlPrinterId)return;const payload={check_date:document.getElementById('tcDate').value||null,backup_black:parseFloat(document.getElementById('tcBackupK').value)||0,backup_cyan:parseFloat(document.getElementById('tcBackupC').value)||0,backup_magenta:parseFloat(document.getElementById('tcBackupM').value)||0,backup_yellow:parseFloat(document.getElementById('tcBackupY').value)||0,pedido:document.getElementById('tcPedido').value.trim()||'',work_order:document.getElementById('tcWO').value.trim()||'',notas:document.getElementById('tcNotas').value.trim()||''};try{const response=await fetch(`/toner-control/${currentTonerControlPrinterId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});if(!response.ok){const d=await response.json();throw new Error(d.detail||'Error');}closeTonerControlModal();showToast('Control de tóner actualizado','success');loadTonerControl();}catch(error){showToast(error.message||'Error actualizando control.','error');console.error(error);}}
function showToast(message,type,duration){type=type||'success';duration=duration||3000;const toast=document.getElementById('appToast');if(!toast)return;const icon=type==='success'?'<i class="bi bi-check-circle-fill" style="color:#22c55e;margin-right:8px"></i>':'<i class="bi bi-x-circle-fill" style="color:#ef4444;margin-right:8px"></i>';toast.innerHTML=icon+'<span>'+message+'</span>';toast.className='toast toast-'+type;void toast.offsetWidth;toast.classList.add('show');clearTimeout(toast._timer);toast._timer=setTimeout(()=>toast.classList.remove('show'),duration);}
function applyAddressBookChanges(){if(!currentAddressBookPrinter){showToast('No hay impresora seleccionada.','error');return;}showToast('Funcionalidad en desarrollo.','error');}
function closeAddressBookAuthModal(success){document.getElementById('addressBookAuthModal')?.classList.remove('open');if(success)loadAddressBookEntries();}
function confirmAddressBookAuthModal(){closeAddressBookAuthModal(true);}
document.addEventListener('click',function(e){const btn=e.target.closest('.action-button,.filter-toggle-btn,.toolbar-button');if(!btn)return;const rect=btn.getBoundingClientRect();const ripple=document.createElement('span');ripple.className='btn-ripple';const size=Math.max(rect.width,rect.height);ripple.style.width=ripple.style.height=size+'px';ripple.style.left=(e.clientX-rect.left-size/2)+'px';ripple.style.top=(e.clientY-rect.top-size/2)+'px';btn.appendChild(ripple);ripple.addEventListener('animationend',()=>ripple.remove());});
(function attachFilterListeners(){restoreDashboardFilters();const searchEl=document.getElementById('searchInput');if(searchEl)searchEl.addEventListener('input',()=>{loadPrinters();saveDashboardFilters();});['viewMode','densityMode','statusFilter','typeFilter','errorFilter','sortFilter'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('change',()=>{loadPrinters();saveDashboardFilters();});});const printerIpEl=document.getElementById('printerIp');if(printerIpEl){printerIpEl.addEventListener('input',()=>validatePrinterIpField());printerIpEl.addEventListener('blur',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});printerIpEl.addEventListener('change',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});}['discoverStartIp','discoverEndIp','discoverSingleIp'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',()=>validateDiscoverFields());});toggleDiscoverModeFields();document.addEventListener('keydown',function(e){if((e.ctrlKey||e.metaKey)&&e.key==='k'){e.preventDefault();const panel=document.getElementById('dashboardFilters');if(panel&&panel.classList.contains('closed'))toggleDashboardFilters();const s=document.getElementById('searchInput');if(s){s.focus();s.select();}return;}if(e.key==='Escape'){const modals=document.querySelectorAll('.modal-overlay.open');if(modals.length){const top=modals[modals.length-1];if(top.id==='appConfirmModal')resolveAppConfirm(false);else if(top.id==='addressBookFormModal')resolveAddressBookForm(null);else top.classList.remove('open');return;}const drawer=document.getElementById('drawerPanel');if(drawer&&drawer.classList.contains('open')){closeDrawer();return;}}});})();
showTab('dashboard');setDensityMode('standard');
updateDashboardSortIndicators();
