async function loadCounters(){const list=document.getElementById('countersList');const lastEl=document.getElementById('countersLastUpdate');const totalEl=document.getElementById('countersSummaryTotal');const tfoot=document.getElementById('countersTfoot');if(!list)return;try{showLoadingIn('countersList',10,'Actualizando contadores...');if(tfoot)tfoot.style.display='none';if(lastEl)lastEl.textContent='Actualizando...';const statusF=document.getElementById('countersStatusFilter')?.value||'all';const typeF=document.getElementById('countersTypeFilter')?.value||'all';const incompleteF=document.getElementById('countersIncompleteFilter')?.value||'all';const searchF=(document.getElementById('countersSearch')?.value||'').toLowerCase().trim();const params=new URLSearchParams();if(statusF!=='all')params.set('status',statusF);if(typeF!=='all')params.set('printer_type',typeF);if(incompleteF!=='all')params.set('incomplete',incompleteF);const qs=params.toString();const url='/printers/counters'+(qs?'?'+qs:'');const response=await fetch(url);let data=await response.json();if(!Array.isArray(data))data=[];if(searchF){data=data.filter(p=>((p.name||'')+' '+(p.ip||'')+' '+(p.serial||'')).toLowerCase().includes(searchF));}if(!data.length){list.innerHTML='<tr><td colspan="10">No hay datos.</td></tr>';if(lastEl)lastEl.textContent='Última: -';if(totalEl)totalEl.textContent='Impresoras: 0';return;}data.sort((a,b)=>{const col=countersSortColumn;if(['total_pages','copy_bw','copy_color','print_bw','print_color','bw_pages','color_pages'].includes(col)){return countersSortDirection==='asc'?(Number(a[col])||0)-(Number(b[col])||0):(Number(b[col])||0)-(Number(a[col])||0);}if(col==='ip'){return countersSortDirection==='asc'?ipToNumber(a.ip)-ipToNumber(b.ip):ipToNumber(b.ip)-ipToNumber(a.ip);}const av=((a[col]??'')+'').toLowerCase();const bv=((b[col]??'')+'').toLowerCase();const r=av.localeCompare(bv);return countersSortDirection==='desc'?-r:r;});countersRawData=[...data];const fmt=value=>{if(value===null||value===undefined||value===''||value==='-')return '-';const n=Number(value);return Number.isNaN(n)?value:n.toLocaleString('es-CR');};const totals={total_pages:0,copy_bw:0,copy_color:0,print_bw:0,print_color:0,bw_pages:0,color_pages:0};list.innerHTML='';data.forEach((p,index)=>{const displayName=p.name||'-';const incomplete=p.is_complete===false;const rowClass=incomplete?'row-low':'';['total_pages','copy_bw','copy_color','print_bw','print_color','bw_pages','color_pages'].forEach(k=>{totals[k]+=(Number(p[k])||0);});list.innerHTML+=`<tr class="${rowClass}"><td><span class="clickable-name" onclick="openCounterHistoryFromCounters(${index})">${displayName}</span></td><td>${p.serial??'-'}</td><td>${p.ip??'-'}</td><td>${fmt(p.total_pages)}</td><td>${fmt(p.copy_bw)}</td><td>${fmt(p.copy_color)}</td><td>${fmt(p.print_bw)}</td><td>${fmt(p.print_color)}</td><td>${fmt(p.bw_pages)}</td><td>${fmt(p.color_pages)}</td></tr>`;});if(tfoot){tfoot.style.display='';document.getElementById('countersTotalPages').textContent=fmt(totals.total_pages);document.getElementById('countersTotalCopyBW').textContent=fmt(totals.copy_bw);document.getElementById('countersTotalCopyColor').textContent=fmt(totals.copy_color);document.getElementById('countersTotalPrintBW').textContent=fmt(totals.print_bw);document.getElementById('countersTotalPrintColor').textContent=fmt(totals.print_color);document.getElementById('countersTotalBW').textContent=fmt(totals.bw_pages);document.getElementById('countersTotalColor').textContent=fmt(totals.color_pages);}updateCountersSortIndicators();if(lastEl)lastEl.textContent='Actualizado: '+new Date().toLocaleTimeString();if(totalEl)totalEl.textContent=`Impresoras: ${data.length}`;}catch(error){list.innerHTML='<tr><td colspan="10">No se pudieron cargar los contadores.</td></tr>';if(lastEl)lastEl.textContent='Error';if(totalEl)totalEl.textContent='Impresoras: 0';console.error('loadCounters error:',error);}}
