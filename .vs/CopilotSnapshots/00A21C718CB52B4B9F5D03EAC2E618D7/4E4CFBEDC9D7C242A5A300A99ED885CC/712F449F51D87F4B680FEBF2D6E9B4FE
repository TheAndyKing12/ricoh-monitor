let countersAutoTimer = null;
let countersSortColumn = 'name';
let countersSortDirection = 'asc';
let countersRawData = [];
let currentAddressBookPrinter = null;
let currentModalPrinter = null;
let currentTonerControlPrinterId = null;
let tonerControlRawData = [];
let tonerControlSortColumn = 'shared_name';
let tonerControlSortDirection = 'asc';
let _appConfirmResolve=null;
let _abFormResolve=null;
let _dashSearchTerm='';
let inventoryRawData=[];
let inventorySortColumn='id';
let inventorySortDirection='asc';

function highlightText(text,search){if(!search||!text)return text;const escaped=search.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');return String(text).replace(new RegExp('('+escaped+')','gi'),'<span class="search-highlight">$1</span>');}
function appConfirm(title,message){return new Promise(resolve=>{_appConfirmResolve=resolve;const modal=document.getElementById('appConfirmModal');const t=document.getElementById('appConfirmTitle');const m=document.getElementById('appConfirmMessage');if(t)t.textContent=title||'Confirmar';if(m)m.textContent=message||'¿Está seguro?';if(modal)modal.classList.add('open');});}
function resolveAppConfirm(value){document.getElementById('appConfirmModal')?.classList.remove('open');if(_appConfirmResolve){_appConfirmResolve(value);_appConfirmResolve=null;}}
function openAddressBookFormModal(entry){return new Promise(resolve=>{_abFormResolve=resolve;const isEdit=!!entry;const t=document.getElementById('abFormTitle');const s=document.getElementById('abFormSubtitle');if(t)t.textContent=isEdit?'Editar usuario':'Agregar usuario';if(s)s.textContent=currentAddressBookPrinter?(currentAddressBookPrinter.shared_name||currentAddressBookPrinter.name||''):'';document.getElementById('abFormName').value=entry?.name??'';document.getElementById('abFormKeyDisplay').value=entry?.key_display??'';document.getElementById('abFormFreq').value=(entry?.freq===false)?'no':'si';document.getElementById('abFormTitle1').value=entry?.title1??'';document.getElementById('abFormTitle2').value=entry?.title2??'';document.getElementById('abFormTitle3').value=entry?.title3??'';document.getElementById('abFormUserCode').value=entry?.user_code??'';document.getElementById('abFormEmail').value=entry?.email_address??'';document.getElementById('abFormFolder').value=entry?.folder??'';document.getElementById('abFormStatus').value=entry?.status??'Activo';document.getElementById('addressBookFormModal')?.classList.add('open');setTimeout(()=>document.getElementById('abFormName')?.focus(),120);});}
function submitAddressBookForm(){const name=(document.getElementById('abFormName')?.value||'').trim();if(!name){showToast('El nombre es obligatorio.','error');return;}const payload={name,key_display:normalizeAddressBookPromptValue(document.getElementById('abFormKeyDisplay')?.value),freq:document.getElementById('abFormFreq')?.value!=='no',title1:normalizeAddressBookPromptValue(document.getElementById('abFormTitle1')?.value),title2:normalizeAddressBookPromptValue(document.getElementById('abFormTitle2')?.value),title3:normalizeAddressBookPromptValue(document.getElementById('abFormTitle3')?.value),user_code:normalizeAddressBookPromptValue(document.getElementById('abFormUserCode')?.value),email_address:normalizeAddressBookPromptValue(document.getElementById('abFormEmail')?.value),folder:normalizeAddressBookPromptValue(document.getElementById('abFormFolder')?.value),status:normalizeAddressBookPromptValue(document.getElementById('abFormStatus')?.value)||'Activo'};document.getElementById('addressBookFormModal')?.classList.remove('open');if(_abFormResolve){_abFormResolve(payload);_abFormResolve=null;}}
function resolveAddressBookForm(value){document.getElementById('addressBookFormModal')?.classList.remove('open');if(_abFormResolve){_abFormResolve(value);_abFormResolve=null;}}
function saveDashboardFilters(){try{const state={search:document.getElementById('searchInput')?.value||'',viewMode:document.getElementById('viewMode')?.value||'table',statusFilter:document.getElementById('statusFilter')?.value||'all',typeFilter:document.getElementById('typeFilter')?.value||'all',errorFilter:document.getElementById('errorFilter')?.value||'all',sortFilter:document.getElementById('sortFilter')?.value||'relevance_desc',sortColumn:dashboardSortColumn,sortDirection:dashboardSortDirection};localStorage.setItem('ricoh_dash_filters',JSON.stringify(state));}catch(e){}}
function restoreDashboardFilters(){try{const raw=localStorage.getItem('ricoh_dash_filters');if(!raw)return;const s=JSON.parse(raw);if(s.search)document.getElementById('searchInput').value=s.search;if(s.viewMode)document.getElementById('viewMode').value=s.viewMode;if(s.statusFilter)document.getElementById('statusFilter').value=s.statusFilter;if(s.typeFilter)document.getElementById('typeFilter').value=s.typeFilter;if(s.errorFilter)document.getElementById('errorFilter').value=s.errorFilter;if(s.sortFilter)document.getElementById('sortFilter').value=s.sortFilter;if(s.sortColumn)dashboardSortColumn=s.sortColumn;if(s.sortDirection)dashboardSortDirection=s.sortDirection;}catch(e){}}

function showLoadingIn(tbodyId,colspan,msg){const el=document.getElementById(tbodyId);if(el)el.innerHTML='<tr><td colspan="'+colspan+'"><div class="loading-spinner-wrap"><div class="loading-spinner"></div><div class="loading-spinner-text">'+(msg||'Cargando...')+'</div></div></td></tr>';}

function animateCountUp(el,target){if(!el)return;const current=parseInt(el.textContent,10)||0;if(current===target){el.textContent=String(target);return;}const diff=target-current;const duration=320;const start=performance.now();const step=now=>{const elapsed=Math.min(now-start,duration);const progress=elapsed/duration;const eased=1-Math.pow(1-progress,3);el.textContent=String(Math.round(current+diff*eased));if(elapsed<duration)requestAnimationFrame(step);else el.textContent=String(target);};requestAnimationFrame(step);}

