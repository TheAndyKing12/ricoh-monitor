async function createAddressBookEntry(){if(!currentAddressBookPrinter){showAddressBookPendingMessage();return;}const name=prompt('Nombre del usuario:');if(name===null)return;const payload={name:name.trim(),key_display:normalizeAddressBookPromptValue(prompt('Key Display:',name.trim())),freq:(prompt('Frecuente? (si/no):','si')||'si').trim().toLowerCase()!=='no',title1:normalizeAddressBookPromptValue(prompt('Title 1:','')),title2:normalizeAddressBookPromptValue(prompt('Title 2:','')),title3:normalizeAddressBookPromptValue(prompt('Title 3:','')),user_code:normalizeAddressBookPromptValue(prompt('User Code:','')),email_address:normalizeAddressBookPromptValue(prompt('E-mail Address:','')),folder:normalizeAddressBookPromptValue(prompt('Folder:','')),status:normalizeAddressBookPromptValue(prompt('Status:','Activo'))||'Activo'};if(!payload.name){alert('El nombre es obligatorio.');return;}try{const response=await fetch(`/printers/${currentAddressBookPrinter.id}/address-book?storage_mode=${encodeURIComponent(ADDRESS_BOOK_FORCED_MODE)}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const data=await response.json();if(!response.ok)throw new Error(data.detail||'No se pudo agregar el usuario');await loadAddressBookEntries();}catch(error){alert(error.message||'No se pudo agregar el usuario.');console.error(error);}
