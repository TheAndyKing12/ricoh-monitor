async function editAddressBookEntry(entry){if(!currentAddressBookPrinter||!entry)return;const name=prompt('Nombre del usuario:',entry.name??'');if(name===null)return;const payload={name:name.trim(),key_display:normalizeAddressBookPromptValue(prompt('Key Display:',entry.key_display??'')),freq:(prompt('Frecuente? (si/no):',entry.freq?'si':'no')||(entry.freq?'si':'no')).trim().toLowerCase()!=='no',title1:normalizeAddressBookPromptValue(prompt('Title 1:',entry.title1??'')),title2:normalizeAddressBookPromptValue(prompt('Title 2:',entry.title2??'')),title3:normalizeAddressBookPromptValue(prompt('Title 3:',entry.title3??'')),user_code:normalizeAddressBookPromptValue(prompt('User Code:',entry.user_code??'')),email_address:normalizeAddressBookPromptValue(prompt('E-mail Address:',entry.email_address??'')),folder:normalizeAddressBookPromptValue(prompt('Folder:',entry.folder??'')),status:normalizeAddressBookPromptValue(prompt('Status:',entry.status??'Activo'))||'Activo'};if(!payload.name){alert('El nombre es obligatorio.');return;}try{const response=await fetch(`/printers/${currentAddressBookPrinter.id}/address-book/${encodeURIComponent(entry.registration_no)}?storage_mode=${encodeURIComponent(ADDRESS_BOOK_FORCED_MODE)}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const data=await response.json();if(!response.ok)throw new Error(data.detail||'No se pudo actualizar el usuario');await loadAddressBookEntries();}catch(error){alert(error.message||'No se pudo actualizar el usuario.');console.error(error);}
