<script>
let dashboardRawData = [];
let dashboardSortColumn = 'shared_name';
let dashboardSortDirection = 'asc';
let printersFetchController = null;
let printersPollInterval = null;
const PRINTERS_POLL_MS = 30000;
let discoveredPrintersCache = [];
let hostnameLookupController = null;
let savedPrintersSortColumn = 'id';
let savedPrintersSortDirection = 'asc';
let countersAutoTimer = null;
let currentAddressBookPrinter = null;
const ADDRESS_BOOK_FORCED_MODE = 'ricoh-real';
let searchDebounceTimer = null;
let lastRefreshTimeStr = '';
let nextRefreshAt = 0;
let refreshCountdownTimer = null;

function showTab(tabName){document.querySelectorAll('.tab').forEach(tab=>tab.classList.remove('active'));const selected=document.getElementById(tabName);if(selected)selected.classList.add('active');document.querySelectorAll('.menu-button').forEach(btn=>btn.classList.remove('active'));const activeBtn=document.querySelector(`.menu-button[onclick*="'${tabName}'"]`);if(activeBtn)activeBtn.classList.add('active');if(tabName==='dashboard'){startPrintersPolling();loadPrinters();}else{stopPrintersPolling();}if(tabName==='printers')loadSavedPrinters();if(tabName==='counters')loadCounters();if(tabName==='inventory')loadInventory();if(tabName==='tonerControl')loadTonerControl();}
function togglePrinterSection(sectionId){['manualPrinterCard','discoverPrinterCard'].forEach(id=>{const el=document.getElementById(id);if(!el)return;if(id===sectionId)el.classList.toggle('is-open');else el.classList.remove('is-open');});}
function toggleDashboardFilters(){const panel=document.getElementById('dashboardFilters');const icon=document.getElementById('filterToggleIcon');const state=document.getElementById('filterToggleState');const btn=document.getElementById('dashboardFilterBtn');const closed=panel.classList.toggle('closed');if(btn)btn.classList.toggle('is-open',!closed);if(icon)icon.textContent=closed?'▾':'▴';if(state)state.textContent=closed?'Ocultos':'Visibles';}
function toggleDashboardFullscreen(){const root=document.documentElement;const sidebar=document.querySelector('.sidebar');const btnLabel=document.getElementById('fullscreenBtnLabel');const btnIcon=document.getElementById('fullscreenBtnIcon');const viewMode=document.getElementById('viewMode');const setUi=isFs=>{document.body.classList.toggle('fullscreen',isFs);if(sidebar)sidebar.style.display=isFs?'none':'';if(viewMode&&isFs)viewMode.value='table';if(btnLabel)btnLabel.textContent=isFs?'Salir pantalla':'Pantalla completa';if(btnIcon)btnIcon.textContent=isFs?'🗗':'⛶';if(isFs)loadPrinters();setTimeout(()=>{setTableFullHeight();},80);};if(document.fullscreenElement){document.exitFullscreen().then(()=>setUi(false)).catch(err=>console.error('No se pudo salir de pantalla completa:',err));return;}root.requestFullscreen().then(()=>setUi(true)).catch(err=>console.error('No se pudo activar pantalla completa:',err));}
document.addEventListener('fullscreenchange',()=>{const isFs=!!document.fullscreenElement;const sidebar=document.querySelector('.sidebar');const btnLabel=document.getElementById('fullscreenBtnLabel');const btnIcon=document.getElementById('fullscreenBtnIcon');const viewMode=document.getElementById('viewMode');document.body.classList.toggle('fullscreen',isFs);if(sidebar)sidebar.style.display=isFs?'none':'';if(viewMode&&isFs)viewMode.value='table';if(btnLabel)btnLabel.textContent=isFs?'Salir pantalla':'Pantalla completa';if(btnIcon)btnIcon.textContent=isFs?'🗗':'⛶';setTimeout(()=>{
setTableFullHeight();if(isFs)loadPrinters();},80);});
function isValidIpv4(ip){return /^(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)(\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)){3}$/.test((ip||'').trim());}
function setFieldValidation(inputId,helpId,message='',state=''){const input=document.getElementById(inputId);const help=document.getElementById(helpId);if(!input)return;input.classList.remove('input-valid','input-invalid');if(state==='valid')input.classList.add('input-valid');if(state==='invalid')input.classList.add('input-invalid');if(help){help.textContent=message;help.className=`field-help${state==='invalid'?' error':state==='valid'?' success':''}`;}}
function validatePrinterIpField(){const ip=document.getElementById('printerIp')?.value.trim()||'';if(!ip){setFieldValidation('printerIp','printerIpHelp','');return false;}if(!isValidIpv4(ip)){setFieldValidation('printerIp','printerIpHelp','IP inválida','invalid');return false;}setFieldValidation('printerIp','printerIpHelp','IP válida','valid');return true;}
function toggleDiscoverModeFields(){const mode=document.getElementById('discoverMode')?.value||'range';const startWrap=document.getElementById('discoverStartWrap');const endWrap=document.getElementById('discoverEndWrap');const singleWrap=document.getElementById('discoverSingleWrap');if(startWrap)startWrap.style.display=mode==='range'?'':'none';if(endWrap)endWrap.style.display=mode==='range'?'':'none';if(singleWrap)singleWrap.style.display=mode==='ip'?'':'none';}
function validateDiscoverFields(){const mode=document.getElementById('discoverMode')?.value||'range';const startIp=document.getElementById('discoverStartIp')?.value.trim()||'';const endIp=document.getElementById('discoverEndIp')?.value.trim()||'';const singleIp=document.getElementById('discoverSingleIp')?.value.trim()||'';let valid=true;if(mode==='range'){if(!startIp||!isValidIpv4(startIp)){setFieldValidation('discoverStartIp','discoverStartIpHelp','IP inicial inválida','invalid');valid=false;}else setFieldValidation('discoverStartIp','discoverStartIpHelp','OK','valid');if(!endIp||!isValidIpv4(endIp)){setFieldValidation('discoverEndIp','discoverEndIpHelp','IP final inválida','invalid');valid=false;}else setFieldValidation('discoverEndIp','discoverEndIpHelp','OK','valid');}else{setFieldValidation('discoverStartIp','discoverStartIpHelp','');setFieldValidation('discoverEndIp','discoverEndIpHelp','');if(!singleIp||!isValidIpv4(singleIp)){setFieldValidation('discoverSingleIp','discoverSingleIpHelp','IP inválida','invalid');valid=false;}else setFieldValidation('discoverSingleIp','discoverSingleIpHelp','OK','valid');}return valid;}
async function autofillPrinterNameFromIp(){const ipEl=document.getElementById('printerIp');const nameEl=document.getElementById('printerName');const communityEl=document.getElementById('printerCommunity');if(!ipEl||!nameEl)return;const ip=ipEl.value.trim();const community=(communityEl?.value||'public').trim()||'public';if(!isValidIpv4(ip))return;if(hostnameLookupController){try{hostnameLookupController.abort();}catch(e){}}hostnameLookupController=new AbortController();try{const response=await fetch(`/printers/resolve-hostname?ip=${encodeURIComponent(ip)}&community=${encodeURIComponent(community)}`,{signal:hostnameLookupController.signal});const data=await response.json();if(data?.hostname&&!nameEl.value.trim()){nameEl.value=data.hostname;nameEl.dataset.autoFilled='true';}}catch(error){if(error.name!=='AbortError')console.warn('No se pudo resolver el hostname.',error);}finally{hostnameLookupController=null;}}
function safeValue(value){if(value===null||value===undefined||value==='')return null;const n=Number(value);return Number.isNaN(n)?null:n;}
function tonerAlertText(value){if(value===null)return '';if(value<10)return '<div class="critical-text">Crítico: tóner muy bajo</div>';if(value<30)return '<div class="warning-text">Advertencia: tóner bajo</div>';return '';}
function renderTonerBar(label,value,cssClass){const numeric=safeValue(value);const display=numeric===null?'-':`${numeric}%`;const width=numeric===null?0:Math.max(0,Math.min(100,numeric));return `<div class="toner-item"><div class="toner-label-row"><span>${label}</span><span>${display}</span></div><div class="bar"><div class="bar-fill ${cssClass}" style="width:${width}%"></div></div>${label==='Black'?tonerAlertText(numeric):''}</div>`;}
function renderTonerMini(label,value,cssClass){const numeric=safeValue(value);if(numeric===null)return `<span class="tc-muted">-</span>`;const width=Math.max(0,Math.min(100,numeric));return `<div class="toner-mini" title="${label}: ${numeric}%"><div class="mini-bar"><div class="fill ${cssClass}" style="width:${width}%"></div></div><span class="mini-label">${numeric}%</span></div>`;}
function normalizeErrorType(errorText){const text=(errorText||'Sin error').toLowerCase();if(!text||text==='sin error')return 'ok';if(text.includes('crítico')||text.includes('critical'))return 'critical';if(text.includes('low toner')||text.includes('tóner bajo'))return 'low';return 'other';}
function getErrorClass(errorText,status){if((status||'').toLowerCase()!=='online')return 'error-critical';const type=normalizeErrorType(errorText);if(type==='critical')return 'error-critical';if(type==='low')return 'error-warn';if(type==='other')return 'error-critical';return 'error-ok';}
function buildCard(printer){const status=(printer.status||'offline').toLowerCase();const statusClass=status==='online'?'status-online':'status-offline';const shared=printer.shared_name||'Sin shared name';const nameLine=printer.name?`<div class="printer-secondary">${printer.name}</div>`:'';let tonerHtml=renderTonerBar('Black',printer.toner_black,'bar-black');if(printer.is_color){tonerHtml+=renderTonerBar('Cyan',printer.toner_cyan,'bar-cyan');tonerHtml+=renderTonerBar('Magenta',printer.toner_magenta,'bar-magenta');tonerHtml+=renderTonerBar('Yellow',printer.toner_yellow,'bar-yellow');}return `<div class="card"><div class="card-header"><div><div class="printer-name clickable-name" onclick="openPrinterModal(${printer.id})">${shared}</div>${nameLine}<div class="printer-model">${printer.model??'-'}</div></div><div class="status-pill ${statusClass}">${status==='online'?'ONLINE':'OFFLINE'}</div></div><div class="info-row"><strong>Serie:</strong> ${printer.serial??'-'}</div><div class="info-row"><strong>IP:</strong> ${printer.ip??'-'}</div><div class="info-row"><strong>Ubicación:</strong> ${printer.location??'-'}</div><div class="info-row"><strong>Error:</strong> <span class="${getErrorClass(printer.error_message,printer.status)}">${printer.error_message??'Sin error'}</span></div><div class="info-row"><strong>Tipo:</strong> ${printer.is_color?'Color':'Blanco y negro'}</div><div class="toner-section"><div class="toner-title">Consumibles</div>${tonerHtml}</div></div>`;}
function buildDashboardTableRow(printer){const status=(printer.status||'offline').toLowerCase();const statusHtml=status==='online'?`<span class="status-badge status-badge-online">Online</span>`:`<span class="status-badge status-badge-offline">Offline</span>`;const errorClass=getErrorClass(printer.error_message,printer.status);const errorText=printer.error_message||'Sin error';const normalized=normalizeErrorType(printer.error_message);let rowClass='';if(status!=='online')rowClass='row-error';else if(normalized==='critical')rowClass='row-error';else if(normalized==='low')rowClass='row-low';const tonerPieces=[renderTonerMini('K',printer.toner_black,'bar-black')];if(printer.is_color){tonerPieces.push(renderTonerMini('C',printer.toner_cyan,'bar-cyan'));tonerPieces.push(renderTonerMini('M',printer.toner_magenta,'bar-magenta'));tonerPieces.push(renderTonerMini('Y',printer.toner_yellow,'bar-yellow'));}return `<tr class="${rowClass}"><td><span class="clickable-name" onclick="openPrinterModal(${printer.id})">${printer.shared_name??'-'}</span></td><td>${printer.name??'-'}</td><td>${printer.model??'-'}</td><td>${printer.serial??'-'}</td><td>${printer.ip??'-'}</td><td>${printer.location??'-'}</td><td>${statusHtml}</td><td class="${errorClass}">${errorText}</td><td><div class="toner-inline">${tonerPieces.join('')}</div></td></tr>`;}
function compareDashboardValues(a,b,column){const av=((a[column]??'')+'').toLowerCase().trim();const bv=((b[column]??'')+'').toLowerCase().trim();if(column==='ip'){const aip=av.split('.').map(x=>parseInt(x||'0',10));const bip=bv.split('.').map(x=>parseInt(x||'0',10));for(let i=0;i<4;i++){if((aip[i]||0)<(bip[i]||0))return -1;if((aip[i]||0)>(bip[i]||0))return 1;}return 0;}return av.localeCompare(bv);}
function sortDashboardTableColumns(data){const sorted=[...data];sorted.sort((a,b)=>{let result=compareDashboardValues(a,b,dashboardSortColumn);if(dashboardSortDirection==='desc')result*=-1;return result;});return sorted;}
function toggleTableSort(column){if(dashboardSortColumn===column){dashboardSortDirection=dashboardSortDirection==='asc'?'desc':'asc';}else{dashboardSortColumn=column;dashboardSortDirection='asc';}renderDashboardWithFilters();updateTableSortIndicators();}
function updateTableSortIndicators(){const cols=['shared_name','name','model','serial','ip','location','status','error_message'];cols.forEach(col=>{const el=document.getElementById('dsort_'+col);if(!el)return;if(col===dashboardSortColumn){el.textContent=dashboardSortDirection==='asc'?'▲':'▼';el.classList.add('active');}else{el.textContent='↕';el.classList.remove('active');}});}
function renderDashboardWithFilters(){const viewMode=(document.getElementById('viewMode')?.value||'table');const search=(document.getElementById('searchInput')?.value||'').toLowerCase().trim();const statusF=document.getElementById('statusFilter')?.value||'all';const typeF=document.getElementById('typeFilter')?.value||'all';const errorF=document.getElementById('errorFilter')?.value||'all';const sortF=document.getElementById('sortFilter')?.value||'relevance_desc';let data=dashboardRawData.filter(p=>{if(statusF!=='all'){const s=(p.status||'').toLowerCase();if(statusF==='online'&&s!=='online')return false;if(statusF==='offline'&&s==='online')return false;}if(typeF!=='all'){if(typeF==='color'&&!p.is_color)return false;if(typeF==='mono'&&p.is_color)return false;}if(errorF!=='all'){const t=normalizeErrorType(p.error_message);if(errorF!==t)return false;}if(search){const hay=[p.shared_name,p.name,p.ip,p.model,p.serial].map(v=>(v||'').toLowerCase()).join(' ');if(!hay.includes(search))return false;}return true;});const total=dashboardRawData.length;const online=dashboardRawData.filter(p=>(p.status||'').toLowerCase()==='online').length;const lowToner=dashboardRawData.filter(p=>{const b=safeValue(p.toner_black);return b!==null&&b<30;}).length;const elTotal=document.getElementById('totalPrinters');const elOnline=document.getElementById('onlinePrinters');const elOffline=document.getElementById('offlinePrinters');const elLow=document.getElementById('lowTonerPrinters');if(elTotal)elTotal.textContent=total;if(elOnline)elOnline.textContent=online;if(elOffline)elOffline.textContent=total-online;if(elLow)elLow.textContent=lowToner;const cardsView=document.getElementById('dashboardCardsView');const tableView=document.getElementById('dashboardTableView');if(viewMode==='table'){if(cardsView)cardsView.style.display='none';if(tableView)tableView.style.display='';const sorted=sortDashboardTableColumns(data);const tbody=document.getElementById('dashboardTableBody');if(tbody){tbody.innerHTML=sorted.length?sorted.map(buildDashboardTableRow).join(''):'<tr><td colspan="9">Sin resultados.</td></tr>';}setTableFullHeight();}else{if(tableView)tableView.style.display='none';if(cardsView)cardsView.style.display='';const sorted=sortDashboardData(data,sortF);const grid=document.getElementById('printersGrid');if(grid){grid.innerHTML=sorted.length?sorted.map(buildCard).join(''):'<p style="padding:16px;color:#94a3b8">Sin resultados.</p>';}}}
function sortDashboardData(data,sortValue){const sorted=[...data];sorted.sort((a,b)=>{const sharedA=(a.shared_name||'').toLowerCase();const sharedB=(b.shared_name||'').toLowerCase();const nameA=(a.name||'').toLowerCase();const nameB=(b.name||'').toLowerCase();const modelA=(a.model||'').toLowerCase();const modelB=(b.model||'').toLowerCase();if(sortValue==='relevance_desc')return getDashboardRelevance(b)-getDashboardRelevance(a);if(sortValue==='relevance_asc')return getDashboardRelevance(a)-getDashboardRelevance(b);if(sortValue==='shared_name_asc')return sharedA.localeCompare(sharedB);if(sortValue==='shared_name_desc')return sharedB.localeCompare(sharedA);if(sortValue==='name_asc')return nameA.localeCompare(nameB);if(sortValue==='name_desc')return nameB.localeCompare(nameA);if(sortValue==='model_asc')return modelA.localeCompare(modelB);if(sortValue==='model_desc')return modelB.localeCompare(modelA);if(sortValue==='ip_asc')return ipToNumber(a.ip)-ipToNumber(b.ip);if(sortValue==='ip_desc')return ipToNumber(b.ip)-ipToNumber(a.ip);return 0;});return sorted;}
async function loadPrinters(){try{if(printersFetchController){try{printersFetchController.abort();}catch(e){}}printersFetchController=new AbortController();const lastUpdateEl=document.getElementById('lastUpdate');if(lastUpdateEl)lastUpdateEl.textContent='Actualizando...';const response=await fetch('/printers/status',{signal:printersFetchController.signal});const json=await response.json();dashboardRawData=Array.isArray(json)?json:[];renderDashboardWithFilters();updateTableSortIndicators();updateSidebarBadges();lastRefreshTimeStr='Actualizado: '+new Date().toLocaleTimeString();const lu=document.getElementById('lastUpdate');if(lu)lu.textContent=lastRefreshTimeStr;startRefreshCountdown();}catch(error){if(error.name!=='AbortError')console.error('loadPrinters error:',error);}finally{printersFetchController=null;}}
function updateSidebarBadges(){const offline=dashboardRawData.filter(p=>(p.status||'').toLowerCase()!=='online').length;const critical=dashboardRawData.filter(p=>{const b=safeValue(p.toner_black);return b!==null&&b<10;}).length;const bo=document.getElementById('badge_offline');const bt=document.getElementById('badge_toner');if(bo){bo.textContent=offline>99?'99+':offline;bo.style.display=offline>0?'flex':'none';}if(bt){bt.textContent=critical>99?'99+':critical;bt.style.display=critical>0?'flex':'none';}}
function startRefreshCountdown(){if(refreshCountdownTimer){clearInterval(refreshCountdownTimer);refreshCountdownTimer=null;}nextRefreshAt=Date.now()+PRINTERS_POLL_MS;const lu=document.getElementById('lastUpdate');if(lu){refreshCountdownTimer=setInterval(()=>{const diff=Math.max(0,Math.round((nextRefreshAt-Date.now())/1000));lu.textContent=lastRefreshTimeStr+(diff>0?`  ·  ↻ en ${diff}s`:'  ·  ↻ actualizando...');},1000);}}
function stopPrintersPolling(){if(printersPollInterval){clearInterval(printersPollInterval);printersPollInterval=null;}if(refreshCountdownTimer){clearInterval(refreshCountdownTimer);refreshCountdownTimer=null;}if(printersFetchController){try{printersFetchController.abort();}catch(e){}printersFetchController=null;}}
function startPrintersPolling(){if(printersPollInterval)return;printersPollInterval=setInterval(loadPrinters,PRINTERS_POLL_MS);}
function resetFilters(){document.getElementById('searchInput').value='';document.getElementById('statusFilter').value='all';document.getElementById('typeFilter').value='all';document.getElementById('errorFilter').value='all';document.getElementById('sortFilter').value='relevance_desc';document.getElementById('viewMode').value='table';saveDashboardPrefs();renderDashboardWithFilters();}
