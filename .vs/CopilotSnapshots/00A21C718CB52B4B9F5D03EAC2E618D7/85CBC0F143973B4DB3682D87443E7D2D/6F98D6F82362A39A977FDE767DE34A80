async function savePrinter(){const editingId=document.getElementById('editingPrinterId').value.trim();const payload={shared_name:document.getElementById('printerSharedName').value.trim()||null,name:document.getElementById('printerName').value.trim()||null,model:document.getElementById('printerModel').value.trim(),ip:document.getElementById('printerIp').value.trim(),serial:document.getElementById('printerSerial').value.trim()||null,location:document.getElementById('printerLocation').value.trim()||null,is_color:document.getElementById('printerIsColor').value==='true',snmp_community:document.getElementById('printerCommunity').value.trim()||'public'};if(!validatePrinterIpField()){alert('La IP no es válida.');return;}if(!payload.ip||!payload.model){alert('IP y modelo son obligatorios.');return;}try{let response;if(editingId){response=await fetch(`/printers/${editingId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});}else{response=await fetch('/printers/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});}const result=await response.json();if(!response.ok)throw new Error(result.detail||'Error guardando impresora');alert(editingId?'Impresora actualizada correctamente.':'Impresora agregada correctamente.');setFieldValidation('printerIp','printerIpHelp','');resetPrinterForm();loadSavedPrinters();loadPrinters();}catch(error){alert(error.message||'No se pudo guardar la impresora.');console.error(error);}}

async function loadSavedPrinters(){try{const response=await fetch('/printers/');let data=await response.json();const list=document.getElementById('savedPrintersList');list.innerHTML='';if(!Array.isArray(data)||!data.length){list.innerHTML='<tr><td colspan="8">No hay impresoras guardadas.</td></tr>';return;}data.sort((a,b)=>{let result=compareSavedPrinterValues(a,b,savedPrintersSortColumn);if(savedPrintersSortDirection==='desc')result*=-1;return result;});data.forEach(printer=>{const printerJson=JSON.stringify(printer).replace(/'/g,'&apos;');list.innerHTML+=`<tr><td>${printer.id}</td><td>${printer.shared_name??'-'}</td><td>${printer.name??'-'}</td><td>${printer.ip??'-'}</td><td>${printer.model??'-'}</td><td>${printer.serial??'-'}</td><td>${printer.is_color?'Color':'Blanco y negro'}</td><td><div class="action-row" style="margin-bottom:0;"><button class="action-button" onclick='editPrinter(${printerJson})'>Editable</button><button class="action-button action-button-warning" onclick='openAddressBook(${printerJson})'>Libreta de direcciones</button><button class="action-button action-button-danger" onclick="deletePrinter(${printer.id})">Eliminar</button></div></td></tr>`;});updateSavedPrintersSortIndicators();}catch(error){console.error('loadSavedPrinters error:',error);document.getElementById('savedPrintersList').innerHTML='<tr><td colspan="8">No se pudieron cargar las impresoras guardadas.</td></tr>';}}

function getSavedPrintersSortIndicator(column){if(savedPrintersSortColumn!==column)return'↕';return savedPrintersSortDirection==='asc'?'▲':'▼';}
function updateSavedPrintersSortIndicators(){['id','shared_name','name','ip'].forEach(column=>{const indicator=document.getElementById(`savedPrintersSort_${column}`);if(indicator)indicator.textContent=getSavedPrintersSortIndicator(column);});}
function compareSavedPrinterValues(a,b,column){const av=((a[column]??'')+'').toLowerCase().trim();const bv=((b[column]??'')+'').toLowerCase().trim();if(column==='id')return Number(a.id||0)-Number(b.id||0);if(column==='ip'){const aip=av.split('.').map(x=>parseInt(x||'0',10));const bip=bv.split('.').map(x=>parseInt(x||'0',10));for(let i=0;i<4;i++){if((aip[i]||0)<(bip[i]||0))return -1;if((aip[i]||0)>(bip[i]||0))return 1;}return 0;}return av.localeCompare(bv);}
function toggleSavedPrintersSort(column){if(savedPrintersSortColumn===column){savedPrintersSortDirection=savedPrintersSortDirection==='asc'?'desc':'asc';}else{savedPrintersSortColumn=column;savedPrintersSortDirection='asc';}loadSavedPrinters();}

async function deletePrinter(printerId){if(!confirm(`¿Eliminar la impresora con ID ${printerId}?`))return;try{const response=await fetch(`/printers/${printerId}`,{method:'DELETE'});if(!response.ok)throw new Error('No se pudo eliminar');loadSavedPrinters();loadPrinters();}catch(error){alert('No se pudo eliminar la impresora.');console.error(error);}}

function openAddressBook(printer){currentAddressBookPrinter=printer||null;const title=document.getElementById('addressBookPrinterTitle');const meta=document.getElementById('addressBookPrinterMeta');const status=document.getElementById('addressBookStatus');const displayName=printer?.shared_name||printer?.name||printer?.model||'Impresora';if(title)title.textContent=`Libreta de direcciones - ${displayName}`;if(meta)meta.textContent=`IP: ${printer?.ip??'-'} | Modelo: ${printer?.model??'-'} | Serie: ${printer?.serial??'-'}`;if(status)status.textContent='Cargando libreta de direcciones local segura.';showTab('addressBook');loadAddressBookEntries();}
function showAddressBookPendingMessage(){const status=document.getElementById('addressBookStatus');if(status)status.textContent=currentAddressBookPrinter?`Pendiente conectar la libreta real de ${currentAddressBookPrinter.ip}. Actualmente está usando almacenamiento local seguro.`:'Abra primero una impresora desde el botón amarillo de la tabla.';}
async function loadAddressBookEntries(){const list=document.getElementById('addressBookList');const status=document.getElementById('addressBookStatus');if(!currentAddressBookPrinter){if(list)list.innerHTML='<tr><td colspan="12">Seleccione una impresora.</td></tr>';showAddressBookPendingMessage();return;}try{if(list)list.innerHTML='<tr><td colspan="12">Cargando libreta de direcciones...</td></tr>';const response=await fetch(`/printers/${currentAddressBookPrinter.id}/address-book?storage_mode=${encodeURIComponent(ADDRESS_BOOK_FORCED_MODE)}`);const data=await response.json();if(!response.ok)throw new Error(data.detail||'No se pudo cargar la libreta');const entries=Array.isArray(data.entries)?data.entries:[];if(status)status.textContent=`Modo: ${data.storage_mode||'local-safe'} | Registros: ${entries.length}`;if(!entries.length){list.innerHTML='<tr><td colspan="12">No hay usuarios registrados.</td></tr>';return;}list.innerHTML='';entries.forEach(entry=>{const entryJson=JSON.stringify(entry).replace(/'/g,'&apos;');list.innerHTML+=`<tr><td>${entry.registration_no??'-'}</td><td>${entry.name??'-'}</td><td>${entry.key_display??'-'}</td><td>${entry.freq?'Sí':'No'}</td><td>${entry.title1??'-'}</td><td>${entry.title2??'-'}</td><td>${entry.title3??'-'}</td><td>${entry.user_code??'-'}</td><td>${entry.email_address??'-'}</td><td>${entry.folder??'-'}</td><td>${entry.status??'-'}</td><td><div class="action-row" style="margin-bottom:0;"><button class="action-button" onclick='editAddressBookEntry(${entryJson})'>Editar</button><button class="action-button action-button-danger" onclick="deleteAddressBookEntry('${entry.registration_no}')">Eliminar</button></div></td></tr>`;});}catch(error){if(list)list.innerHTML='<tr><td colspan="12">No se pudo cargar la libreta de direcciones.</td></tr>';if(status)status.textContent=error.message||'Error cargando libreta';console.error(error);}
}
