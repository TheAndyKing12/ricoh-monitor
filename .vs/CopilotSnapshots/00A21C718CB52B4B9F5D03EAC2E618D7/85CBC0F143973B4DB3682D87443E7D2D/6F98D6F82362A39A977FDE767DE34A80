async function discoverPrinters(){try{const mode=document.getElementById('discoverMode')?.value||'range';const startIp=document.getElementById('discoverStartIp')?.value.trim()||'';const endIp=document.getElementById('discoverEndIp')?.value.trim()||'';const singleIp=document.getElementById('discoverSingleIp')?.value.trim()||'';const community=document.getElementById('discoverCommunity')?.value.trim()||'public';const params=new URLSearchParams({mode,community});if(!validateDiscoverFields())return;if(mode==='range'){params.set('start_ip',startIp);params.set('end_ip',endIp);}else{params.set('ip',singleIp);}const response=await fetch(`/printers/discover?${params.toString()}`);const data=await response.json();const list=document.getElementById('printersList');const selectAll=document.getElementById('selectAllDiscovered');list.innerHTML='';discoveredPrintersCache=Array.isArray(data)?data:[];if(selectAll)selectAll.checked=false;if(!Array.isArray(data)||!data.length){list.innerHTML='<tr><td colspan="7">No se encontraron impresoras.</td></tr>';return;}data.forEach((printer,index)=>{list.innerHTML+=`<tr><td class="discover-select-col"><input id="discoverSelect_${index}" class="discover-checkbox" type="checkbox" checked></td><td>${printer.shared_name??'-'}</td><td>${printer.name??'-'}</td><td>${printer.ip??'-'}</td><td>${printer.model??'-'}</td><td>${printer.serial??'-'}</td><td>${printer.is_color?'Color':'Blanco y negro'}</td></tr>`;});}catch(error){console.error('discoverPrinters error:',error);document.getElementById('printersList').innerHTML='<tr><td colspan="7">No se pudo descubrir impresoras.</td></tr>';}}

async function importPrinters(){try{const selectedPrinters=getSelectedDiscoveredPrinters();if(!selectedPrinters.length){alert('Seleccione al menos una impresora para importar.');return;}const community=document.getElementById('discoverCommunity')?.value.trim()||'public';const payload=selectedPrinters.map(printer=>({...printer,snmp_community:printer.snmp_community||community}));const response=await fetch('/printers/import-discovered',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const data=await response.json();alert(`Importadas: ${data.imported_count} | Omitidas: ${data.skipped_count}`);clearDiscoveredPrinters();loadPrinters();loadSavedPrinters();}catch(error){alert('No se pudieron importar las impresoras.');console.error(error);}}

