async function addInventoryItem(){const payload={name:document.getElementById('invName').value.trim(),model:document.getElementById('invModel').value.trim(),type:document.getElementById('invType').value,quantity:Number(document.getElementById('invQty').value),min_stock:Number(document.getElementById('invMin').value)};if(!payload.name||!payload.model||Number.isNaN(payload.quantity)||Number.isNaN(payload.min_stock)){ alert('Completa todos los campos del inventario.');return;}try{await fetch('/inventory/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});document.getElementById('invName').value='';document.getElementById('invModel').value='';document.getElementById('invType').value='toner';document.getElementById('invQty').value='';document.getElementById('invMin').value='';loadInventory();}catch(error){alert('No se pudo agregar el inventario.');console.error(error);}}
async function deleteInventory(id){try{await fetch(`/inventory/${id}`,{method:'DELETE'});loadInventory();}catch(error){alert('No se pudo eliminar el inventario.');console.error(error);}}
async function loadTonerControl(){try{const response=await fetch('/toner-control/');const data=await response.json();const list=document.getElementById('tonerControlList');if(!list)return;list.innerHTML='';if(!Array.isArray(data)||!data.length){list.innerHTML='<tr><td colspan="18">No hay impresoras</td></tr>';return;}data.forEach(p=>{list.innerHTML+=`<tr><td>${p.shared_name??'-'}</td><td>${p.name??'-'}</td><td>${p.model??'-'}</td><td>${p.serial??'-'}</td><td><input value="${p.check_date??''}" id="check_${p.printer_id}"></td><td>${p.toner_black??'-'}</td><td>${p.is_color?(p.toner_cyan??'-'):'-'}</td><td>${p.is_color?`<input type="number" value="${p.toner_magenta??0}" id="tm_${p.printer_id}">`:'-'}</td><td>${p.is_color?`<input type="number" value="${p.toner_yellow??0}" id="ty_${p.printer_id}">`:'-'}</td><td><input type="number" value="${p.backup_black??0}" id="bk_${p.printer_id}"></td><td>${p.is_color?`<input type="number" value="${p.backup_cyan??0}" id="bc_${p.printer_id}">`:'-'}</td><td>${p.is_color?`<input type="number" value="${p.backup_magenta??0}" id="bm_${p.printer_id}">`:'-'}</td><td>${p.is_color?`<input type="number" value="${p.backup_yellow??0}" id="by_${p.printer_id}">`:'-'}</td><td>${p.location??'-'}</td><td><input value="${p.pedido??''}" id="pedido_${p.printer_id}"></td><td><input value="${p.work_order??''}" id="wo_${p.printer_id}"></td><td><input value="${p.notas??''}" id="notas_${p.printer_id}"></td><td><button class="action-button" onclick="saveBackup(${p.printer_id}, ${p.is_color})">Guardar</button></td></tr>`;});}catch(error){const list=document.getElementById('tonerControlList');if(list)list.innerHTML='<tr><td colspan="18">Error cargando datos</td></tr>';console.error('loadTonerControl error:',error);}
async function saveBackup(id,isColor){const data={check_date:document.getElementById('check_'+id).value,backup_black:Number(document.getElementById('bk_'+id).value)||0,pedido:document.getElementById('pedido_'+id).value,work_order:document.getElementById('wo_'+id).value,notas:document.getElementById('notas_'+id).value};if(isColor){data.backup_cyan=Number(document.getElementById('bc_'+id).value)||0;data.backup_magenta=Number(document.getElementById('bm_'+id).value)||0;data.backup_yellow=Number(document.getElementById('by_'+id).value)||0;}try{await fetch(`/toner-control/${id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});alert('Guardado');loadTonerControl();}catch(error){alert('Error guardando backup');console.error(error);}
}
function setTableFullHeight(){const header=document.querySelector('header');const filters=document.getElementById('dashboardFilters');const tableWrap=document.querySelector('#dashboardTableView .table-wrapper.dashboard-table-wrap');if(!tableWrap)return;const headerH=header?header.getBoundingClientRect().height:60;const filtersH=(filters&&!filters.classList.contains('closed'))?filters.getBoundingClientRect().height:0;const extraTop=20;const available=Math.max(320,window.innerHeight-headerH-filtersH-extraTop);tableWrap.style.height=available+'px';tableWrap.style.maxHeight=available+'px';}
function saveDashboardPrefs(){const keys=['viewMode','statusFilter','typeFilter','errorFilter','sortFilter'];const prefs={};keys.forEach(k=>{const el=document.getElementById(k);if(el)prefs[k]=el.value;});try{localStorage.setItem('dashboardPrefs',JSON.stringify(prefs));}catch(e){}
}
function loadDashboardPrefs(){try{const stored=localStorage.getItem('dashboardPrefs');if(!stored)return;const prefs=JSON.parse(stored);Object.entries(prefs).forEach(([k,v])=>{const el=document.getElementById(k);if(el)el.value=v;});}catch(e){}}
function openPrinterModal(printerId){const p=dashboardRawData.find(x=>x.id===printerId);if(!p)return;window._modalPrinter=p;const status=(p.status||'offline').toLowerCase();const statusPill=status==='online'?'<span class="status-pill status-online">ONLINE</span>':'<span class="status-pill status-offline">OFFLINE</span>';document.getElementById('modalTitle').innerHTML=`${p.shared_name??'Sin nombre'} ${statusPill}`;document.getElementById('modalSubtitle').innerHTML=`<span>${p.model??'-'}</span><span>·</span><span>${p.is_color?'Color':'Blanco y negro'}</span>`;document.getElementById('modalInfoGrid').innerHTML=[['Nombre',p.name??'-'],['IP',p.ip??'-'],['Serie',p.serial??'-'],['Ubicación',p.location??'-']].map(([l,v])=>`<div class="modal-field"><div class="modal-field-label">${l}</div><div class="modal-field-value">${v}</div></div>`).join('');const eClass=getErrorClass(p.error_message,p.status);document.getElementById('modalErrorContent').innerHTML=`<span class="${eClass}">${p.error_message??'Sin error'}</span>`;let th=renderModalTonerBar('Black',p.toner_black,'bar-black');if(p.is_color){th+=renderModalTonerBar('Cyan',p.toner_cyan,'bar-cyan');th+=renderModalTonerBar('Magenta',p.toner_magenta,'bar-magenta');th+=renderModalTonerBar('Yellow',p.toner_yellow,'bar-yellow');}document.getElementById('modalTonerContent').innerHTML=th;document.getElementById('printerModal').classList.add('open');}
function closePrinterModal(){document.getElementById('printerModal').classList.remove('open');window._modalPrinter=null;}
async function editFromModal(){const p=window._modalPrinter;closePrinterModal();if(!p)return;try{const res=await fetch(`/printers/${p.id}`);const full=await res.json();if(res.ok)editPrinter(full);else editPrinter(p);}catch(e){editPrinter(p);}}
function renderModalTonerBar(label,value,cssClass){const numeric=safeValue(value);const display=numeric===null?'-':`${numeric}%`;const width=numeric===null?0:Math.max(0,Math.min(100,numeric));return `<div class="modal-toner-item"><div class="modal-toner-row"><span>${label}</span><span>${display}</span></div><div class="modal-bar"><div class="modal-bar-fill ${cssClass}" style="width:${width}%"></div></div>${label==='Black'?tonerAlertText(numeric):''}</div>`;}
(function attachFilterListeners(){
const searchEl=document.getElementById('searchInput');if(searchEl)searchEl.addEventListener('input',()=>{clearTimeout(searchDebounceTimer);searchDebounceTimer=setTimeout(()=>renderDashboardWithFilters(),300);});['viewMode','statusFilter','typeFilter','errorFilter','sortFilter'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('change',()=>{saveDashboardPrefs();renderDashboardWithFilters();});});const printerIpEl=document.getElementById('printerIp');if(printerIpEl){printerIpEl.addEventListener('input',()=>validatePrinterIpField());printerIpEl.addEventListener('blur',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});printerIpEl.addEventListener('change',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});}['discoverStartIp','discoverEndIp','discoverSingleIp'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',()=>validateDiscoverFields());});toggleDiscoverModeFields();document.addEventListener('keydown',e=>{if(e.key==='Escape')closePrinterModal();});
})();

loadDashboardPrefs();showTab('dashboard');
</script>
