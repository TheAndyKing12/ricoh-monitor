async function addInventoryItem(){const payload={name:document.getElementById('invName').value.trim(),model:document.getElementById('invModel').value.trim(),type:document.getElementById('invType').value,quantity:Number(document.getElementById('invQty').value),min_stock:Number(document.getElementById('invMin').value)};if(!payload.name||!payload.model||Number.isNaN(payload.quantity)||Number.isNaN(payload.min_stock)){alert('Completa todos los campos del inventario.');return;}try{await fetch('/inventory/',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});document.getElementById('invName').value='';document.getElementById('invModel').value='';document.getElementById('invType').value='toner';document.getElementById('invQty').value='';document.getElementById('invMin').value='';loadInventory();}catch(error){alert('No se pudo agregar el inventario.');console.error(error);}}
async function deleteInventory(id){try{await fetch(`/inventory/${id}`,{method:'DELETE'});loadInventory();}catch(error){alert('No se pudo eliminar el inventario.');console.error(error);}}
async function loadTonerControl(){try{const response=await fetch('/toner-control/');const data=await response.json();const list=document.getElementById('tonerControlList');if(!list)return;list.innerHTML='';if(!Array.isArray(data)||!data.length){list.innerHTML='<tr><td colspan="18">No hay impresoras</td></tr>';return;}data.forEach(p=>{list.innerHTML+=`<tr><td>${p.shared_name??'-'}</td><td>${p.name??'-'}</td><td>${p.model??'-'}</td><td>${p.serial??'-'}</td><td><input value="${p.check_date??''}" id="check_${p.printer_id}"></td><td>${p.toner_black??'-'}</td><td>${p.is_color?(p.toner_cyan??'-'):'-'}</td><td>${p.is_color?(p.toner_magenta??'-'):'-'}</td><td>${p.is_color?(p.toner_yellow??'-'):'-'}</td><td><input type="number" value="${p.backup_black??0}" id="bk_${p.printer_id}"></td><td>${p.is_color?`<input type="number" value="${p.backup_cyan??0}" id="bc_${p.printer_id}">`:'-'}</td><td>${p.is_color?`<input type="number" value="${p.backup_magenta??0}" id="bm_${p.printer_id}">`:'-'}</td><td>${p.is_color?`<input type="number" value="${p.backup_yellow??0}" id="by_${p.printer_id}">`:'-'}</td><td>${p.location??'-'}</td><td><input value="${p.pedido??''}" id="pedido_${p.printer_id}"></td><td><input value="${p.work_order??''}" id="wo_${p.printer_id}"></td><td><input value="${p.notas??''}" id="notas_${p.printer_id}"></td><td><button class="action-button" onclick="saveBackup(${p.printer_id}, ${p.is_color})">Guardar</button></td></tr>`;});}catch(error){const list=document.getElementById('tonerControlList');if(list)list.innerHTML='<tr><td colspan="18">Error cargando datos</td></tr>';console.error('loadTonerControl error:',error);}}
async function saveBackup(id,isColor){const data={check_date:document.getElementById('check_'+id).value,backup_black:Number(document.getElementById('bk_'+id).value)||0,pedido:document.getElementById('pedido_'+id).value,work_order:document.getElementById('wo_'+id).value,notas:document.getElementById('notas_'+id).value};if(isColor){data.backup_cyan=Number(document.getElementById('bc_'+id).value)||0;data.backup_magenta=Number(document.getElementById('bm_'+id).value)||0;data.backup_yellow=Number(document.getElementById('by_'+id).value)||0;}try{await fetch(`/toner-control/${id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});alert('Guardado');loadTonerControl();}catch(error){alert('Error guardando backup');console.error(error);}}

function setTableFullHeight() {
    const header = document.querySelector('header');
    const filters = document.getElementById('dashboardFilters');
    const tableWrap = document.querySelector('#dashboardTableView .table-wrapper.dashboard-table-wrap');
    if (!tableWrap) return;
    const headerH = header ? header.getBoundingClientRect().height : 60;
    const filtersH = (filters && !filters.classList.contains('closed')) ? filters.getBoundingClientRect().height : 0;
    const extraTop = 20;
    const available = Math.max(320, window.innerHeight - headerH - filtersH - extraTop);
    tableWrap.style.height = available + 'px';
    tableWrap.style.maxHeight = available + 'px';
}
(function attachFilterListeners(){const searchEl=document.getElementById('searchInput');if(searchEl)searchEl.addEventListener('input',()=>loadPrinters());['viewMode','densityMode','statusFilter','typeFilter','errorFilter','sortFilter'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('change',()=>loadPrinters());});const printerIpEl=document.getElementById('printerIp');if(printerIpEl){printerIpEl.addEventListener('input',()=>validatePrinterIpField());printerIpEl.addEventListener('blur',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});printerIpEl.addEventListener('change',()=>{validatePrinterIpField();autofillPrinterNameFromIp();});}['discoverStartIp','discoverEndIp','discoverSingleIp'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',()=>validateDiscoverFields());});toggleDiscoverModeFields();})();
showTab('dashboard');setDensityMode('standard');


