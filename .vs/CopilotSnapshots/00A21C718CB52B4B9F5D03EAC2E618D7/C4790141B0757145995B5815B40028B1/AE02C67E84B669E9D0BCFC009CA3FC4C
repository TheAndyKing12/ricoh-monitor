@router.post("/{printer_id}/address-book/apply")
def apply_address_book_changes(printer_id: int, storage_mode: str | None = Query(default=None), admin: str | None = Query(default=None), password: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    mode = _get_storage_mode(storage_mode)
    if mode != "ricoh-real":
        raise HTTPException(status_code=400, detail="Apply is only available in ricoh-real mode")

    staged_entries = _get_local_entries(printer_id)
    if not staged_entries:
        return {
            "message": "No hay cambios pendientes para aplicar.",
            "applied": False,
            "pending_entries": 0,
            "printer_ip": printer.ip,
        }

    session = _ricoh_build_session(printer.ip)
    try:
        _ricoh_login_address_book(session, printer.ip, admin, password)
        real_entries = _ricoh_load_entries_with_session(session, printer.ip, dump=False)
        real_by_reg = {str(e.get("registration_no") or "").zfill(5): e for e in real_entries}

        applied_create = 0
        applied_update = 0
        for entry in staged_entries:
            reg = str(entry.get("registration_no") or "").strip().zfill(5)
            op_mode = "MODUSER" if reg in real_by_reg else "ADDUSER"
            _ricoh_set_user(session, printer.ip, entry, op_mode)
            if op_mode == "ADDUSER":
                applied_create += 1
            else:
                applied_update += 1

        _clear_local_entries(printer_id)
        return {
            "message": "Cambios aplicados en la Ricoh.",
            "applied": True,
            "pending_entries": len(staged_entries),
            "created": applied_create,
            "updated": applied_update,
            "printer_ip": printer.ip,
        }
    finally:
        _ricoh_logout_address_book(session, printer.ip)


def _clear_local_entries(printer_id: int):
    with STORE_LOCK:
        store = _load_store()
        store[str(printer_id)] = []
        _save_store(store)


def _ricoh_extract_wim_token(html: str) -> str:
    token_match = re.search(r'name=["\']wimToken["\'][^>]*value=["\']([^"\']*)["\']', html or "", re.IGNORECASE)
    return token_match.group(1) if token_match else ""


def _ricoh_load_entries_with_session(session: requests.Session, printer_ip: str, dump: bool = False) -> list[dict]:
    list_page_resp = session.get(f"http://{printer_ip}/web/entry/es/address/adrsList.cgi", timeout=RICOH_HTTP_TIMEOUT)
    if dump:
        ADRSLIST_DUMP_PATH.parent.mkdir(parents=True, exist_ok=True)
        ADRSLIST_DUMP_PATH.write_text(list_page_resp.text or "", encoding="utf-8", errors="ignore")
        _dump_ricoh_address_scripts(session, printer_ip, list_page_resp.text or "")

    endpoint = f"http://{printer_ip}/web/entry/es/address/adrsListLoadEntry.cgi"
    params = {
        "_": str(int(time.time() * 1000)),
        "listCountIn": "50",
        "getCountIn": "1",
    }
    headers = {
        "Accept": "text/plain, */*",
        "X-Requested-With": "XMLHttpRequest",
        "Referer": f"http://{printer_ip}/web/entry/es/address/adrsList.cgi",
    }

    response = session.get(endpoint, params=params, headers=headers, timeout=RICOH_HTTP_TIMEOUT)
    if response.status_code != 200:
        raise HTTPException(status_code=502, detail=f"Ricoh address-book list request failed ({response.status_code})")

    if "Tiempo de sesión agotado" in (response.text or ""):
        _ricoh_login_address_book(session, printer_ip)
        response = session.get(endpoint, params=params, headers=headers, timeout=RICOH_HTTP_TIMEOUT)
        if response.status_code != 200:
            raise HTTPException(status_code=502, detail=f"Ricoh address-book retry failed ({response.status_code})")

    if dump:
        RAW_DUMP_PATH.parent.mkdir(parents=True, exist_ok=True)
        RAW_DUMP_PATH.write_text(response.text or "", encoding="utf-8", errors="ignore")

    return _sort_entries(_ricoh_parse_entries(response.text))


def _ricoh_set_user(session: requests.Session, printer_ip: str, entry: dict, mode: str):
    reg = str(entry.get("registration_no") or "").strip().zfill(5)
    name = str(entry.get("name") or "").strip()
    if not _is_plausible_reg(reg) or not name:
        raise HTTPException(status_code=400, detail="Invalid staged entry")

    list_page = session.get(f"http://{printer_ip}/web/entry/es/address/adrsList.cgi", timeout=RICOH_HTTP_TIMEOUT)
    token = _ricoh_extract_wim_token(list_page.text)
    if not token:
        raise HTTPException(status_code=502, detail="Ricoh wimToken not found")

    get_payload = {
        "mode": mode,
        "outputSpecifyModeIn": "PROGRAMMED" if mode == "MODUSER" else "DEFAULT",
        "entryIndexIn": reg if mode == "MODUSER" else "",
        "wimToken": token,
    }
    session.post(f"http://{printer_ip}/web/entry/es/address/adrsGetUser.cgi", data=get_payload, timeout=RICOH_HTTP_TIMEOUT)

    key_display = str(entry.get("key_display") or name).strip() or name
    email = str(entry.get("email_address") or "").strip()
    user_code = str(entry.get("user_code") or "").strip()
    folder = str(entry.get("folder") or "").strip()

    post_data = [
        ("inputSpecifyModeIn", "WRITE"),
        ("listUpdateIn", "UPDATE"),
        ("wimToken", token),
        ("mode", mode),
        ("pageSpecifiedIn", ""),
        ("pageNumberIn", ""),
        ("searchSpecifyModeIn", ""),
        ("outputSpecifyModeIn", ""),
        ("inputSpecifyModeIn", ""),
        ("wayFrom", "adrsGetUser.cgi"),
        ("wayTo", "adrsList.cgi"),
        ("isSelfPasswordEditMode", "false"),
        ("priorityIn", "5"),
        ("entryIndexIn", reg),
        ("entryNameIn", name),
        ("entryReadNameIn", name),
        ("entryDisplayNameIn", key_display),
        ("entryTagInfoIn", "2"),
        ("entryTagInfoIn", "2"),
        ("entryTagInfoIn", "2"),
        ("entryTagInfoIn", "1"),
        ("userCodeIn", user_code),
        ("smtpAuthAccountIn", "AUTH_ASSIGNMENT_O"),
        ("smtpAuthUserNameIn", name),
        ("folderAuthAccountIn", "AUTH_ASSIGNMENT_O"),
        ("folderAuthUserNameIn", name),
        ("ldapAuthAccountIn", "AUTH_ASSIGNMENT_O"),
        ("ldapAuthUserNameIn", name),
        ("availableFuncIn", "MFPBROWSER"),
        ("entryUseIn", "ENTRYUSE_TO_O"),
        ("entryUseIn", "ENTRYUSE_FROM_O"),
        ("mailAddressIn", email),
        ("isCertificateExist", "false"),
        ("folderProtocolIn", "SMB_O"),
        ("folderPathNameIn", folder),
    ]

    resp = session.post(f"http://{printer_ip}/web/entry/es/address/adrsSetUser.cgi", data=post_data, timeout=RICOH_HTTP_TIMEOUT)
    if resp.status_code != 200:
        raise HTTPException(status_code=502, detail=f"Ricoh set user failed ({resp.status_code})")
    if not (resp.text or "").lstrip().startswith("["):
        raise HTTPException(status_code=502, detail="Ricoh set user rejected request")
