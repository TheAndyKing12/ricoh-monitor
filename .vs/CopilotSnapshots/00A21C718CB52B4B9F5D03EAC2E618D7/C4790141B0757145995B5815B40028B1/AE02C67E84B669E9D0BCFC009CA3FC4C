def _ensure_store_dir():
    STORE_PATH.parent.mkdir(parents=True, exist_ok=True)


def _load_store() -> dict:
    _ensure_store_dir()
    if not STORE_PATH.exists():
        return {}
    try:
        return json.loads(STORE_PATH.read_text(encoding="utf-8"))
    except Exception:
        return {}


def _save_store(data: dict):
    _ensure_store_dir()
    STORE_PATH.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")


def _get_printer_or_404(db: Session, printer_id: int):
    printer = crud.get_printer_by_id(db, printer_id)
    if not printer:
        raise HTTPException(status_code=404, detail="Printer not found")
    return printer


def _sort_entries(entries: list[dict]) -> list[dict]:
    def is_zero_registration(value) -> bool:
        text = str(value or "").strip()
        return text.isdigit() and int(text) == 0

    cleaned = [item for item in (entries or []) if not is_zero_registration(item.get("registration_no"))]
    return sorted(cleaned, key=lambda item: int(str(item.get("registration_no") or "0")))


def _next_registration_no(entries: list[dict]) -> str:
    max_value = 0
    for entry in entries:
        try:
            max_value = max(max_value, int(str(entry.get("registration_no") or "0")))
        except Exception:
            continue
    return str(max_value + 1).zfill(5)


def _get_storage_mode(override_mode: str | None = None) -> str:
    if override_mode:
        mode = override_mode.strip().lower()
        if mode in SUPPORTED_STORAGE_MODES:
            return mode
    mode = (os.getenv("ADDRESS_BOOK_STORAGE_MODE", DEFAULT_STORAGE_MODE) or DEFAULT_STORAGE_MODE).strip().lower()
    return mode if mode in SUPPORTED_STORAGE_MODES else DEFAULT_STORAGE_MODE


def _get_local_entries(printer_id: int) -> list[dict]:
    with STORE_LOCK:
        store = _load_store()
        return _sort_entries(store.get(str(printer_id), []))


def _create_local_entry(printer_id: int, payload: AddressBookEntryCreate) -> dict:
    with STORE_LOCK:
        store = _load_store()
        entries = store.setdefault(str(printer_id), [])
        registration_no = (payload.registration_no or "").strip() or _next_registration_no(entries)
        if any(str(item.get("registration_no")) == registration_no for item in entries):
            raise HTTPException(status_code=400, detail="Registration number already exists")
        entry = payload.dict()
        entry["registration_no"] = registration_no
        entries.append(entry)
        store[str(printer_id)] = _sort_entries(entries)
        _save_store(store)
    return entry


def _update_local_entry(printer_id: int, registration_no: str, payload: AddressBookEntryUpdate) -> dict:
    with STORE_LOCK:
        store = _load_store()
        entries = store.get(str(printer_id), [])
        target = next((item for item in entries if str(item.get("registration_no")) == registration_no), None)
        if not target:
            raise HTTPException(status_code=404, detail="Address book entry not found")
        for key, value in payload.dict(exclude_unset=True).items():
            target[key] = value
        store[str(printer_id)] = _sort_entries(entries)
        _save_store(store)
    return target


def _delete_local_entry(printer_id: int, registration_no: str):
    with STORE_LOCK:
        store = _load_store()
        entries = store.get(str(printer_id), [])
        new_entries = [item for item in entries if str(item.get("registration_no")) != registration_no]
        if len(new_entries) == len(entries):
            raise HTTPException(status_code=404, detail="Address book entry not found")
        store[str(printer_id)] = _sort_entries(new_entries)
        _save_store(store)


def _ricoh_credentials(admin: str | None = None, password: str | None = None) -> tuple[str, str]:
    user = (admin or os.getenv("RICOH_ADDRESSBOOK_USER", "admin") or "admin").strip()
    secret = password if password is not None else (os.getenv("RICOH_ADDRESSBOOK_PASSWORD", "") or "")
    return user, secret


def _ricoh_build_session(printer_ip: str) -> requests.Session:
    session = requests.Session()
    session.headers.update({"User-Agent": "Mozilla/5.0 (compatible)"})
    session.cookies.set("cookieOnOffChecker", "on", path="/")
    return session


def _ricoh_login_address_book_browser(session: requests.Session, printer_ip: str, user: str, secret: str, candidates: list[dict], diagnostics: list[str]) -> bool:
    if not ADDRESS_BOOK_BROWSER_LOGIN_ENABLED:
        diagnostics.append("browser:disabled")
        return False
    try:
        from playwright.sync_api import sync_playwright
    except Exception as ex:
        diagnostics.append(f"browser:unavailable={type(ex).__name__}")
        return False

    login_markers = (
        "authform.cgi",
        "inicio de sesión",
        "contraseña de inicio de sesión",
        "nombre de usuario de inicio de sesión",
    )

    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            context = browser.new_context(ignore_https_errors=True)
            page = context.new_page()
            try:
                for idx, candidate in enumerate(candidates, start=1):
                    try:
                        page.goto(candidate["auth_url"], wait_until="domcontentloaded", timeout=15000)
                    except Exception as ex:
                        diagnostics.append(f"browser:c{idx}:auth_exc={type(ex).__name__}")
                        continue

                    for selector in ("input[name='userid_work']", "input[name='userid']"):
                        loc = page.locator(selector)
                        if loc.count() > 0:
                            try:
                                loc.first.fill(user)
                            except Exception:
                                pass
                    for selector in ("input[name='password_work']", "input[name='password']"):
                        loc = page.locator(selector)
                        if loc.count() > 0:
                            try:
                                loc.first.fill(secret)
                            except Exception:
                                pass

                    submitted = False
                    submit_loc = page.locator("input[type='submit'],button[type='submit']")
                    if submit_loc.count() > 0:
                        try:
                            submit_loc.first.click(timeout=5000)
                            submitted = True
                        except Exception:
                            submitted = False
                    if not submitted:
                        try:
                            page.evaluate("() => { if (document.forms && document.forms[0]) document.forms[0].submit(); }")
                        except Exception:
                            diagnostics.append(f"browser:c{idx}:submit_fail")
                            continue

                    try:
                        page.wait_for_timeout(800)
                        page.goto(candidate["page_url"], wait_until="domcontentloaded", timeout=15000)
                    except Exception as ex:
                        diagnostics.append(f"browser:c{idx}:page_exc={type(ex).__name__}")
                        continue

                    page_text = (page.content() or "").lower()
                    matched = [m for m in login_markers if m in page_text]
                    if matched:
                        diagnostics.append(f"browser:c{idx}:markers={','.join(matched[:2])}")
                        continue

                    for cookie in context.cookies():
                        name = cookie.get("name")
                        value = cookie.get("value")
                        if not name:
                            continue
                        session.cookies.set(
                            name,
                            value,
                            domain=cookie.get("domain"),
                            path=cookie.get("path") or "/",
                        )
                    diagnostics.append(f"browser:c{idx}:ok")
                    return True
            finally:
                browser.close()
    except Exception as ex:
        diagnostics.append(f"browser:error={type(ex).__name__}")

    return False


def _ricoh_login_address_book(session: requests.Session, printer_ip: str, admin: str | None = None, password: str | None = None):
    user, secret = _ricoh_credentials(admin, password)
    candidates = [
        {
            "auth_url": f"http://{printer_ip}/web/guest/es/websys/webArch/authForm.cgi?open=address/adrsList.cgi",
            "login_url": f"http://{printer_ip}/web/guest/es/websys/webArch/login.cgi",
            "page_url": f"http://{printer_ip}/web/entry/es/address/adrsList.cgi",
        },
        {
            "auth_url": f"http://{printer_ip}/web/guest/websys/webArch/authForm.cgi?open=address/adrsList.cgi",
            "login_url": f"http://{printer_ip}/web/guest/websys/webArch/login.cgi",
            "page_url": f"http://{printer_ip}/web/entry/address/adrsList.cgi",
        },
    ]

    diagnostics: list[str] = []
    auth_form_available = False
    for idx, candidate in enumerate(candidates, start=1):
        try:
            auth_resp = session.get(candidate["auth_url"], timeout=RICOH_HTTP_TIMEOUT)
            diagnostics.append(f"c{idx}:auth={auth_resp.status_code}")
        except Exception as ex:
            diagnostics.append(f"c{idx}:auth_exc={type(ex).__name__}")
            continue
        if auth_resp.status_code != 200:
            continue

        auth_form_available = True
        token_match = re.search(r'name=["\']wimToken["\'][^>]*value=["\']([^"\']*)["\']', auth_resp.text, re.IGNORECASE)
        token = token_match.group(1) if token_match else ""

        hidden_inputs: dict[str, str] = {}
        for input_match in re.finditer(r"<input[^>]*>", auth_resp.text or "", re.IGNORECASE):
            tag = input_match.group(0)
            if not re.search(r'type=["\']?hidden["\']?', tag, re.IGNORECASE):
                continue
            name_match = re.search(r'name=["\']([^"\']+)["\']', tag, re.IGNORECASE)
            if not name_match:
                continue
            value_match = re.search(r'value=["\']([^"\']*)["\']', tag, re.IGNORECASE)
            hidden_inputs[name_match.group(1)] = value_match.group(1) if value_match else ""
        diagnostics.append(f"c{idx}:hidden={len(hidden_inputs)}")

        base_payload = {
            **hidden_inputs,
            "userid_work": hidden_inputs.get("userid_work", ""),
            "password_work": hidden_inputs.get("password_work", ""),
            "open": "address/adrsList.cgi",
            "wimToken": token or hidden_inputs.get("wimToken", ""),
        }

        user_b64 = base64.b64encode(user.encode("utf-8")).decode("ascii")
        pass_b64 = base64.b64encode(secret.encode("utf-8")).decode("ascii")

        payload_variants = (
            ("b64_hidden", {**base_payload, "userid": user_b64, "password": pass_b64}),
            ("plain_hidden", {**base_payload, "userid": user, "password": secret}),
            ("work_only", {**base_payload, "userid": "", "password": "", "userid_work": user, "password_work": secret}),
            ("plain_dual", {**base_payload, "userid": user, "password": secret, "userid_work": user, "password_work": secret}),
            ("b64_dual", {**base_payload, "userid": user_b64, "password": pass_b64, "userid_work": user, "password_work": secret}),
        )
        post_targets = (
            ("logincgi", candidate["login_url"]),
            ("authform", candidate["auth_url"].split("?", 1)[0]),
        )

        for target_name, post_url in post_targets:
            for mode, payload in payload_variants:
                try:
                    login_resp = session.post(
                        post_url,
                        data=payload,
                        headers={"Referer": candidate["auth_url"]},
                        timeout=RICOH_HTTP_TIMEOUT,
                    )
                    diagnostics.append(f"c{idx}:{target_name}:{mode}:login={login_resp.status_code}")
                except Exception as ex:
                    diagnostics.append(f"c{idx}:{target_name}:{mode}:login_exc={type(ex).__name__}")
                    continue
                if login_resp.status_code != 200:
                    continue

                try:
                    page_resp = session.get(candidate["page_url"], timeout=RICOH_HTTP_TIMEOUT)
                    diagnostics.append(f"c{idx}:{target_name}:{mode}:page={page_resp.status_code}")
                except Exception as ex:
                    diagnostics.append(f"c{idx}:{target_name}:{mode}:page_exc={type(ex).__name__}")
                    continue
                page_text = (page_resp.text or "").lower()
                login_markers = (
                    "authform.cgi",
                    "inicio de sesión",
                    "contraseña de inicio de sesión",
                    "nombre de usuario de inicio de sesión",
                )
                matched_markers = [marker for marker in login_markers if marker in page_text]
                if matched_markers:
                    diagnostics.append(f"c{idx}:{target_name}:{mode}:markers={','.join(matched_markers[:2])}")
                    continue
                diagnostics.append(f"c{idx}:{target_name}:{mode}:ok")
                return

    diag_text = " | ".join(diagnostics[-12:]) if diagnostics else "sin diagnóstico"
    if not auth_form_available:
        raise HTTPException(status_code=502, detail=f"Ricoh auth form not available ({diag_text})")
    if _ricoh_login_address_book_browser(session, printer_ip, user, secret, candidates, diagnostics):
        return

    diag_text = " | ".join(diagnostics[-16:]) if diagnostics else "sin diagnóstico"
    if not auth_form_available:
        raise HTTPException(status_code=502, detail=f"Ricoh auth form not available ({diag_text})")
    raise HTTPException(status_code=401, detail=f"Credenciales inválidas para la libreta de direcciones ({diag_text})")


def _ricoh_logout_address_book(session: requests.Session, printer_ip: str):
    logout_urls = [
        f"http://{printer_ip}/web/entry/es/websys/webArch/logout.cgi",
        f"http://{printer_ip}/web/guest/es/websys/webArch/logout.cgi",
        f"http://{printer_ip}/web/entry/es/address/logout.cgi",
    ]
    for url in logout_urls:
        try:
            session.get(url, timeout=RICOH_HTTP_TIMEOUT)
        except Exception:
            continue


def _is_noise_name(value: str) -> bool:
    text = (value or "").strip().lower()
    if not text:
        return True
    noise_tokens = (
        "location",
        "concat(",
        "background-color",
        "function(",
        "var ",
        "document.",
        "window.",
        "http://",
        "https://",
        "websys/",
        "cgi",
        "<script",
        "</script",
        "{",
        "}",
        ";",
    )
    return any(token in text for token in noise_tokens)


def _is_plausible_reg(reg: str) -> bool:
    s = str(reg or "").strip()
    if not re.fullmatch(r"\d{1,6}", s):
        return False
    n = int(s)
    return 1 <= n <= 99999


def _entry_dict(reg: str, name: str) -> dict:
    return {
        "registration_no": str(reg).zfill(5),
        "name": name,
        "key_display": None,
        "freq": True,
        "title1": None,
        "title2": None,
        "title3": None,
        "user_code": None,
        "email_address": None,
        "folder": None,
        "status": "Activo",
    }


def _ricoh_parse_entries_from_html(content: str) -> list[dict]:
    entries: list[dict] = []
    html = content or ""
    rows = re.findall(r"<tr[^>]*>(.*?)</tr>", html, flags=re.IGNORECASE | re.DOTALL)
    for row in rows:
        cols_raw = re.findall(r"<t[dh][^>]*>(.*?)</t[dh]>", row, flags=re.IGNORECASE | re.DOTALL)
        if not cols_raw:
            continue
        cols = [re.sub(r"<[^>]+>", " ", c) for c in cols_raw]
        cols = [re.sub(r"\s+", " ", c).strip() for c in cols]
        reg = None
        for col in cols:
            if re.fullmatch(r"\d{1,6}", col or "") and _is_plausible_reg(col):
                reg = col
                break
        if not reg:
            continue
        name = ""
        for col in cols:
            if col and not re.fullmatch(r"\d{1,6}", col):
                if not _is_noise_name(col):
                    name = col
                    break
        if not name:
            continue
        entries.append(_entry_dict(reg, name))

    if not entries:
        for reg, name in re.findall(r"[\"'](\d{1,6})[\"']\s*[,;]\s*[\"']([^\"']{1,120})[\"']", html):
            clean_name = re.sub(r"\s+", " ", name).strip()
            if _is_plausible_reg(reg) and clean_name and not _is_noise_name(clean_name):
                entries.append(_entry_dict(reg, clean_name))

    dedup: dict[str, dict] = {}
    for entry in entries:
        dedup[entry["registration_no"]] = entry
    return _sort_entries(list(dedup.values()))


def _ricoh_parse_entries(content: str) -> list[dict]:
    content = content or ""
    stripped = content.strip()
    if not stripped:
        return []

    try:
        payload = json.loads(stripped)
        candidates = payload if isinstance(payload, list) else payload.get("entries") if isinstance(payload, dict) else None
        if isinstance(candidates, list):
            parsed: list[dict] = []
            for item in candidates:
                if not isinstance(item, dict):
                    continue
                registration_no = str(item.get("registration_no") or item.get("registrationNo") or item.get("regNo") or "").strip()
                name = str(item.get("name") or item.get("displayName") or item.get("userName") or "").strip()
                if not _is_plausible_reg(registration_no):
                    continue
                if not name or _is_noise_name(name):
                    continue
                parsed.append({
                    "registration_no": registration_no.zfill(5),
                    "name": name,
                    "key_display": item.get("key_display") or item.get("keyDisplay"),
                    "freq": bool(item.get("freq", True)),
                    "title1": item.get("title1"),
                    "title2": item.get("title2"),
                    "title3": item.get("title3"),
                    "user_code": item.get("user_code") or item.get("userCode"),
                    "email_address": item.get("email_address") or item.get("emailAddress"),
                    "folder": item.get("folder"),
                    "status": item.get("status") or "Activo",
                })
            if parsed:
                return _sort_entries(parsed)
    except Exception:
        pass

    js_like_rows = re.findall(r"\[\s*(\d+)\s*,\s*(\d+)\s*,\s*'([^']+)'\s*,\s*'([^']+)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*,\s*'([^']*)'\s*\]", stripped)
    if js_like_rows:
        parsed_js: list[dict] = []
        for entry_id, freq_flag, reg, name, user_code, _, email, folder in js_like_rows:
            reg_text = (reg or "").strip()
            name_text = (name or "").strip()
            if not _is_plausible_reg(reg_text):
                continue
            if not name_text or _is_noise_name(name_text):
                continue
            parsed_js.append({
                "registration_no": reg_text.zfill(5),
                "name": name_text,
                "key_display": name_text,
                "freq": str(freq_flag).strip() == "1",
                "title1": None,
                "title2": None,
                "title3": None,
                "user_code": (user_code or "").strip() or None,
                "email_address": (email or "").strip() or None,
                "folder": (folder or "").strip() or None,
                "status": "Activo",
                "_entry_id": str(entry_id or "").strip() or None,
            })
        if parsed_js:
            dedup: dict[str, dict] = {}
            for entry in parsed_js:
                dedup[entry["registration_no"]] = entry
            return _sort_entries(list(dedup.values()))

    lines = [ln.strip() for ln in re.split(r"\r?\n", stripped) if ln.strip()]
    parsed_lines: list[dict] = []
    for line in lines:
        if line.startswith("<"):
            continue
        if _is_noise_name(line):
            continue
        parts = [p.strip() for p in re.split(r"\t|;|\|", line) if p.strip()]
        reg = next((p for p in parts if _is_plausible_reg(p)), None)
        if not reg:
            m = re.search(r"\b(\d{1,6})\b", line)
            reg = m.group(1) if m and _is_plausible_reg(m.group(1)) else None
        if not reg:
            continue
        name = None
        for p in parts:
            if p != reg and not re.fullmatch(r"\d{1,6}", p) and not _is_noise_name(p):
                name = p
                break
        if not name:
            m_name = re.search(r"\b\d{1,6}\b\s+([A-Za-zÁÉÍÓÚÑáéíóúñ0-9 .,_\-()]{2,120})", line)
            candidate = m_name.group(1).strip() if m_name else ""
            name = candidate if candidate and not _is_noise_name(candidate) else None
        if not name:
            continue
        parsed_lines.append(_entry_dict(reg, name))
    if parsed_lines:
        dedup: dict[str, dict] = {}
        for entry in parsed_lines:
            dedup[entry["registration_no"]] = entry
        return _sort_entries(list(dedup.values()))

    return _ricoh_parse_entries_from_html(content)


def _get_ricoh_entries(printer, admin: str | None = None, password: str | None = None) -> list[dict]:
    session = _ricoh_build_session(printer.ip)
    try:
        _ricoh_login_address_book(session, printer.ip, admin, password)
        entries = _ricoh_load_entries_with_session(session, printer.ip, dump=True)
        return _sort_entries(entries)
    finally:
        _ricoh_logout_address_book(session, printer.ip)


def _create_ricoh_entry(printer, payload: AddressBookEntryCreate) -> dict:
    return _create_local_entry(printer.id, payload)


def _update_ricoh_entry(printer, registration_no: str, payload: AddressBookEntryUpdate) -> dict:
    return _update_local_entry(printer.id, registration_no, payload)


def _delete_ricoh_entry(printer, registration_no: str):
    return _delete_local_entry(printer.id, registration_no)


def _merge_entries(base_entries: list[dict], overlay_entries: list[dict]) -> list[dict]:
    merged: dict[str, dict] = {}
    for entry in base_entries or []:
        reg = str(entry.get("registration_no") or "").strip()
        if reg:
            merged[reg] = entry
    for entry in overlay_entries or []:
        reg = str(entry.get("registration_no") or "").strip()
        if reg:
            merged[reg] = entry
    return _sort_entries(list(merged.values()))


@router.post("/{printer_id}/address-book/auth")
def validate_address_book_auth(printer_id: int, payload: AddressBookAuthRequest, db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    session = _ricoh_build_session(printer.ip)
    try:
        try:
            _ricoh_login_address_book(session, printer.ip, payload.admin, payload.password)
            return {"valid": True, "printer_id": printer.id, "printer_ip": printer.ip, "storage_mode": "ricoh-real"}
        except HTTPException as ex:
            if not ADDRESS_BOOK_BROWSER_LOGIN_ENABLED:
                cfg_user, cfg_secret = _ricoh_credentials()
                if (payload.admin or "").strip() == cfg_user and (payload.password or "") == cfg_secret:
                    return {
                        "valid": True,
                        "printer_id": printer.id,
                        "printer_ip": printer.ip,
                        "storage_mode": "local-safe",
                        "warning": "Login Ricoh no disponible; acceso habilitado en modo local seguro.",
                    }
            raise ex
    finally:
        _ricoh_logout_address_book(session, printer.ip)


@router.post("/{printer_id}/address-book/logout")
def logout_address_book_session(printer_id: int, admin: str | None = Query(default=None), password: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    session = _ricoh_build_session(printer.ip)
    try:
        _ricoh_login_address_book(session, printer.ip, admin, password)
    except Exception:
        pass
    _ricoh_logout_address_book(session, printer.ip)
    return {"logged_out": True, "printer_id": printer.id, "printer_ip": printer.ip}


@router.get("/{printer_id}/address-book", response_model=AddressBookListResponse)
def list_address_book(printer_id: int, storage_mode: str | None = Query(default=None), admin: str | None = Query(default=None), password: str | None = Query(default=None), db: Session = Depends(get_db)):
    printer = _get_printer_or_404(db, printer_id)
    storage_mode = _get_storage_mode(storage_mode)
    if storage_mode == "ricoh-real":
        try:
            ricoh_entries = _get_ricoh_entries(printer, admin, password)
            overlay_entries = _get_local_entries(printer_id)
            entries = _merge_entries(ricoh_entries, overlay_entries)
        except HTTPException:
            if not ADDRESS_BOOK_BROWSER_LOGIN_ENABLED:
                entries = _get_local_entries(printer_id)
                storage_mode = "local-safe"
            else:
                raise
    else:
        entries = _get_local_entries(printer_id)
    return {
        "printer_id": printer.id,
        "printer_ip": printer.ip,
        "storage_mode": storage_mode,
        "entries": entries,
    }


