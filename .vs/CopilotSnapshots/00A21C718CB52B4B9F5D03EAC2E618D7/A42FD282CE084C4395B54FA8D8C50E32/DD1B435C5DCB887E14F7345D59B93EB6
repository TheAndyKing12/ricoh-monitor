from app.database import SessionLocal

from app import models

def fix_printer_names():

    db = SessionLocal()

    printers = db.query(models.Printer).all()

    print(f"Impresoras encontradas: {len(printers)}")

    for p in printers:

        print("ANTES ->", p.id, "shared_name=", p.shared_name, "name=", p.name)

        if p.shared_name:

            if not p.name or p.name.strip() == "-" or p.name.strip() == "":

                p.name = p.shared_name

            # vacía shared_name siempre para dejarlo manual

            p.shared_name = None

        print("DESPUÉS ->", p.id, "shared_name=", p.shared_name, "name=", p.name)

    db.commit()

    db.close()

    print("Datos corregidos")

if __name__ == "__main__":

    fix_printer_names()
 