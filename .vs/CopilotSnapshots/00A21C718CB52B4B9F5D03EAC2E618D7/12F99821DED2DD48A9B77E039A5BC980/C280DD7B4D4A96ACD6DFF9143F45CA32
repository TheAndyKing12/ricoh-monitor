with open('frontend/dashboard.html', encoding='utf-8') as f:
    content = f.read()

js_start = content.index('<script>') + len('<script>')
js_end = content.index('</script>')
js = content[js_start:js_end]

# Find absolute line number offset of <script> in file
script_line_offset = content[:js_start].count('\n')

balance = 0
in_str = None
escape = False
lines = js.split('\n')
snapshots = []  # (line_idx, balance)

for line_idx, line in enumerate(lines):
    for ch in line:
        if escape:
            escape = False
            continue
        if ch == '\\' and in_str in ('"', "'", '`'):
            escape = True
            continue
        if in_str is None:
            if ch == '{': balance += 1
            elif ch == '}': balance -= 1
            elif ch in ('"', "'", '`'): in_str = ch
        else:
            if ch == in_str: in_str = None
    snapshots.append((line_idx, balance))

print(f"Balance final: {balance}")
# Find last line where balance dropped to 1 for the last time going backwards
for idx in range(len(snapshots)-1, -1, -1):
    if snapshots[idx][1] == 1:
        file_line = snapshots[idx][0] + script_line_offset + 1
        all_lines = content.split('\n')
        print(f"Ultima linea con balance=1: archivo linea {file_line}")
        for i in range(max(0, file_line-1), min(len(all_lines), file_line+2)):
            print(f"  L{i+1}: {all_lines[i][:150]}")
        break
