with open('frontend/dashboard.html', encoding='utf-8') as f:
    content = f.read()

js_start = content.index('<script>') + len('<script>')
js_end = content.index('</script>')
js = content[js_start:js_end]
script_line_offset = content[:js_start].count('\n')
lines = js.split('\n')

# Scan forward, record each { with its line index and balance AFTER
balance = 0
in_str = None
escape = False
open_stack = []  # stack of (line_idx, balance_before)

for line_idx, line in enumerate(lines):
    for ch in line:
        if escape:
            escape = False
            continue
        if ch == '\\' and in_str in ('"', "'", '`'):
            escape = True
            continue
        if in_str is None:
            if ch == '{':
                balance += 1
                open_stack.append(line_idx)
            elif ch == '}':
                balance -= 1
                if open_stack:
                    open_stack.pop()
            elif ch in ('"', "'", '`'):
                in_str = ch
        else:
            if ch == in_str:
                in_str = None

print(f"Balance final: {balance}")
print(f"Llaves sin cerrar: {len(open_stack)}")
all_lines = content.split('\n')
for line_idx in open_stack:
    file_line = line_idx + script_line_offset + 1
    print(f"  {{ sin cerrar en linea archivo {file_line}: {all_lines[file_line-1][:160]}")
