with open('frontend/dashboard.html', encoding='utf-8') as f:
    content = f.read()

js_start = content.index('<script>') + len('<script>')
js_end = content.index('</script>')
js = content[js_start:js_end]

balance = 0
in_str = None
escape = False
lines = js.split('\n')

for line_idx, line in enumerate(lines):
    for ch in line:
        if escape:
            escape = False
            continue
        if ch == '\\' and in_str in ('"', "'", '`'):
            escape = True
            continue
        if in_str is None:
            if ch == '{':
                balance += 1
            elif ch == '}':
                balance -= 1
            elif ch in ('"', "'", '`'):
                in_str = ch
        else:
            if ch == in_str:
                in_str = None

    if balance < 0:
        print(f"BALANCE NEGATIVO en linea JS {line_idx+1}: {line[:120]}")
        break

print(f"Balance final: {balance}")
if balance != 0:
    print("ERROR: llaves desbalanceadas en el JS")
else:
    print("OK: llaves balanceadas")
