with open('frontend/dashboard.html', encoding='utf-8') as f:
    lines = f.readlines()

# Line 304 (index 303): add missing closing } for the function body
target = 303
line = lines[target]
if line.rstrip('\n').endswith('null;}'):
    lines[target] = line.rstrip('\n') + '}\n'
    with open('frontend/dashboard.html', 'w', encoding='utf-8') as f:
        f.writelines(lines)
    print("FIXED: added missing } to line 304")
else:
    print(f"No fix needed or line changed. End: {repr(line[-30:])}")
