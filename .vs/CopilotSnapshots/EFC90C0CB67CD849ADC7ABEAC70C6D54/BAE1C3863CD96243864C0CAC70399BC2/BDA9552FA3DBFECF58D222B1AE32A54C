<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Ricoh Monitor Dashboard</title>
<link rel="stylesheet" href="style.css">
<link rel="stylesheet" href="bootstrap-icons.min.css">
<link rel="stylesheet" href="inter.css">
<style>
*{box-sizing:border-box}
body{margin:0;font-family:'Inter',Arial,sans-serif;background:#111827;color:#f3f4f6}
.layout{display:flex;min-height:100vh}
.sidebar{width:64px;background:#0f172a;border-right:1px solid #1f2937;padding:12px 8px;transition:width .28s ease}
.sidebar:hover{width:240px;padding:20px}
.sidebar h2{margin:0 0 12px 0;font-size:18px;transition:opacity .18s ease,transform .18s ease}
.sidebar-title{display:inline-block;opacity:1;transform:none;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .sidebar-title{opacity:0;transform:translateX(-8px)}
.menu-button{width:100%;display:flex;align-items:center;gap:10px;justify-content:center;background:#111827;color:#e5e7eb;border:1px solid #374151;border-radius:10px;padding:12px 14px;text-align:left;font-size:14px;cursor:pointer;margin-bottom:10px;transition:background .2s ease,border-color .2s ease,box-shadow .2s ease,color .2s ease,transform .15s ease;position:relative}
.menu-button:nth-child(2){transition-delay:30ms}
.menu-button:nth-child(3){transition-delay:60ms}
.menu-button:nth-child(4){transition-delay:90ms}
.menu-button:nth-child(5){transition-delay:120ms}
.menu-button:nth-child(6){transition-delay:150ms}
.menu-button:hover{background:#1f2937}
.sidebar:hover .menu-button{justify-content:flex-start}
.menu-button.active{background:rgba(37,99,235,0.12);border-color:rgba(59,130,246,0.45);color:#93c5fd;box-shadow:inset 3px 0 0 #3b82f6}
.menu-button.active .menu-icon i{color:#60a5fa}
.menu-icon{font-size:18px;flex-shrink:0;width:20px;text-align:center;line-height:1;position:relative}
.menu-icon i{display:inline-block;transition:transform .22s cubic-bezier(.34,1.56,.64,1),color .18s ease}
.menu-button:hover .menu-icon i{transform:scale(1.28);color:#60a5fa}
.menu-badge{position:absolute;top:-7px;right:-9px;background:#ef4444;color:#fff;font-size:9px;font-weight:700;min-width:15px;height:15px;border-radius:999px;display:none;align-items:center;justify-content:center;padding:0 3px;line-height:1;border:1.5px solid #0f172a;animation:badgePop .25s cubic-bezier(.34,1.56,.64,1)}
.menu-badge.warn{background:#f59e0b}
@keyframes badgePop{from{transform:scale(0)}to{transform:scale(1)}}
.menu-label{display:inline-block;transition:opacity .18s ease,transform .18s ease}
.sidebar:not(:hover) .menu-label{opacity:0;transform:translateX(-6px);width:0;overflow:hidden}
.content{flex:1;display:flex;flex-direction:column}
header{padding:14px 20px;background:#0f172a;border-bottom:1px solid #1f2937;display:flex;flex-direction:column;gap:12px}
.badge{padding:8px 12px;border-radius:999px;background:#1f2937;font-size:13px}
.tab{display:none;padding:12px}
.tab.active{display:block;animation:tabFadeIn .18s ease}
@keyframes tabFadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin-bottom:12px}
.summary-card{background:#1f2937;border:1px solid #374151;border-radius:14px;padding:18px;position:relative;overflow:hidden;transition:transform .2s ease,box-shadow .2s ease}
.summary-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(255,255,255,.1)}
.summary-card-total{border-color:#2563eb}
.summary-card-online{border-color:#22c55e}
.summary-card-offline{border-color:#ef4444}
.summary-card-toner{border-color:#eab308}
.summary-card h3{margin:0 0 8px;font-size:13px;color:#9ca3af;font-weight:normal;display:flex;align-items:center;gap:6px}
.summary-card .value{font-size:28px;font-weight:bold}
.summary-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 14px 14px}
.summary-card-total::after{background:#2563eb}
.summary-card-online::after{background:#22c55e}
.summary-card-offline::after{background:#ef4444}
.summary-card-toner::after{background:#eab308}
.card-icon-bg { position:absolute; right:-20px; bottom:-20px; font-size:120px; color:#fff; opacity:0.04; transition:opacity .3s ease; pointer-events:none; z-index:0; }
.summary-card:hover .card-icon-bg{opacity:.13}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:18px}
.card{background:#1f2937;border:1px solid #374151;border-radius:16px;padding:18px;box-shadow:0 2px 12px rgba(0,0,0,.25);transition:transform .2s ease,box-shadow .2s ease,border-color .2s ease}
.card:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(0,0,0,.4);border-color:#4b5563}
.card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px}
.printer-name{font-size:18px;font-weight:bold;margin:0}
.printer-model{margin-top:4px;font-size:13px;color:#9ca3af}
.printer-secondary{margin-top:4px;font-size:13px;color:#d1d5db}
.status-pill{padding:6px 10px;border-radius:999px;font-size:12px;font-weight:bold;text-transform:uppercase;white-space:nowrap}
.status-online{background:rgba(34,197,94,.18);color:#22c55e;border:1px solid rgba(34,197,94,.4)}
.status-offline{background:rgba(239,68,68,.18);color:#ef4444;border:1px solid rgba(239,68,68,.4)}
.info-row{font-size:13px;color:#d1d5e1;margin-bottom:6px}
.toner-section{margin-top:16px}
.toner-title{font-size:13px;color:#9ca3b8;margin-bottom:10px;text-transform:uppercase;letter-spacing:.04em}
.toner-item{margin-bottom:12px}
.toner-label-row{display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px}
.bar{width:100%;height:12px;background:#111827;border-radius:999px;overflow:hidden;border:1px solid #374151}
.bar-fill{height:100%;border-radius:999px;transition:width .4s ease}
.bar-black{background:linear-gradient(90deg,#64748b,#e5e7eb)}
.bar-cyan{background:linear-gradient(90deg,#0891b2,#22d3ee)}
.bar-magenta{background:linear-gradient(90deg,#a21caf,#e879f9)}
.bar-yellow{background:linear-gradient(90deg,#b45309,#fde047)}
.empty-state{text-align:center;padding:60px 20px;color:#9ca3baf;background:#1f2937;border-radius:16px;border:1px solid #374151}
.warning-text{color:#f59e0b;font-size:12px;margin-top:8px}
.critical-text{color:#ef4444;font-size:12px;margin-top:8px}
.section-title{padding-left:14px;border-left:3px solid #3b82f6}
.action-row{display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap}
.action-button{background:#2563eb;color:#fff;border:none;border-radius:10px;padding:12px 16px;cursor:pointer;font-size:14px}
.action-button:hover{background:#1d4ed8}
.action-button-danger{background:#dc2626}
.action-button-danger:hover{background:#b91c1c}
.action-button-secondary{background:#475569}
.action-button-secondary:hover{background:#334155}
.action-button-warning{background:#eab308;color:#111827;font-weight:700}
.action-button-warning:hover{background:#ca8a04}
.action-button-success{background:#16a34a}
.action-button-success:hover{background:#15803d}
.table-wrapper{background:#1f2937;border:1px solid #374151;border-radius:16px;overflow:auto;max-width:100%;max-height:70vh}
table{width:100%;border-collapse:collapse;min-width:1100px}
th,td{padding:14px;text-align:left;border-bottom:1px solid #374151;font-size:14px;vertical-align:top}
th{background:#111827;color:#9ca3af}
tr:last-child td{border-bottom:none}
.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.form-grid>div{display:flex;flex-direction:column;gap:6px}
.form-grid label{display:block;font-size:13px;color:#cbd5e1;font-weight:600}
input,select{padding:10px;border-radius:8px;border:1px solid #374151;background:#111827;color:white;width:100%}
.dashboard-title{font-size:24px;font-weight:700;color:#f8fafc;line-height:1.1}
.dashboard-header{width:100%;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.dashboard-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.filter-toggle-btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;min-width:220px;min-height:44px;background:linear-gradient(180deg,#1e293b 0%,#162033 100%);border:1px solid #3b4d65;color:#f8fafc;border-radius:999px;padding:10px 16px;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.22);transition:.2s ease}
.filter-toggle-btn:hover{transform:translateY(-1px);background:linear-gradient(180deg,#25344b 0%,#1a2638 100%)}
.filter-toggle-btn.is-open{background:linear-gradient(180deg,#1d4ed8 0%,#1e40af 100%);border-color:#60a5fa;box-shadow:0 6px 18px rgba(37,99,235,.28)}
.filter-toggle-btn.is-open .filter-toggle-state{color:#dbeafe}
.filter-toggle-icon{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:999px;background:#111827;border:1px solid #334155;font-size:12px;color:#cbd5e1;flex:0 0 auto}
.filter-toggle-btn.is-open .filter-toggle-icon{background:rgba(15,23,42,.6);border-color:#93c5fd;color:#eff6ff}
.dashboard-filters{display:grid;grid-template-columns:minmax(240px,2fr) repeat(5,minmax(120px,1fr)) minmax(96px,auto);gap:8px;margin:0 0 12px;align-items:center;transition:max-height .25s ease,opacity .2s ease,transform .2s ease;max-height:600px;opacity:1;transform:none;overflow:visible;pointer-events:auto}
.dashboard-filters.closed{max-height:0;opacity:0;transform:translateY(-8px);margin:0;gap:0;overflow:hidden;pointer-events:none}
.toolbar-input,.toolbar-select{min-height:34px;padding:7px 10px;border-radius:8px;border:1px solid #374151;background:#0f172a;color:#e5e7eb;font-size:12px;width:100%}
.toolbar-button{min-height:34px;padding:7px 12px;border-radius:8px;border:1px solid #374151;background:#1f2937;color:#e5e7eb;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap}
.toolbar-button:hover{background:#273244}
.warning-text,.error-warn,.toner-low{color:#f59e0b !important;font-weight:700}
.critical-text,.error-critical,.toner-critical{color:#ef4444 !important;font-weight:700}
.error-ok{color:#cbd5e1}
.printer-collapsible{display:none}
.printer-collapsible.is-open{display:block}
.discover-fields{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:14px}
.discover-fields>div{display:flex;flex-direction:column;gap:6px}
.field-help{font-size:12px;margin-top:4px;color:#9ca3b8}
.field-help.error{color:#ef4444}
.field-help.success{color:#22c55e}
.input-invalid{border-color:#ef4444 !important;box-shadow:0 0 0 1px rgba(239,68,68,.35)}
.input-valid{border-color:#22c55e !important;box-shadow:0 0 0 1px rgba(34,197,94,.25)}
.discover-select-col{width:56px;text-align:center}
.discover-checkbox{width:18px;height:18px;accent-color:#2563eb;cursor:pointer}
.sortable-th{cursor:pointer;user-select:none;white-space:nowrap}
.sortable-th:hover{color:#e5e7eb}
.row-error{background:rgba(239,68,68,.07)}.row-low{background:rgba(234,179,8,.07)}
.status-badge{padding:4px 8px;border-radius:999px;font-size:12px;font-weight:700}
.status-badge-online{background:rgba(34,197,94,.18);color:#22c55e}
.status-badge-offline{background:rgba(239,68,68,.18);color:#ef4444}
.toner-inline{display:flex;gap:8px;flex-wrap:wrap}
.toner-mini{display:flex;align-items:center;gap:6px;min-width:80px}.mini-bar{width:42px;height:8px;background:#111827;border:1px solid #374151;border-radius:999px;overflow:hidden}.mini-bar .fill{height:100%}.mini-label{font-size:12px}.tc-muted{color:#94a3b8}
.sort-ind{font-size:11px;color:inherit;opacity:0.5;margin-left:5px;min-width:10px;display:inline-block;transition:opacity 0.15s,font-weight:600}
.sort-ind.active{opacity:1;text-shadow:none;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);display:none;align-items:center;justify-content:center;z-index:1000;padding:16px;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex;animation:modalFadeIn .18s ease}
@keyframes modalFadeIn{from{opacity:0}to{opacity:1}}
.modal-box{background:#1e293b;border:1px solid #334155;border-radius:20px;padding:28px;width:100%;max-width:560px;max-height:88vh;overflow-y:auto;position:relative;animation:modalSlideUp .22s cubic-bezier(.34,1.56,.64,1)}
@keyframes modalSlideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-close{position:absolute;top:14px;right:14px;background:none;border:none;color:#64748b;font-size:18px;cursor:pointer;padding:4px 8px;border-radius:8px;line-height:1}
.modal-close:hover{background:#334155;color:#e2e8f0}
.modal-title{font-size:20px;font-weight:700;color:#f8fafc;margin:0 0 4px;padding-right:32px}
.modal-subtitle{font-size:13px;color:#94a3b8;margin:0 0 20px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.modal-section{margin-bottom:20px}
.modal-section-title{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:#475569;margin:0 0 10px;font-weight:700}
.modal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.modal-field{background:#111827;border:1px solid #1f2937;border-radius:10px;padding:10px 14px}
.modal-field-label{font-size:10px;color:#475569;margin-bottom:3px;text-transform:uppercase;letter-spacing:.05em}
.modal-field-value{font-size:13px;color:#e2e8f0;font-weight:500}
.modal-toner-item{margin-bottom:12px}
.modal-toner-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:5px;color:#cbd5e1}
.modal-bar{width:100%;height:10px;background:#0f172a;border-radius:999px;overflow:hidden;border:1px solid #1f2937}
.modal-bar-fill{height:100%;border-radius:999px;transition:width .5s ease}
.modal-actions{display:flex;gap:10px;margin-top:22px;justify-content:flex-end;border-top:1px solid #1f2937;padding-top:18px}
.clickable-name{cursor:pointer;color:#93c5fd}
.clickable-name:hover{text-decoration:underline}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:900;display:none;cursor:pointer;backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px)}
.drawer-overlay.open{display:block}
.drawer-panel{position:fixed;top:0;right:0;height:100vh;width:460px;max-width:96vw;background:#1e293b;border-left:1px solid #334155;z-index:901;transform:translateX(110%);transition:transform .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-8px 0 40px rgba(0,0,0,.45)}
.drawer-panel.open{transform:translateX(0);animation:drawerSlideIn .35s cubic-bezier(.34,1.56,.64,1)}
.drawer-header{display:flex;align-items:center;justify-content:space-between;padding:20px 24px 16px;border-bottom:1px solid #334155;flex-shrink:0}
.drawer-title{font-size:16px;font-weight:700;color:#f8fafc;margin:0}
.drawer-close{background:none;border:none;color:#64748b;font-size:20px;cursor:pointer;padding:4px 8px;border-radius:8px;line-height:1}
.drawer-close:hover{background:#334155;color:#e2e8f0}
.drawer-body{flex:1;overflow-y:auto;padding:20px 24px}
.drawer-footer{padding:16px 24px;border-top:1px solid #334155;display:flex;gap:10px;justify-content:flex-end;flex-shrink:0}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#0f172a}
::-webkit-scrollbar-thumb{background:#334155;border-radius:999px}
::-webkit-scrollbar-thumb:hover{background:#475569}
tbody tr:hover td{background:rgba(255,255,255,.035);transition:background .15s ease}
.toast{position:fixed;bottom:24px;right:24px;background:#1e293b;border:1px solid #334155;color:#f8fafc;padding:14px 20px;border-radius:12px;font-size:14px;z-index:2000;box-shadow:0 8px 24px rgba(0,0,0,.4);transform:translateY(20px);opacity:0;transition:transform .25s ease,opacity .25s ease;pointer-events:none;max-width:320px}
.toast.show{transform:translateY(0);opacity:1}
.toast.toast-success{border-color:rgba(34,197,94,.4)}
.toast.toast-error{border-color:rgba(239,68,68,.4)}
.toast{display:flex;align-items:center}
tbody tr:nth-child(even) td{background:rgba(255,255,255,.018)}
thead th{position:sticky;top:0;z-index:2;box-shadow:0 1px 0 #374151}
input:focus,select:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 2px rgba(59,130,246,.18)}
.section-title{padding-left:14px;border-left:3px solid #3b82f6}
.drawer-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#2563eb,#60a5fa);z-index:1}
@keyframes offlinePulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}50%{box-shadow:0 0 0 5px rgba(239,68,68,.13)}}
.status-offline{animation:offlinePulse 2.8s ease-in-out infinite}
.action-button:active{transform:scale(.97)}
.sidebar:not(:hover) .menu-button[data-tooltip]::after{content:attr(data-tooltip);position:absolute;left:calc(100% + 10px);top:50%;transform:translateY(-50%);background:#1e293b;color:#f8fafc;padding:6px 12px;border-radius:8px;font-size:12px;white-space:nowrap;pointer-events:none;opacity:0;border:1px solid #334155;box-shadow:0 4px 14px rgba(0,0,0,.35);z-index:9999;transition:opacity .15s ease}
.sidebar:not(:hover) .menu-button[data-tooltip]:hover::after{opacity:1}
.status-badge-online::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:#22c55e;margin-right:5px;vertical-align:middle;animation:statusDotPulse 2.2s ease-in-out infinite}
.status-badge-offline::before{content:'';display:inline-block;width:6px;height:6px;border-radius:50%;background:#ef4444;margin-right:5px;vertical-align:middle}
@keyframes statusDotPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
@keyframes drawerSlideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes drawerSlideOut{from{transform:translateX(0);opacity:1}to{transform:translateX(100%);opacity:0}}
.drawer-panel.closing{animation:drawerSlideOut .28s cubic-bezier(.4,0,.2,1) forwards}
.loading-spinner-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 20px;gap:14px}
.loading-spinner{width:36px;height:36px;border:3px solid #1f2937;border-top-color:#3b82f6;border-radius:50%;animation:spinnerRotate .7s linear infinite}
@keyframes spinnerRotate{to{transform:rotate(360deg)}}
.loading-spinner-text{font-size:13px;color:#64748b}
.summary-card-total:hover{box-shadow:0 0 24px rgba(37,99,235,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-online:hover{box-shadow:0 0 24px rgba(34,197,94,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-offline:hover{box-shadow:0 0 24px rgba(239,68,68,.28),0 8px 28px rgba(255,255,255,.1)}
.summary-card-toner:hover{box-shadow:0 0 24px rgba(234,179,8,.28),0 8px 28px rgba(255,255,255,.1)}
@keyframes badgeShake{0%,100%{transform:translateX(0)}20%{transform:translateX(-2px)}40%{transform:translateX(2px)}60%{transform:translateX(-1.5px)}80%{transform:translateX(1.5px)}}
.menu-badge[style*="flex"]{animation:badgePop .25s cubic-bezier(.34,1.56,.64,1),badgeShake .4s ease .3s 2}
@keyframes barShimmer{from{left:-100%}to{left:100%}}
.bar-fill{position:relative;overflow:hidden}
.bar-fill::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.18),transparent);animation:barShimmer 2.4s ease-in-out infinite}
@keyframes rowSlideIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.stagger-row{animation:rowSlideIn .22s ease both}
.action-button,.filter-toggle-btn,.toolbar-button{position:relative;overflow:hidden}
.btn-ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.22);transform:scale(0);animation:rippleAnim .5s ease-out;pointer-events:none}
@keyframes rippleAnim{to{transform:scale(4);opacity:0}}
@keyframes skeletonPulse{0%{background-position:-200% 0}100%{background-position:200% 0}}
.skeleton{background:linear-gradient(90deg,#1f2937 25%,#2a3a50 50%,#1f2937 75%);background-size:200% 100%;animation:skeletonPulse 1.5s ease-in-out infinite;border-radius:8px;min-height:16px}
.skeleton-row{display:flex;gap:12px;padding:10px 14px}.skeleton-cell{flex:1;height:14px}
.modal-saving-overlay{position:absolute;inset:0;background:rgba(15,23,42,.88);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;border-radius:20px;z-index:10;animation:modalFadeIn .18s ease}
.search-highlight{background:#fde047;color:#111827;border-radius:2px;padding:0 2px}
.app-modal-form .form-grid{gap:10px}
.app-modal-form .form-grid label{font-size:12px;color:#94a3b8;margin-bottom:2px}
.app-confirm-message{font-size:14px;color:#cbd5e1;line-height:1.6}
.kbd{display:inline-block;background:#1f2937;border:1px solid #374151;border-radius:4px;padding:1px 6px;font-size:11px;font-family:monospace;color:#94a3b8;margin:0 2px;vertical-align:middle}
